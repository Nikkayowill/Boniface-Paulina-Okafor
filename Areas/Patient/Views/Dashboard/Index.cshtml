@model Okafor_.NET.Areas.Patient.Controllers.PatientDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-0 px-md-2 mt-2 mt-md-4">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col">
            @if (Model.HasProfile)
            {
                <h1 class="h2">Welcome, <strong>@Model.PatientName</strong>!</h1>
                <p class="text-muted">Your patient portal dashboard - quick access to your healthcare information.</p>
            }
            else
            {
                <h1 class="h2">Welcome to Your Patient Portal!</h1>
                <p class="text-muted">
                    <a href="@Url.Action("Create", "Profile", new { area = "Patient" })" class="btn btn-primary btn-sm min-touch-target">
                        Complete Your Profile
                    </a>
                </p>
            }
        </div>
    </div>

    <!-- KPI Cards Row 1 -->
    <div class="row g-3 g-md-4 mb-4">
        <!-- Upcoming Appointments -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <p class="text-muted small mb-2">Upcoming Appointments</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.UpcomingAppointmentsCount</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Appointments", new { area = "Patient" })" class="btn btn-outline-primary btn-sm w-100 mt-auto">
                        View Appointments
                    </a>
                </div>
            </div>
        </div>

        <!-- Pending Teleconsultations -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-info mb-3">
                        <i class="bi bi-camera-video"></i>
                    </div>
                    <p class="text-muted small mb-2">Teleconsultations</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.PendingTeleconsultationsCount</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Teleconsultations", new { area = "Patient" })" class="btn btn-outline-info btn-sm w-100 mt-auto">
                        View Teleconsults
                    </a>
                </div>
            </div>
        </div>

        <!-- Unread Messages -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-success mb-3">
                        <i class="bi bi-envelope"></i>
                    </div>
                    <p class="text-muted small mb-2">Unread Messages</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.UnreadMessagesCount</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Messages", new { area = "Patient" })" class="btn btn-outline-success btn-sm w-100 mt-auto">
                        View Messages
                    </a>
                </div>
            </div>
        </div>

        <!-- Documents -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-warning mb-3">
                        <i class="bi bi-file-earmark-pdf"></i>
                    </div>
                    <p class="text-muted small mb-2">My Documents</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.PendingDocumentsCount</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Documents", new { area = "Patient" })" class="btn btn-outline-warning btn-sm w-100 mt-auto">
                        View Documents
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <a href="@Url.Action("Index", "Appointments", new { area = "Patient" })" class="btn btn-outline-primary w-100">
                                <i class="bi bi-calendar-check"></i> View Appointments
                            </a>
                        </div>
                        <div class="col-12 col-md-4">
                            <a href="@Url.Action("Index", "Messages", new { area = "Patient" })" class="btn btn-outline-info w-100">
                                <i class="bi bi-envelope"></i> Messages
                            </a>
                        </div>
                        <div class="col-12 col-md-4">
                            <a href="@Url.Action("Index", "Documents", new { area = "Patient" })" class="btn btn-outline-warning w-100">
                                <i class="bi bi-file-earmark"></i> Documents
                            </a>
                        </div>
                    </div>
                    <div class="row g-3 mt-2">
                        <div class="col-12 col-md-4">
                            <a href="@Url.Action("Index", "Teleconsultations", new { area = "Patient" })" class="btn btn-outline-success w-100">
                                <i class="bi bi-camera-video"></i> Teleconsults
                            </a>
                        </div>
                        <div class="col-12 col-md-4">
                            <a href="@Url.Action("Index", "Profile", new { area = "Patient" })" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-person"></i> Profile
                            </a>
                        </div>
                        @if (!Model.HasProfile)
                        {
                            <div class="col-12 col-md-4">
                                <a href="@Url.Action("Create", "Profile", new { area = "Patient" })" class="btn btn-primary w-100">
                                    <i class="bi bi-person-plus"></i> Create Profile
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

