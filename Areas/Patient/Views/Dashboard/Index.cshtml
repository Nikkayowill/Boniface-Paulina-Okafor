@model Okafor_.NET.Areas.Patient.Controllers.PatientDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-0 px-md-2 mt-2 mt-md-4">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col">
            <p class="text-uppercase fw-bold mb-1" style="font-size:0.72rem;letter-spacing:0.14em;color:#0a5f8f;">Patient Portal</p>
            @if (Model.HasProfile)
            {
                <h1 class="h2 fw-bold mb-1">Welcome, @Model.PatientName</h1>
                <p class="text-muted mb-0">Appointments, teleconsultations, messages, and documents in one place.</p>
            }
            else
            {
                <h1 class="h2 fw-bold mb-2">Welcome to your portal</h1>
                <a href="@Url.Action("Create", "Profile", new { area = "Patient" })" class="btn btn-primary btn-sm min-touch-target">
                    Complete Profile
                </a>
            }
        </div>
    </div>

    @if (!Model.HasProfile)
    {
        <div class="alert alert-primary border-0 shadow-sm mb-4">
            <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-md-between">
                <div>
                    <p class="text-uppercase fw-bold small mb-1">Next step</p>
                    <h2 class="h5 mb-1">Complete your patient profile</h2>
                    <p class="mb-0 small">This helps the hospital link appointments, documents, messages, and teleconsultations to your account.</p>
                </div>
                <a href="@Url.Action("Create", "Profile", new { area = "Patient" })" class="btn btn-primary min-touch-target">
                    Complete Profile
                </a>
            </div>
        </div>
    }
    else if (Model.MessagesAwaitingReviewCount > 0)
    {
        <div class="alert alert-primary border-0 shadow-sm mb-4">
            <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-md-between">
                <div>
                    <p class="text-uppercase fw-bold small mb-1">Next step</p>
                    <h2 class="h5 mb-1">Your message is awaiting review</h2>
                    <p class="mb-0 small">Hospital staff have not yet marked your message as reviewed.</p>
                </div>
                <a href="@Url.Action("Index", "Messages", new { area = "Patient" })" class="btn btn-primary min-touch-target">
                    View Messages
                </a>
            </div>
        </div>
    }
    else if (Model.PendingTeleconsultationsCount > 0)
    {
        <div class="alert alert-info border-0 shadow-sm mb-4">
            <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-md-between">
                <div>
                    <p class="text-uppercase fw-bold small mb-1">Next step</p>
                    <h2 class="h5 mb-1">Review your teleconsultation</h2>
                    <p class="mb-0 small">Check the latest status and meeting link details for virtual care.</p>
                </div>
                <a href="@Url.Action("Index", "Teleconsultations", new { area = "Patient" })" class="btn btn-outline-info min-touch-target">
                    View Teleconsults
                </a>
            </div>
        </div>
    }
    else if (Model.UpcomingAppointmentsCount > 0)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-md-between">
                <div>
                    <p class="text-uppercase fw-bold small mb-1">Next step</p>
                    <h2 class="h5 mb-1">Review your upcoming appointment</h2>
                    <p class="mb-0 small">Confirm the date, doctor, and any notes before your visit.</p>
                </div>
                <a href="@Url.Action("Index", "Appointments", new { area = "Patient" })" class="btn btn-outline-success min-touch-target">
                    View Appointments
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-light border shadow-sm mb-4">
            <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center justify-content-md-between">
                <div>
                    <p class="text-uppercase fw-bold small mb-1">Next step</p>
                    <h2 class="h5 mb-1">Need care?</h2>
                    <p class="mb-0 small">Start a new appointment request when you are ready.</p>
                </div>
                <a asp-area="" asp-controller="AppointmentRequests" asp-action="Create" class="btn btn-outline-primary min-touch-target">
                    Book Appointment
                </a>
            </div>
        </div>
    }

    <!-- KPI Cards Row 1 -->
    <div class="row g-3 g-md-4 mb-4">
        <!-- Upcoming Appointments -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100 dashboard-kpi">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-primary mb-3">
                        <svg width="44" height="44" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="4" width="18" height="17" rx="2" />
                            <path d="M8 2v4M16 2v4M3 10h18M8.5 15.5l2.2 2.2 4.8-5" />
                        </svg>
                    </div>
                    <p class="text-muted small mb-2">Upcoming Appointments</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.UpcomingAppointmentsCount</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Appointments", new { area = "Patient" })" class="btn btn-outline-primary btn-sm w-100 mt-auto">
                        View Appointments
                    </a>
                </div>
            </div>
        </div>

        <!-- Pending Teleconsultations -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100 dashboard-kpi dashboard-kpi-green">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-info mb-3">
                        <svg width="44" height="44" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="6" width="13" height="12" rx="2" />
                            <path d="m16 10 5-3v10l-5-3z" />
                        </svg>
                    </div>
                    <p class="text-muted small mb-2">Teleconsultations</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.PendingTeleconsultationsCount</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Teleconsultations", new { area = "Patient" })" class="btn btn-outline-info btn-sm w-100 mt-auto">
                        View Teleconsults
                    </a>
                </div>
            </div>
        </div>

        <!-- Messages awaiting staff review -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100 dashboard-kpi dashboard-kpi-coral">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-success mb-3">
                        <svg width="44" height="44" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="5" width="18" height="14" rx="2" />
                            <path d="m4 7 8 6 8-6" />
                        </svg>
                    </div>
                    <p class="text-muted small mb-2">Awaiting Staff Review</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.MessagesAwaitingReviewCount</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Messages", new { area = "Patient" })" class="btn btn-outline-success btn-sm w-100 mt-auto">
                        View Messages
                    </a>
                </div>
            </div>
        </div>

        <!-- Documents -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100 dashboard-kpi dashboard-kpi-gold">
                <div class="card-body d-flex flex-column text-center">
                    <div class="display-4 text-warning mb-3">
                        <svg width="44" height="44" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M7 3h7l4 4v14H7z" />
                            <path d="M14 3v5h4M9 15h6M9 18h4" />
                        </svg>
                    </div>
                    <p class="text-muted small mb-2">My Documents</p>
                    <h2 class="mb-3">
                        @if (Model.HasProfile)
                        {
                            <span>@Model.PendingDocumentsCount</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </h2>
                    <a href="@Url.Action("Index", "Documents", new { area = "Patient" })" class="btn btn-outline-warning btn-sm w-100 mt-auto">
                        View Documents
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <a asp-area="" asp-controller="AppointmentRequests" asp-action="Create" class="btn btn-outline-primary w-100 d-inline-flex align-items-center justify-content-center gap-2">
                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                                    <rect x="3" y="4" width="18" height="17" rx="2" />
                                    <path d="M8 2v4M16 2v4M3 10h18M12 14v5M9.5 16.5h5" />
                                </svg>
                                Book Appointment
                            </a>
                        </div>
                        <div class="col-12 col-md-4">
                            <a asp-area="" asp-controller="Teleconsultations" asp-action="Create" class="btn btn-outline-success w-100 d-inline-flex align-items-center justify-content-center gap-2">
                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                                    <rect x="3" y="6" width="13" height="12" rx="2" />
                                    <path d="m16 10 5-3v10l-5-3z" />
                                </svg>
                                Request Teleconsult
                            </a>
                        </div>
                        <div class="col-12 col-md-4">
                            <a href="@Url.Action("Index", "Profile", new { area = "Patient" })" class="btn btn-outline-secondary w-100 d-inline-flex align-items-center justify-content-center gap-2">
                                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                                    <circle cx="12" cy="8" r="4" />
                                    <path d="M4 21a8 8 0 0 1 16 0" />
                                </svg>
                                Update Profile
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col">
            @await Component.InvokeAsync("PushNotifications")
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/push-notifications.js" asp-append-version="true"></script>
}
