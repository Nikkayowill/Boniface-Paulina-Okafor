@model IEnumerable<Okafor_.NET.Models.PatientDocument>

@{
    ViewData["Title"] = "My Documents";
}

@if (ViewBag.HasProfile == false)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <h5 class="mb-2">Document access is not ready yet</h5>
            <p class="text-muted mb-0">Your account has not been linked to a patient profile. Please contact the hospital admin team for access to your documents.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="h5 mb-1">My Documents</h1>
                <p class="text-muted mb-0">Securely share records with the hospital and access documents added for @(ViewBag.PatientName ?? "your account").</p>
            </div>
            <a asp-area="Patient"
               asp-controller="Documents"
               asp-action="Upload"
               class="btn btn-success w-100 w-md-auto flex-shrink-0">Upload a document</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <h2 class="h6 mb-2">No documents available yet</h2>
                <p class="text-muted mb-3">Upload a referral, result, or other relevant record, or wait for hospital staff to add a document.</p>
                <a asp-area="Patient" asp-controller="Documents" asp-action="Upload" class="btn btn-success">Upload your first document</a>
            </div>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var doc in Model)
            {
                <div class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-start py-3 gap-3">
                    <div class="me-md-3 min-w-0">
                        <div class="fw-semibold mb-1">@doc.Title</div>
                        @if (!string.IsNullOrWhiteSpace(doc.Description))
                        {
                            <p class="text-muted small mb-1">@doc.Description</p>
                        }
                        <span class="text-muted" style="font-size:0.75rem;">Uploaded @doc.UploadedAt.ToString("d MMM yyyy")</span>
                    </div>
                    <a asp-area="Patient"
                       asp-controller="Documents"
                       asp-action="Download"
                       asp-route-id="@doc.Id"
                       target="_blank"
                       rel="noopener"
                       class="btn btn-sm btn-outline-secondary w-100 w-md-auto">View / Download</a>
                </div>
            }
        </div>
    }
}
