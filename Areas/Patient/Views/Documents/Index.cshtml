@model IEnumerable<Okafor_.NET.Models.PatientDocument>

@{
    ViewData["Title"] = "My Documents";
}

@if (ViewBag.HasProfile == false)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <h5 class="mb-2">Document access is not ready yet</h5>
            <p class="text-muted mb-0">Your account has not been linked to a patient profile. Please contact the hospital admin team for access to your documents.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 d-flex flex-column flex-sm-row gap-3 justify-content-between align-items-sm-center">
            <div>
                <h5 class="mb-1">My Documents</h5>
                <p class="text-muted mb-0">Securely access documents for @(ViewBag.PatientName ?? "your account").</p>
            </div>
            <a asp-area="Patient" asp-controller="Documents" asp-action="Upload"
               class="btn btn-sm btn-dark min-touch-target">Upload Document</a>
        </div>
    </div>

    @if (TempData["Success"] is string successMessage)
    {
        <div class="alert alert-success" role="status">@successMessage</div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <h6 class="mb-2">No documents available yet</h6>
                <p class="text-muted mb-3">Documents uploaded by you or hospital staff will appear here.</p>
                <a asp-area="Patient" asp-controller="Documents" asp-action="Upload"
                   class="btn btn-sm btn-outline-dark">Upload Your First Document</a>
            </div>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var doc in Model)
            {
                <div class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-start py-3 gap-3">
                    <div class="me-md-3 min-w-0">
                        <div class="fw-semibold mb-1">@doc.Title</div>
                        @if (!string.IsNullOrWhiteSpace(doc.Description))
                        {
                            <p class="text-muted small mb-1">@doc.Description</p>
                        }
                        <span class="text-muted" style="font-size:0.75rem;">Uploaded @doc.UploadedAt.ToString("d MMM yyyy")</span>
                    </div>
                    <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-md-auto">
                        <a asp-area="Patient"
                           asp-controller="Documents"
                           asp-action="Download"
                           asp-route-id="@doc.Id"
                           target="_blank"
                           rel="noopener"
                           class="btn btn-sm btn-outline-secondary">View / Download</a>
                        <form asp-area="Patient" asp-controller="Documents" asp-action="Delete"
                              asp-route-id="@doc.Id" method="post"
                              onsubmit="return confirm('Permanently delete this document?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Delete</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
}
