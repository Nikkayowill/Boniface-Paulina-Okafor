@model Okafor_.NET.Models.PatientProfile

@{
    ViewData["Title"] = "My Profile";
}

<div class="card border-0 shadow-sm" style="max-width:640px;">
    <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
            <div>
                <h1 class="h5 mb-1">My profile</h1>
                <p class="text-muted small mb-0">Keep these details current so the hospital can identify your account.</p>
            </div>
            <a asp-area="Patient" asp-controller="Profile" asp-action="Edit" class="btn btn-outline-secondary">Edit profile</a>
        </div>
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted small fw-semibold">Full Name</dt>
            <dd class="col-sm-8">@Model.FullName</dd>

            <dt class="col-sm-4 text-muted small fw-semibold">Phone</dt>
            <dd class="col-sm-8">@(Model.Phone ?? "—")</dd>

            <dt class="col-sm-4 text-muted small fw-semibold">Address</dt>
            <dd class="col-sm-8">@(Model.Address ?? "—")</dd>

            <dt class="col-sm-4 text-muted small fw-semibold">Member Since</dt>
            <dd class="col-sm-8">@Model.CreatedAt.ToString("d MMM yyyy")</dd>
        </dl>
    </div>
</div>
