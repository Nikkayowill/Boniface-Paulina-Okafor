@model Okafor_.NET.ViewModels.PatientProfileEditViewModel

@{
    ViewData["Title"] = "Complete Your Profile";
}

<div class="row justify-content-center">
<div class="col-12 col-lg-8 col-xl-6">
    <div class="card border-0 shadow-sm">
    <div class="card-body p-3 p-md-4">
        <h1 class="h5 mb-2">Complete your patient profile</h1>
        <p class="text-muted mb-4">Add your contact details so hospital staff can identify your account and support your care.</p>
        <form asp-area="Patient" asp-controller="Profile" asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-semibold">Full name</label>
                <input asp-for="FullName" class="form-control" autocomplete="name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-semibold">Phone number <span class="fw-normal text-muted">(optional)</span></label>
                <input asp-for="Phone" class="form-control" type="tel" inputmode="tel" autocomplete="tel" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Address" class="form-label fw-semibold">Address <span class="fw-normal text-muted">(optional)</span></label>
                <textarea asp-for="Address" rows="3" class="form-control" autocomplete="street-address"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-success w-100 w-md-auto">Save profile</button>
        </form>
    </div>
    </div>
</div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
