@model Okafor_.NET.ViewModels.PatientProfileEditViewModel

@{
    ViewData["Title"] = "Complete Your Profile";
}

<div class="card border-0 shadow-sm" style="max-width:520px;">
    <div class="card-body p-4">
        <p class="text-muted small mb-4">Please fill in your details to activate your patient portal.</p>
        <form asp-area="Patient" asp-controller="Profile" asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label small fw-semibold">Full Name</label>
                <input asp-for="FullName" class="form-control form-control-sm" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Phone" class="form-label small fw-semibold">Phone Number</label>
                <input asp-for="Phone" class="form-control form-control-sm" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Address" class="form-label small fw-semibold">Address</label>
                <textarea asp-for="Address" rows="3" class="form-control form-control-sm"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-sm btn-dark">Save Profile</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
