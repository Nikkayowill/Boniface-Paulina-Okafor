@model Okafor_.NET.ViewModels.AdminUploadDocumentViewModel

@{
    ViewData["Title"] = "Upload Document — " + ViewBag.PatientName;
}

<div class="card border-0 shadow-sm" style="max-width:540px;">
    <div class="card-body p-4">
        <p class="text-muted small mb-4">Upload a PDF or image file for <strong>@ViewBag.PatientName</strong>.</p>
        <form asp-area="Admin" asp-controller="PatientProfiles" asp-action="UploadDocument"
              method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="PatientProfileId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label small fw-semibold">Title</label>
                <input asp-for="Title" class="form-control form-control-sm" placeholder="e.g. Blood Test Results – April 2026" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label small fw-semibold">Description <span class="fw-normal text-muted">(optional)</span></label>
                <textarea asp-for="Description" rows="2" class="form-control form-control-sm"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="File" class="form-label small fw-semibold">File <span class="fw-normal text-muted">(PDF, JPG, JPEG, PNG, WebP — max 10 MB)</span></label>
                <input asp-for="File" type="file" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                <span asp-validation-for="File" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-dark">Upload</button>
                <a asp-area="Admin" asp-controller="PatientProfiles" asp-action="Details"
                   asp-route-id="@Model.PatientProfileId" class="btn btn-sm btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
