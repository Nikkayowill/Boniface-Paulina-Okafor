@model Okafor_.NET.Models.ContactSubmission

@{
    ViewData["Title"] = "Contact Submission";
    var replySubject = Uri.EscapeDataString($"Re: {Model.Subject}");
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back to submissions</a>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <article class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <p class="text-uppercase text-muted fw-semibold small mb-1">Subject</p>
                <h1 class="h4 text-break mb-4">@Model.Subject</h1>
                <p class="mb-0 text-break" style="white-space:pre-wrap">@Model.Message</p>
                <p class="small text-muted mt-4 mb-0">Submitted @Model.SubmittedAt.ToString("dddd, d MMMM yyyy 'at' h:mm tt")</p>
            </div>
        </article>
    </div>

    <aside class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h6">Contact details</h2>
                <dl class="small mb-4">
                    <dt class="text-muted mt-3">Name</dt>
                    <dd class="mb-0">@Model.Name</dd>
                    <dt class="text-muted mt-3">Email</dt>
                    <dd class="mb-0 text-break">@Model.Email</dd>
                </dl>
                <div class="d-grid gap-2">
                    <a href="mailto:@Model.Email?subject=@replySubject" class="btn btn-primary">Reply by email</a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Permanently delete this submission?');">
                        <button type="submit" class="btn btn-outline-danger w-100">Delete submission</button>
                    </form>
                </div>
            </div>
        </div>
    </aside>
</div>
