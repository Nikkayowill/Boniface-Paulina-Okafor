@model Okafor_.NET.Models.ContactSubmission

@{
    ViewData["Title"] = "Contact Submission Details";
}

<h1 class="mb-4">Contact Submission</h1>

<div class="card mb-4" style="max-width:640px">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9"><a href="mailto:@Model.Email">@Model.Email</a></dd>

            <dt class="col-sm-3">Subject</dt>
            <dd class="col-sm-9">@Model.Subject</dd>

            <dt class="col-sm-3">Submitted</dt>
            <dd class="col-sm-9">@Model.SubmittedAt.ToString("MMMM d, yyyy HH:mm")</dd>

            <dt class="col-sm-3">Message</dt>
            <dd class="col-sm-9" style="white-space:pre-wrap">@Model.Message</dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
          onsubmit="return confirm('Delete this submission?')">
        <button type="submit" class="btn btn-outline-danger">Delete</button>
    </form>
</div>
