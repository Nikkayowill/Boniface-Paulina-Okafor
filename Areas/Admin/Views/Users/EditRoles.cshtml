@model Okafor_.NET.ViewModels.EditRolesViewModel

@{
    ViewData["Title"] = "Edit Roles";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&larr; Back</a>
    <h1 class="mb-0">Edit Roles</h1>
</div>

<div class="card shadow-sm" style="max-width:480px">
    <div class="card-body">
        <p class="text-muted small mb-4">Managing roles for: <strong>@Model.Email</strong></p>

        <form asp-action="EditRoles" method="post">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Email" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="IsAdmin" class="form-check-input" id="isAdmin" />
                    <label class="form-check-label fw-semibold" for="isAdmin">Admin</label>
                    <div class="form-text">Full access to all administration features.</div>
                </div>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="IsStaff" class="form-check-input" id="isStaff" />
                    <label class="form-check-label fw-semibold" for="isStaff">Staff</label>
                    <div class="form-text">Limited access to view appointments and patient data.</div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Roles</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
