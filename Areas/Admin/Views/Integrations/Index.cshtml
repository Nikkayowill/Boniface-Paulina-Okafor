@model Okafor_.NET.ViewModels.IntegrationReadinessViewModel

@{
    ViewData["Title"] = "Integration Readiness";
}

<div class="mb-4">
    <p class="text-uppercase fw-bold mb-1" style="font-size:0.72rem;letter-spacing:0.14em;color:#0a5f8f;">Launch Operations</p>
    <h1 class="mb-1 fw-bold">Integration Readiness</h1>
    <p class="text-muted mb-0 small">Configuration presence only for the @Model.EnvironmentName environment. Secret values are never displayed.</p>
</div>

<div class="alert alert-warning" role="note">
    <strong>Configured does not mean provider-tested.</strong> Each live integration still needs a controlled staging request, callback or delivery check before launch.
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body"><span class="text-muted small">Configured</span><strong class="d-block fs-3">@Model.ConfiguredCount / @Model.Integrations.Count</strong></div></div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body"><span class="text-muted small">Launch-required configured</span><strong class="d-block fs-3">@Model.RequiredConfiguredCount / @Model.RequiredCount</strong></div></div>
    </div>
</div>

<div class="row g-3">
    @foreach (var integration in Model.Integrations)
    {
        <div class="col-12 col-xl-6">
            <article class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                        <div>
                            <h2 class="h5 mb-1">@integration.Name</h2>
                            <p class="text-muted small mb-0">@integration.Purpose</p>
                        </div>
                        <div class="d-flex gap-2">
                            @if (integration.IsRequiredForLaunch)
                            {
                                <span class="badge bg-primary">Launch required</span>
                            }
                            <span class="badge @(integration.IsConfigured ? "bg-success" : integration.IsRequiredForLaunch ? "bg-warning text-dark" : "bg-secondary")">
                                @(integration.IsConfigured ? "Configured" : integration.IsRequiredForLaunch ? "Needs setup" : "Not configured")
                            </span>
                        </div>
                    </div>

                    <dl class="mt-3 mb-0 small">
                        <dt>Activation</dt>
                        <dd class="text-muted">@integration.ActivationMode</dd>
                        @if (integration.MissingKeys.Count > 0)
                        {
                            <dt>Missing configuration keys</dt>
                            <dd>
                                <ul class="mb-2 ps-3">
                                    @foreach (var key in integration.MissingKeys)
                                    {
                                        <li><code>@key.Replace(":", "__")</code></li>
                                    }
                                </ul>
                            </dd>
                        }
                        <dt>Next verification</dt>
                        <dd class="text-muted mb-0">@integration.SetupHint</dd>
                    </dl>
                </div>
            </article>
        </div>
    }
</div>
