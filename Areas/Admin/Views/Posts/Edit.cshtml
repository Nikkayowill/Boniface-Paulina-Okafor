@model Okafor_.NET.ViewModels.CmsPostViewModel

@{
    ViewData["Title"] = "Edit Post";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Edit Post</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Posts</a>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <input asp-for="Id" type="hidden" />
    <input asp-for="CreatedAt" type="hidden" />
    <input asp-for="ExistingThumbnailUrl" type="hidden" />

    <div class="row g-4">

        @* Main column *@
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header fw-semibold small text-uppercase text-muted">Content</div>
                <div class="card-body">

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control form-control-lg" maxlength="120" autocomplete="off" />
                        <div class="form-text">Write for one real patient or community question. Avoid vague titles and keyword lists.</div>
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text text-muted small">/news/</span>
                            <input asp-for="Slug" class="form-control" maxlength="220"
                                   pattern="[a-z0-9]+(?:-[a-z0-9]+)*" autocomplete="off" />
                        </div>
                        <div class="form-text text-warning">Changing the slug will break existing links to this post.</div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Summary" class="form-label fw-semibold">Summary / Excerpt</label>
                        <textarea asp-for="Summary" class="form-control" rows="3" maxlength="300"
                                  aria-describedby="summary-help"></textarea>
                        <div id="summary-help" class="form-text">
                            Used in search results and shares. Be specific; do not repeat the title or list keywords.
                            <span class="float-end"><span data-character-count-for="Summary">0</span>/300</span>
                        </div>
                        <span asp-validation-for="Summary" class="text-danger small"></span>
                    </div>

                    <div class="mb-0">
                        <label asp-for="Content" class="form-label fw-semibold"></label>
                        <textarea asp-for="Content" class="form-control font-monospace" rows="18"
                                  aria-describedby="content-help"></textarea>
                        <div id="content-help" class="form-text">
                            Blank lines create paragraphs. End a short line with <code>:</code> for a heading.
                            Start lines with <code>-</code> for bullets or <code>1.</code> for numbered steps.
                            @if (Model.Content.Contains('<', StringComparison.Ordinal))
                            {
                                <span class="d-block text-warning">
                                    This older post contains HTML tags. The public page strips unsafe markup; remove the tags as you revise the copy.
                                </span>
                            }
                        </div>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                </div>
            </div>
        </div>

        @* Sidebar column *@
        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-header fw-semibold small text-uppercase text-muted">Publish</div>
                <div class="card-body">
                    <div class="form-check mb-2">
                        <input asp-for="Published" class="form-check-input" type="checkbox" />
                        <label asp-for="Published" class="form-check-label">Published</label>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                        <label asp-for="IsFeatured" class="form-check-label">★ Featured on homepage</label>
                    </div>
                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                    <hr />
                    <p class="small text-muted mb-0">
                        Created: @Model.CreatedAt.ToString("dd MMM yyyy")
                        @if (Model.CreatedAt != default)
                        {
                            <span class="d-block">UTC @Model.CreatedAt.ToString("HH:mm")</span>
                        }
                    </p>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header fw-semibold small text-uppercase text-muted">Before publishing</div>
                <div class="card-body">
                    <ul class="small text-muted ps-3 mb-0">
                        <li>Reconfirm dates, services, prices, staffing, and contact details.</li>
                        <li>Name the source or reviewer for medical guidance.</li>
                        <li>Remove patient-identifying information unless permission is documented.</li>
                        <li>Keep the next step clear.</li>
                    </ul>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header fw-semibold small text-uppercase text-muted">Thumbnail</div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ExistingThumbnailUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.ExistingThumbnailUrl" alt="Current thumbnail"
                                 class="img-fluid rounded" style="max-height:160px;object-fit:cover;" />
                        </div>
                        <p class="small text-muted mb-2">Upload a new image to replace the current thumbnail.</p>
                    }
                    else
                    {
                        <p class="small text-muted mb-2">JPG, JPEG, PNG, or WebP only (max 5 MB)</p>
                    }
                    <input asp-for="Thumbnail" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="Thumbnail" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var summaryEl = document.getElementById('Summary');
        var summaryCountEl = document.querySelector('[data-character-count-for="Summary"]');

        function updateSummaryCount() {
            summaryCountEl.textContent = summaryEl.value.length;
        }

        summaryEl.addEventListener('input', updateSummaryCount);
        updateSummaryCount();
    </script>
}
