@model Okafor_.NET.ViewModels.CmsPostViewModel

@{
    ViewData["Title"] = "New Post";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">New Post</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Posts</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-4">

        @* Main column *@
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header fw-semibold small text-uppercase text-muted">Content</div>
                <div class="card-body">

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" id="Title" class="form-control form-control-lg" placeholder="Post title" autocomplete="off" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text text-muted small">/news/</span>
                            <input asp-for="Slug" id="Slug" class="form-control" placeholder="post-slug" autocomplete="off" />
                        </div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Summary" class="form-label fw-semibold">Summary / Excerpt</label>
                        <textarea asp-for="Summary" class="form-control" rows="2"
                                  placeholder="Short description displayed on the blog listing page (max 500 characters, optional)"></textarea>
                        <span asp-validation-for="Summary" class="text-danger small"></span>
                    </div>

                    <div class="mb-0">
                        <label asp-for="Content" class="form-label fw-semibold"></label>
                        <textarea asp-for="Content" class="form-control" rows="14" placeholder="Write post content..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                </div>
            </div>
        </div>

        @* Sidebar column *@
        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-header fw-semibold small text-uppercase text-muted">Publish</div>
                <div class="card-body">
                    <div class="form-check mb-2">
                        <input asp-for="Published" class="form-check-input" type="checkbox" />
                        <label asp-for="Published" class="form-check-label">Published</label>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                        <label asp-for="IsFeatured" class="form-check-label">★ Featured on homepage</label>
                    </div>
                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Create Post</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header fw-semibold small text-uppercase text-muted">Thumbnail</div>
                <div class="card-body">
                    <p class="small text-muted mb-2">JPG, JPEG, PNG, or WebP only (max 5 MB)</p>
                    <input asp-for="Thumbnail" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="Thumbnail" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/tinymce/tinymce.min.js" asp-append-version="true"></script>
    <script>
        if (window.tinymce) {
            tinymce.init({
                selector: '#Content',
                license_key: 'gpl',
                menubar: false,
                statusbar: false,
                plugins: 'lists link',
                toolbar: 'undo redo | blocks | bold italic | bullist numlist | link | removeformat',
                block_formats: 'Paragraph=p;Heading 2=h2;Heading 3=h3;Heading 4=h4',
                branding: false,
                promotion: false,
                height: 380
            });
        }

        var titleEl = document.getElementById('Title');
        var slugEl = document.getElementById('Slug');

        function toSlug(text) {
            return text.toLowerCase().trim()
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
        }

        titleEl.addEventListener('input', function () {
            if (!slugEl.dataset.userEdited) {
                slugEl.value = toSlug(this.value);
            }
        });

        slugEl.addEventListener('input', function () {
            this.dataset.userEdited = '1';
        });
    </script>
}
