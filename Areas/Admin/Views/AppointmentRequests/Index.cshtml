@model IEnumerable<Okafor_.NET.Models.AppointmentRequest>

@{
    ViewData["Title"] = "Appointment Requests";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-3">
    <h1 class="mb-0 h2">Appointment Requests</h1>
    <span class="badge bg-secondary"><span data-booking-pending-count="appointment">@Model.Count(x => x.Status == Okafor_.NET.Models.AppointmentStatus.Pending)</span> pending / @Model.Count() total</span>
</div>
<div class="alert alert-info d-none small" data-booking-realtime role="status" aria-live="polite"></div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show small" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-md-none">
    @if (Model.Any())
    {
        <div class="vstack gap-3">
            @foreach (var item in Model)
            {
                <article class="card border-0 shadow-sm" data-booking-row="appointment:@item.Id">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="min-w-0">
                                <h2 class="h6 mb-1 text-truncate">@item.PatientName</h2>
                                <p class="small text-muted mb-0 text-truncate">@(item.Email ?? item.Phone ?? "No contact provided")</p>
                            </div>
                            @switch (item.Status)
                            {
                                case Okafor_.NET.Models.AppointmentStatus.Pending:
                                    <span class="badge bg-warning text-dark" data-booking-status="appointment:@item.Id">Pending</span>
                                    break;
                                case Okafor_.NET.Models.AppointmentStatus.Approved:
                                    <span class="badge bg-success" data-booking-status="appointment:@item.Id">Approved</span>
                                    break;
                                case Okafor_.NET.Models.AppointmentStatus.Rejected:
                                    <span class="badge bg-danger" data-booking-status="appointment:@item.Id">Rejected</span>
                                    break;
                                case Okafor_.NET.Models.AppointmentStatus.Cancelled:
                                    <span class="badge bg-secondary" data-booking-status="appointment:@item.Id">Cancelled</span>
                                    break;
                            }
                        </div>
                        <dl class="row small mb-3 g-2">
                            <dt class="col-5 text-muted">Department</dt>
                            <dd class="col-7 mb-0 text-end">@(item.Department?.Name ?? "Unassigned")</dd>
                            <dt class="col-5 text-muted">Doctor</dt>
                            <dd class="col-7 mb-0 text-end">@(item.Doctor?.FullName ?? "Unassigned")</dd>
                            <dt class="col-5 text-muted">Date</dt>
                            <dd class="col-7 mb-0 text-end">@item.PreferredDate.ToString("MM/dd/yyyy")</dd>
                            <dt class="col-5 text-muted">Received</dt>
                            <dd class="col-7 mb-0 text-end">@item.CreatedAt.ToString("MM/dd/yyyy")</dd>
                        </dl>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary w-100">Review</a>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <p class="mb-1">No appointment requests found.</p>
                <small>Requests submitted through the public booking form will appear here.</small>
            </div>
        </div>
    }
</div>

<div class="table-responsive d-none d-md-block">
<table class="table table-hover align-middle mb-0">
    <thead class="table-dark">
        <tr>
            <th>Patient</th>
            <th>Department</th>
            <th>Doctor</th>
            <th>Date / Time</th>
            <th>Status</th>
            <th>Contact</th>
            <th>Received</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            <tr data-booking-row="appointment:@item.Id">
                <td>
                    <strong>@item.PatientName</strong>
                    @if (!string.IsNullOrWhiteSpace(item.Email))
                    {
                        <br /><small class="text-muted">@item.Email</small>
                    }
                    else if (!string.IsNullOrWhiteSpace(item.Phone))
                    {
                        <br /><small class="text-muted">@item.Phone</small>
                    }
                </td>
                <td class="small">@(item.Department?.Name ?? "—")</td>
                <td class="small">@(item.Doctor?.FullName ?? "<em>Unassigned</em>")</td>
                <td class="small">
                    @item.PreferredDate.ToString("d MMM yyyy")
                    @if (!string.IsNullOrWhiteSpace(item.PreferredTime))
                    {
                        <br /><span class="text-muted">@item.PreferredTime</span>
                    }
                </td>
                <td>
                    @switch (item.Status)
                    {
                        case Okafor_.NET.Models.AppointmentStatus.Pending:
                            <span class="badge bg-warning text-dark" data-booking-status="appointment:@item.Id">Pending</span>
                            break;
                        case Okafor_.NET.Models.AppointmentStatus.Approved:
                            <span class="badge bg-success" data-booking-status="appointment:@item.Id">Approved</span>
                            break;
                        case Okafor_.NET.Models.AppointmentStatus.Rejected:
                            <span class="badge bg-danger" data-booking-status="appointment:@item.Id">Rejected</span>
                            break;
                        case Okafor_.NET.Models.AppointmentStatus.Cancelled:
                            <span class="badge bg-secondary" data-booking-status="appointment:@item.Id">Cancelled</span>
                            break;
                    }
                </td>
                <td>
                    @if (item.ContactConfirmed)
                    {
                        <span class="badge bg-success">@item.ContactMethod</span>
                    }
                    else
                    {
                        <span class="badge bg-light text-dark border">Pending</span>
                    }
                </td>
                <td class="small text-muted">@item.CreatedAt.ToString("d MMM yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Review</a>
                </td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="8" class="text-center text-muted py-5">
                <p class="mb-1">No appointment requests found.</p>
                <small>Requests submitted through the public booking form will appear here.</small>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
