@model Okafor_.NET.Models.AppointmentRequest

@{
    ViewData["Title"] = "Appointment Request Details";
}

<h1>Appointment Request Details</h1>

<dl class="row">
    <dt class="col-sm-3">Patient Name</dt>
    <dd class="col-sm-9">@Model.PatientName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Phone</dd>

    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@(Model.Department?.Name ?? "N/A")</dd>

    <dt class="col-sm-3">Doctor</dt>
    <dd class="col-sm-9">@(Model.Doctor?.FullName ?? "Unassigned")</dd>

    <dt class="col-sm-3">Preferred Date</dt>
    <dd class="col-sm-9">@Model.PreferredDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Message</dt>
    <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.Message) ? Model.Message : "N/A")</dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
