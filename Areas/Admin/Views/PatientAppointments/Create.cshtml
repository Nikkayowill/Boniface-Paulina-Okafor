@model Okafor_.NET.ViewModels.AdminPatientAppointmentViewModel

@{
    ViewData["Title"] = "Add Appointment";
}

<div class="card border-0 shadow-sm" style="max-width:560px;">
    <div class="card-body p-4">
        <form asp-area="Admin" asp-controller="PatientAppointments" asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label asp-for="PatientProfileId" class="form-label small fw-semibold">Patient</label>
                <select asp-for="PatientProfileId" asp-items="ViewBag.Patients" class="form-select form-select-sm">
                    <option value="">— Select patient —</option>
                </select>
                <span asp-validation-for="PatientProfileId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DepartmentId" class="form-label small fw-semibold">Department</label>
                <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select form-select-sm">
                    <option value="">— Select department —</option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DoctorId" class="form-label small fw-semibold">Doctor <span class="fw-normal text-muted">(optional)</span></label>
                <select asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-select form-select-sm">
                    <option value="">— Any available —</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="AppointmentDate" class="form-label small fw-semibold">Date &amp; Time</label>
                <input asp-for="AppointmentDate" type="datetime-local" class="form-control form-control-sm" />
                <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label small fw-semibold">Status</label>
                <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select form-select-sm"></select>
            </div>
            <div class="mb-4">
                <label asp-for="Notes" class="form-label small fw-semibold">Notes <span class="fw-normal text-muted">(optional)</span></label>
                <textarea asp-for="Notes" rows="3" class="form-control form-control-sm"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-dark">Save</button>
                <a asp-area="Admin" asp-controller="PatientProfiles" asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
