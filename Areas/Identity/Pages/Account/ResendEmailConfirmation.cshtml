@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend Confirmation Email";
}

<section class="bg-bone-100 py-14 sm:py-20 min-h-[60vh] flex items-center">
    <div class="mx-auto w-full max-w-md px-4 sm:px-6">
        <div class="bg-bone-50 border border-bone-300 p-6 sm:p-8">
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-teal-700">Patient Portal</p>
            <h1 class="mt-2 font-serif text-2xl font-bold text-[#1c1c1c]">Resend confirmation email</h1>

            @if (Model.RequestCompleted)
            {
                <div class="mt-5 border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm leading-6 text-emerald-900" role="status">
                    If an unconfirmed account exists for that email, a new confirmation message has been sent.
                </div>
                <a asp-page="./Login" class="ok-btn ok-btn-primary mt-6 w-full">Return to sign in</a>
            }
            else
            {
                <p class="mt-3 text-sm leading-6 text-[#5c5c5c]">Enter the email used to create your account.</p>
                <form method="post" class="mt-6 space-y-5">
                    <div asp-validation-summary="ModelOnly" class="border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" role="alert"></div>
                    <div>
                        <label asp-for="Input.Email" class="ok-form-label">Email address</label>
                        <input asp-for="Input.Email" class="ok-field" type="email" inputmode="email" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <button type="submit" class="ok-btn ok-btn-primary w-full">Send confirmation email</button>
                </form>
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
