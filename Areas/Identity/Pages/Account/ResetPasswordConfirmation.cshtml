@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password reset";
}

<section class="bg-bone-100 py-20 min-h-[60vh] flex items-center">
    <div class="mx-auto w-full max-w-md px-6 text-center">
        <div class="bg-bone-50 border border-bone-300 p-10">
            <!-- Icon -->
            <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center bg-teal-100">
                <svg class="h-7 w-7 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h1 class="font-serif text-2xl font-bold text-[#1c1c1c] mb-3">Password Reset</h1>
            <p class="text-sm text-[#5c5c5c] leading-relaxed">
                Your password has been successfully reset. You can now sign in with your new credentials.
            </p>
            <div class="mt-8">
                <a asp-page="./Login" class="inline-flex items-center gap-2 bg-teal-800 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-colors hover:bg-teal-700">
                    Sign In
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>
