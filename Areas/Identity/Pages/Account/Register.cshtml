@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="account-shell">
    <div class="mx-auto w-full max-w-md px-6">

        <!-- Header -->
        <div class="mb-8 text-center">
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-teal-600 mb-1">Patient Portal</p>
            <h1 class="font-serif text-3xl font-bold text-[#1c1c1c]">Create an Account</h1>
            <p class="mt-2 text-sm text-[#5c5c5c]">Register to manage your appointments and records</p>
        </div>

        <div class="account-card">

            <div asp-validation-summary="ModelOnly" class="mb-5 border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" role="alert"></div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-5">

                <div>
                    <label asp-for="Input.Email" class="ok-form-label">Email address</label>
                    <input asp-for="Input.Email" class="ok-field" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="ok-form-label">Password</label>
                    <input asp-for="Input.Password" class="ok-field" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.ConfirmPassword" class="ok-form-label">Confirm password</label>
                    <input asp-for="Input.ConfirmPassword" class="ok-field" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <button id="registerSubmit" type="submit" class="site-button site-button--primary w-full">
                    Create Account
                </button>

            </form>

            <div class="mt-6 border-t border-bone-300 pt-5 text-center">
                <p class="text-sm text-[#5c5c5c]">
                    Already have an account?
                    <a asp-page="./Login" class="font-medium text-teal-700 hover:text-teal-900">Sign in here</a>
                </p>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
