@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirm your account";
}

<section class="bg-bone-100 py-20 min-h-[60vh] flex items-center">
    <div class="mx-auto w-full max-w-md px-6 text-center">
        <div class="bg-bone-50 border border-bone-300 p-10">
            <!-- Icon -->
            <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center bg-teal-100">
                <svg class="h-7 w-7 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
            </div>
            <h1 class="font-serif text-2xl font-bold text-[#1c1c1c] mb-3">Almost There</h1>
            @if (Model.DisplayConfirmAccountLink)
            {
                <p class="text-sm text-[#5c5c5c] leading-relaxed mb-4">
                    No email sender is configured yet. For development, use the link below to confirm your account.
                </p>
                <a id="confirm-link" href="@Model.EmailConfirmationUrl"
                   class="inline-block text-sm font-medium text-teal-700 underline underline-offset-2 hover:text-teal-900">
                    Click here to confirm your account
                </a>
            }
            else
            {
                <p class="text-sm text-[#5c5c5c] leading-relaxed">
                    Please check your email to confirm your account before signing in.
                </p>
            }
            <div class="mt-8">
                <a asp-page="./Login" class="inline-flex items-center gap-2 bg-teal-800 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-colors hover:bg-teal-700">
                    Back to Sign In
                </a>
            </div>
        </div>
    </div>
</section>

