@model Okafor_.NET.ViewModels.PublicHomeIndexViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Okafor_.NET.Services.ILaunchFeatureAvailability LaunchFeatures

@{
    ViewData["Title"] = "Home";
    ViewData["PageTitle"] = "Hospital in Isuochi, Abia State | Okafor Memorial Hospital";
    ViewData["MetaDescription"] = "Book visits, request teleconsultations, find hospital services, and read plain-language health guidance from Boniface and Paulina Okafor Memorial Hospital in Abia State, Nigeria.";
    ViewData["CanonicalPath"] = "/";

    var hospitalName = Configuration["Hospital:Name"] ?? "Boniface and Paulina Okafor Memorial Hospital";
    var hospitalAddress = Configuration["Hospital:Address"];
    var hospitalEmail = Configuration["Hospital:Email"];
    var emergencyNumbers = Configuration["Hospital:EmergencyNumbers"];
    var mapUrl = Configuration["Hospital:GoogleMapEmbedUrl"];

    string Excerpt(string? text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length > maxLength ? text[..maxLength] + "..." : text;
    }

    var heroSlides = new[]
    {
        new { Image = "/images/placeholders/Hospital/WVHK5210.webp", MobileImage = "/images/placeholders/Hospital/WVHK5210-mobile.webp", Width = 1600, Height = 1200, Alt = "Patients and families gathered at Boniface and Paulina Okafor Memorial Hospital", Caption = "Community-centred care in Isuochi" },
        new { Image = "/images/placeholders/Hospital/ASOM7222.webp", MobileImage = "/images/placeholders/Hospital/ASOM7222-mobile.webp", Width = 1600, Height = 1200, Alt = "Hospital staff and visiting supporters outside the hospital", Caption = "The people behind our hospital mission" },
        new { Image = "/images/placeholders/Hospital/GOEH7326.webp", MobileImage = "/images/placeholders/Hospital/GOEH7326-mobile.webp", Width = 1080, Height = 809, Alt = "Boniface and Paulina Okafor Memorial Hospital sign", Caption = "Built in memory, rooted in service" },
        new { Image = "/images/placeholders/Hospital/PTXN7478.webp", MobileImage = "/images/placeholders/Hospital/PTXN7478-mobile.webp", Width = 1600, Height = 1200, Alt = "Community members attending a hospital outreach gathering", Caption = "Health outreach for local families" }
    };
    var portraitImage = "/images/placeholders/Hospital/GQVT1373.webp";
    var missionImage = "/images/placeholders/Hospital/ASOM7222.webp";
    var signImage = "/images/placeholders/Hospital/GOEH7326.webp";
    var corridorImage = "/images/placeholders/Hospital/UDIU2949.webp";
    var gatheringImage = "/images/placeholders/Hospital/PTXN7478.webp";

    var services = Model.FeaturedDepartments?.Take(4).ToList() ?? new List<Okafor_.NET.Models.Department>();
    var latestPosts = Model.LatestPosts?.Take(3).ToList() ?? new List<Okafor_.NET.Models.Post>();

    var careRoutes = new[]
    {
        new { Label = "Appointments", Title = "Request a visit", Body = "Tell us the department, doctor, and time that works for you. The hospital team will review your request.", Controller = "AppointmentRequests", Action = "Create" },
        new { Label = "Virtual care", Title = "Ask about teleconsultation", Body = "Use remote care for questions or follow-ups when the clinical team says it is appropriate.", Controller = "Teleconsultations", Action = "Create" },
        new { Label = "Bills", Title = "Pay a hospital bill", Body = "Pay online and keep your receipt for your records.", Controller = "BillPayments", Action = "Index" },
        new { Label = "Support", Title = "Support patient care", Body = "Give toward the hospital mission and help care reach families who need it.", Controller = "Donation", Action = "Index" }
    };

    var educationTopics = new[]
    {
        "Malaria prevention",
        "High blood pressure",
        "Diabetes awareness",
        "AIDS education",
        "Maternal health",
        "Infant care"
    };

    var trustPoints = new[]
    {
        "Care close to home for families in Isuochi and nearby communities",
        LaunchFeatures.IsEnabled(Okafor_.NET.Services.LaunchFeature.BillPayments)
            ? "Clear online paths for appointments, teleconsultation, payment, and contact"
            : "Clear online paths for appointments, teleconsultation, donations, and contact",
        "Plain-language education on common preventable conditions",
        "Attention to mothers, infants, seniors, and vulnerable patients",
        "Built in memory of Boniface and Paulina Okafor"
    };
}

<div class="public-home hospital-home">
    <section class="hospital-hero" aria-labelledby="home-hero-title">
        <div class="hospital-hero__content public-wrap">
            <div class="hospital-hero__copy reveal">
                <h1 id="home-hero-title">Boniface and Paulina Okafor Memorial Hospital</h1>
                <p class="hospital-hero__lead">
                    Request a visit, ask about remote care, or find clear health guidance before you come in.
                </p>
                <div class="hospital-hero__actions" aria-label="Primary actions">
                    <a asp-controller="AppointmentRequests" asp-action="Create" class="site-button site-button--primary">Request appointment</a>
                    <a asp-controller="Teleconsultations" asp-action="Create" class="site-button site-button--light">Ask about teleconsultation</a>
                </div>
            </div>
        </div>

        <div class="hospital-hero__carousel reveal"
             data-hero-carousel
             role="region"
             aria-roledescription="carousel"
             aria-label="Hospital and community photographs">
            <div class="hospital-hero__viewport" data-carousel-viewport>
                <div class="hospital-hero__track" data-carousel-track>
                    @for (var slideIndex = 0; slideIndex < heroSlides.Length; slideIndex++)
                    {
                        var slide = heroSlides[slideIndex];
                        var isCurrentSlide = slideIndex == 0;
                        <figure class="hospital-hero__slide@(isCurrentSlide ? " is-active" : string.Empty)"
                                data-carousel-slide
                                data-carousel-label="@slide.Caption"
                                aria-hidden="@(isCurrentSlide ? "false" : "true")">
                            <picture>
                                <source media="(max-width: 719px)" srcset="@slide.MobileImage" />
                                <img src="@slide.Image"
                                     width="@slide.Width"
                                     height="@slide.Height"
                                     onerror="this.onerror=null;this.src='/images/placeholders/placeholder.svg'"
                                     alt="@slide.Alt"
                                     loading="@(isCurrentSlide ? "eager" : "lazy")"
                                     fetchpriority="@(isCurrentSlide ? "high" : "low")"
                                     decoding="async" />
                            </picture>
                            <figcaption>@slide.Caption</figcaption>
                        </figure>
                    }
                </div>
            </div>

            <div class="hospital-hero__carousel-ui">
                <div class="hospital-hero__indicators" aria-label="Choose a carousel image">
                    @for (var slideIndex = 0; slideIndex < heroSlides.Length; slideIndex++)
                    {
                        <button type="button"
                                data-carousel-go="@slideIndex"
                                aria-label="Show image @(slideIndex + 1)"
                                aria-current="@(slideIndex == 0 ? "true" : "false")"></button>
                    }
                </div>
                <div class="hospital-hero__controls">
                    <button type="button" data-carousel-prev aria-label="Previous image">←</button>
                    <button type="button" data-carousel-toggle aria-label="Pause image carousel">Pause</button>
                    <button type="button" data-carousel-next aria-label="Next image">→</button>
                </div>
            </div>
            <p class="sr-only" data-carousel-status aria-live="polite"></p>
        </div>

        <div class="hospital-care-dock public-wrap reveal" aria-label="Care shortcuts">
            <a asp-controller="Home" asp-action="Contact">
                <span>Emergency line</span>
                <strong>@(!string.IsNullOrWhiteSpace(emergencyNumbers) ? emergencyNumbers : "Contact hospital")</strong>
            </a>
            <a asp-controller="Home" asp-action="Services">
                <span>Services</span>
                <strong>Choose a department</strong>
            </a>
            <a asp-controller="Home" asp-action="PatientInformationHub">
                <span>Patient information</span>
                <strong>Prevention guides</strong>
            </a>
        </div>
    </section>

    <section class="hospital-section hospital-section--intro" aria-labelledby="intro-title">
        <div class="public-wrap hospital-intro">
            <div class="hospital-intro__statement reveal">
                <p class="hospital-kicker">Start here</p>
                <h2 id="intro-title">Know the next step before you arrive.</h2>
            </div>
            <div class="hospital-intro__text reveal">
                <p>
                    Use this page to request a visit, ask about remote care, read prevention guidance, or contact the hospital team for current details.
                </p>
                <a asp-controller="Home" asp-action="Contact" class="hospital-text-link">Contact the hospital</a>
            </div>
        </div>
    </section>

    <section class="hospital-partner" aria-labelledby="partner-title">
        <div class="public-wrap hospital-partner__grid">
            <div class="hospital-partner__mark" aria-hidden="true">NFHP</div>
            <div class="hospital-partner__copy">
                <p class="hospital-kicker">Hospital support partner</p>
                <h2 id="partner-title">Care strengthened by the Nigeria Family Helper Program.</h2>
                <p>
                    The program helps advance accessible, subsidized healthcare and supports the hospital's work with mothers, infants, seniors, and families in vulnerable circumstances.
                </p>
            </div>
            <a href="https://www.nigeriafamilyhelperprogram.org/boniface-and-paulina-okafor-hospital"
               target="_blank"
               rel="noopener noreferrer"
               class="site-button site-button--secondary">
                Visit partner website
                <span aria-hidden="true">↗</span>
            </a>
        </div>
    </section>

    <section class="hospital-section hospital-routes" aria-labelledby="routes-title">
        <div class="public-wrap">
            <div class="hospital-section-heading reveal">
                <p class="hospital-kicker">Care routes</p>
                <h2 id="routes-title">Choose the care path that matches your situation.</h2>
            </div>

            <div class="hospital-route-grid">
                @foreach (var route in careRoutes.Where(route =>
                    route.Controller != "BillPayments" ||
                    LaunchFeatures.IsEnabled(Okafor_.NET.Services.LaunchFeature.BillPayments)))
                {
                    <a asp-controller="@route.Controller" asp-action="@route.Action" class="hospital-route reveal">
                        <span>@route.Label</span>
                        <strong>@route.Title</strong>
                        <em>@route.Body</em>
                    </a>
                }
            </div>
        </div>
    </section>

    <section class="hospital-section hospital-section--deep" aria-labelledby="mission-title">
        <div class="hospital-mission">
            <figure class="hospital-mission__media reveal">
                <img src="@portraitImage" alt="Patients from different generations seated together at the hospital" loading="lazy" />
            </figure>
            <div class="hospital-mission__copy reveal">
                <p class="hospital-kicker">Care philosophy</p>
                <h2 id="mission-title">Care should start with less confusion.</h2>
                <p>
                    Families come with symptoms, bills, directions, follow-up questions, and worries about what happens next. The hospital website keeps those needs visible so patients can act with more confidence.
                </p>
                <ul class="hospital-proof-list">
                    @foreach (var point in trustPoints)
                    {
                        <li>@point</li>
                    }
                </ul>
            </div>
        </div>
    </section>

    <section class="hospital-section hospital-services" aria-labelledby="services-title">
        <div class="public-wrap hospital-services__layout">
            <div class="hospital-services__header reveal">
                <p class="hospital-kicker">Clinical services</p>
                <h2 id="services-title">Find the department that fits your health concern.</h2>
                <p>Start with featured services, then view the full services page for more detail.</p>
                <a asp-controller="Home" asp-action="Services" class="site-button site-button--secondary">View all services</a>
            </div>

            <div class="hospital-service-list" aria-label="Featured departments">
                @if (services.Any())
                {
                    @foreach (var service in services)
                    {
                        <article class="hospital-service-row reveal">
                            <span>@service.Name</span>
                            <p>@(!string.IsNullOrWhiteSpace(service.Description) ? Excerpt(service.Description, 140) : "Department details are being prepared by the hospital team.")</p>
                        </article>
                    }
                }
                else
                {
                    <article class="hospital-service-row reveal">
                        <span>Care guidance available</span>
                        <p>Please contact the hospital team for current department and service details.</p>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="hospital-section hospital-learning" aria-labelledby="education-title">
        <div class="public-wrap hospital-learning__grid">
            <div class="hospital-learning__copy reveal">
                <p class="hospital-kicker">Health education</p>
                <h2 id="education-title">Learn the signs, risks, and questions to bring to your visit.</h2>
                <p>Short health guides help families understand common conditions before they become emergencies.</p>
            </div>
            <ul class="hospital-topic-list reveal">
                @foreach (var topic in educationTopics)
                {
                    <li>
                        <a asp-controller="Home" asp-action="PatientInformationHub">@topic</a>
                    </li>
                }
            </ul>
        </div>
    </section>

    <section class="hospital-section hospital-gallery" aria-label="Hospital community gallery">
        <figure class="hospital-gallery__large reveal">
            <img src="@missionImage" alt="Hospital staff and visitors standing outside the hospital" loading="lazy" />
        </figure>
        <figure class="hospital-gallery__small reveal">
            <img src="@signImage" alt="Hospital memorial sign at the facility entrance" loading="lazy" />
        </figure>
        <figure class="hospital-gallery__small reveal">
            <img src="@corridorImage" alt="Hospital team member seated with patients and family" loading="lazy" />
        </figure>
        <figure class="hospital-gallery__wide reveal">
            <img src="@gatheringImage" alt="Community health gathering at the hospital" loading="lazy" />
        </figure>
    </section>

    <section class="hospital-section hospital-updates" aria-labelledby="updates-title">
        <div class="public-wrap">
            <div class="hospital-section-heading reveal">
                <p class="hospital-kicker">Stories and updates</p>
                <h2 id="updates-title">News, outreach, and health notes from the hospital.</h2>
            </div>

            <div class="hospital-update-grid">
                @if (latestPosts.Any())
                {
                    @foreach (var post in latestPosts)
                    {
                        var excerpt = !string.IsNullOrWhiteSpace(post.Summary) ? post.Summary : post.Content;
                        <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@post.Slug" class="hospital-update reveal">
                            <time datetime="@post.CreatedAt.ToString("yyyy-MM-dd")">@post.CreatedAt.ToString("MMM dd, yyyy")</time>
                            <strong>@post.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(excerpt))
                            {
                                <span>@Excerpt(excerpt, 125)</span>
                            }
                        </a>
                    }
                }
                else
                {
                    @for (var i = 1; i <= 3; i++)
                    {
                        <article class="hospital-update hospital-update--placeholder reveal">
                            <time>Hospital update</time>
                            <strong>Hospital news coming soon</strong>
                            <span>Outreach stories and health updates will appear here when the team publishes them.</span>
                        </article>
                    }
                }
            </div>

            <a asp-controller="Home" asp-action="News" class="site-button site-button--secondary hospital-updates__cta">View news</a>
        </div>
    </section>

    <section class="hospital-section hospital-contact" aria-labelledby="contact-title">
        <div class="public-wrap hospital-contact__grid">
            <div class="hospital-contact__copy reveal">
                <p class="hospital-kicker">Visit or contact us</p>
                <h2 id="contact-title">Speak with the hospital before you travel.</h2>
                <p>Confirm clinic availability, directions, and current visiting details with the team.</p>
                <div class="hospital-contact__actions">
                    <a asp-controller="AppointmentRequests" asp-action="Create" class="site-button site-button--primary">Request appointment</a>
                    <a asp-controller="Home" asp-action="Contact" class="site-button site-button--secondary">Contact us</a>
                </div>
            </div>

            <div class="hospital-contact__details reveal">
                <dl>
                    <div>
                        <dt>Hospital</dt>
                        <dd>@hospitalName</dd>
                    </div>
                    <div>
                        <dt>Location</dt>
                        <dd>@(!string.IsNullOrWhiteSpace(hospitalAddress) ? hospitalAddress : "Please contact the hospital for current location details.")</dd>
                    </div>
                    <div>
                        <dt>Emergency</dt>
                        <dd>@(!string.IsNullOrWhiteSpace(emergencyNumbers) ? emergencyNumbers : "Please use the contact page to reach the hospital team.")</dd>
                    </div>
                    <div>
                        <dt>Email</dt>
                        <dd>
                            @if (!string.IsNullOrWhiteSpace(hospitalEmail))
                            {
                                <a href="mailto:@hospitalEmail">@hospitalEmail</a>
                            }
                            else
                            {
                                <span>Please use the contact form for email enquiries.</span>
                            }
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="hospital-map reveal">
                @if (!string.IsNullOrWhiteSpace(mapUrl))
                {
                    <iframe title="Map to Boniface and Paulina Okafor Memorial Hospital"
                            src="@mapUrl"
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"></iframe>
                }
                else
                {
                    <span>Directions available from the hospital team.</span>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/js/hero-carousel.js" asp-append-version="true"></script>
}
