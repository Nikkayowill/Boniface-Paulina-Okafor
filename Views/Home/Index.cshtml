@model Okafor_.NET.ViewModels.PublicHomeIndexViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Home";
    ViewData["MetaDescription"] = "Boniface and Paulina Okafor Memorial Hospital provides accessible, compassionate healthcare and health education for vulnerable families in Nigeria.";

    var hospitalName = Configuration["Hospital:Name"] ?? "Boniface and Paulina Okafor Memorial Hospital";
    var hospitalAddress = Configuration["Hospital:Address"];
    var hospitalEmail = Configuration["Hospital:Email"];
    var emergencyNumbers = Configuration["Hospital:EmergencyNumbers"];
    var mapUrl = Configuration["Hospital:GoogleMapEmbedUrl"];

    string Excerpt(string? text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length > maxLength ? text[..maxLength] + "..." : text;
    }

    var heroImage = "/images/placeholders/Hospital/GOEH7326.webp";
    var careImages = new[]
    {
        "/images/placeholders/Hospital/AETL0059.webp",
        "/images/placeholders/Hospital/MKEA3316.webp",
        "/images/placeholders/Hospital/FSKC7061.webp",
        "/images/placeholders/Hospital/WHRJ0248.webp"
    };
    var services = Model.FeaturedDepartments?.Take(3).ToList() ?? new List<Okafor_.NET.Models.Department>();
    var latestPosts = Model.LatestPosts?.Take(3).ToList() ?? new List<Okafor_.NET.Models.Post>();

    var educationTopics = new[]
    {
        "Malaria Prevention",
        "High Blood Pressure",
        "Diabetes Awareness",
        "AIDS Education",
        "Maternal Health",
        "Infant Care"
    };

    var trustPoints = new[]
    {
        "Care for vulnerable families",
        "Focus on mothers, infants, and seniors",
        "Health education and prevention",
        "Community-rooted service",
        "Dignity in every visit"
    };
}

<div class="public-home public-home--gateway">
    <section class="public-gateway-hero" aria-labelledby="home-hero-title">
        <img class="public-gateway-hero__media"
             src="@heroImage"
             onerror="this.onerror=null;this.src='/images/placeholders/placeholder.svg'"
             alt="" />
        <div class="public-gateway-hero__overlay">
            <div class="public-wrap">
                <h1 id="home-hero-title" class="public-gateway-title reveal">
                    Welcome to Boniface and Paulina Okafor Memorial Hospital
                </h1>
            </div>
        </div>
    </section>

    <section class="public-gateway-section public-gateway-section--lift" aria-labelledby="actions-title">
        <div class="public-wrap">
            <h2 id="actions-title" class="public-sr-heading">Start here</h2>
            <div class="public-action-card-grid">
                <article class="public-action-card reveal">
                    <p class="public-card-kicker">Start here</p>
                    <h3>Contact Us</h3>
                    <p>Get location, phone, and visit guidance from the hospital team.</p>
                    <a asp-controller="Home" asp-action="Contact" class="public-action-btn">Contact Us</a>
                </article>
                <article class="public-action-card reveal">
                    <p class="public-card-kicker">Appointments</p>
                    <h3>Book Appointment</h3>
                    <p>Choose a department, doctor, and available time for a visit.</p>
                    <a asp-controller="AppointmentRequests" asp-action="Create" class="public-action-btn">Book Appointment</a>
                </article>
                <article class="public-action-card reveal">
                    <p class="public-card-kicker">Virtual</p>
                    <h3>Teleconsultation</h3>
                    <p>Request a phone or video consultation when remote care is suitable.</p>
                    <a asp-controller="Teleconsultations" asp-action="Create" class="public-action-btn">Teleconsultation</a>
                </article>
            </div>
        </div>
    </section>

    <section class="public-gateway-section" aria-labelledby="education-title">
        <div class="public-wrap">
            <div class="public-education-card reveal">
                <div class="public-education-card-header">
                    <div class="public-section-heading" style="margin-bottom: 0.7rem;">
                        <p class="public-eyebrow">Health education</p>
                        <h2 id="education-title" style="font-size:1.13rem; margin-bottom:0.18rem;">Learn About Your Health</h2>
                        <p style="font-size:0.93rem; margin-bottom:0;">Simple guidance to help families prevent common life-threatening diseases.</p>
                    </div>
                </div>
                <div class="public-education-card-links">
                    <ul class="public-education-list">
                        @foreach (var topic in educationTopics)
                        {
                            <li>
                                <a asp-controller="Home" asp-action="PatientInformationHub" class="public-education-link">@topic</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="public-gateway-section public-gateway-section--sand" aria-labelledby="care-title">
        <div class="public-wrap">
            <div class="public-section-heading reveal">
                <p class="public-eyebrow">Get care</p>
                <h2 id="care-title">Get Care</h2>
                <p>Getting an appointment at BP Okafor Memorial is easy. Choose the path that best fits your need.</p>
            </div>
            <div class="public-care-grid">
                <article class="public-care-card reveal">
                    <figure class="public-care-card__media">
                        <img src="@careImages[0]" alt="Hospital entrance and signage" loading="lazy" />
                    </figure>
                    <h3>Visit the Hospital</h3>
                    <p>Use the contact page for location details, general enquiries, and visit planning.</p>
                    <a asp-controller="Home" asp-action="Contact">Plan Your Visit</a>
                </article>
                <article class="public-care-card reveal">
                    <figure class="public-care-card__media">
                        <img src="@careImages[1]" alt="Hospital staff helping with visit paperwork" loading="lazy" />
                    </figure>
                    <h3>Request an Appointment</h3>
                    <p>Send an appointment request to the hospital team.</p>
                    <a asp-controller="AppointmentRequests" asp-action="Create">Appointment Request Form</a>
                </article>
                <article class="public-care-card reveal">
                    <figure class="public-care-card__media">
                        <img src="@careImages[2]" alt="Community members gathered for hospital outreach" loading="lazy" />
                    </figure>
                    <h3>Support a Patient</h3>
                    <p>Use the donation workflow to support the hospital mission.</p>
                    <a asp-controller="Donation" asp-action="Index">Donate</a>
                </article>
                <article class="public-care-card reveal">
                    <figure class="public-care-card__media">
                        <img src="@careImages[3]" alt="Hospital consultation workspace" loading="lazy" />
                    </figure>
                    <h3>Ask About Teleconsultation</h3>
                    <p>Begin a virtual care request when remote follow-up may be appropriate.</p>
                    <a asp-controller="Teleconsultations" asp-action="Create">Teleconsultation</a>
                </article>
            </div>
        </div>
    </section>

    <section class="public-gateway-section" aria-labelledby="services-title">
        <div class="public-wrap public-two-column">
            <div class="public-section-heading reveal">
                <p class="public-eyebrow">Care services</p>
                <h2 id="services-title">Care for families, mothers, children, and seniors.</h2>
                <p>These service cards use departments already available to the homepage.</p>
                <a asp-controller="Home" asp-action="Services" class="public-button public-button--outline">View Services</a>
            </div>
            <div class="public-mini-list">
                @if (services.Any())
                {
                    @foreach (var service in services)
                    {
                        <article class="public-mini-card reveal">
                            <h3>@service.Name</h3>
                            <p>@(!string.IsNullOrWhiteSpace(service.Description) ? Excerpt(service.Description, 120) : "Department details are being prepared by the hospital team.")</p>
                        </article>
                    }
                }
                else
                {
                    <article class="public-mini-card reveal">
                        <h3>Care guidance available</h3>
                        <p>Please contact the hospital team for current department and service details.</p>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="public-gateway-section public-gateway-section--forest" aria-labelledby="stories-title">
        <div class="public-wrap">
            <div class="public-section-heading reveal">
                <p class="public-eyebrow">Stories and updates</p>
                <h2 id="stories-title">Stories from the Mission</h2>
                <p>Published updates appear here when available. No patient stories or outcomes are invented.</p>
            </div>
            <div class="public-story-grid">
                @if (latestPosts.Any())
                {
                    @foreach (var post in latestPosts)
                    {
                        var excerpt = !string.IsNullOrWhiteSpace(post.Summary) ? post.Summary : post.Content;
                        <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@post.Slug" class="public-story-link reveal">
                            <span class="public-story-link__date">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                            <strong>@post.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(excerpt))
                            {
                                <span>@Excerpt(excerpt, 125)</span>
                            }
                        </a>
                    }
                }
                else
                {
                    @for (var i = 1; i <= 3; i++)
                    {
                        <article class="public-story-link public-story-link--placeholder reveal">
                            <span class="public-story-link__date">Hospital update</span>
                            <strong>Mission update @i</strong>
                            <span>Hospital stories and health updates will appear here when available.</span>
                        </article>
                    }
                }
            </div>
            <a asp-controller="Home" asp-action="News" class="public-button public-button--light mt-8">View News</a>
        </div>
    </section>

    <section class="public-gateway-section public-gateway-section--compact" aria-labelledby="help-title">
        <div class="public-wrap public-help-panel reveal">
            <div>
                <p class="public-eyebrow">Need help?</p>
                <h2 id="help-title">Need help finding the right care?</h2>
                <p>Choose a practical next step, or contact the hospital team for guidance.</p>
            </div>
            <div class="public-help-links">
                <a asp-controller="Home" asp-action="Services">View Services</a>
                <a asp-controller="Home" asp-action="Contact">Contact Us</a>
                <a asp-controller="AppointmentRequests" asp-action="Create">Request Appointment</a>
                <a asp-controller="Donation" asp-action="Index">Donate</a>
            </div>
        </div>
    </section>

    <section class="public-gateway-section" aria-labelledby="trust-title">
        <div class="public-wrap public-two-column">
            <div class="public-section-heading reveal">
                <p class="public-eyebrow">Why choose us</p>
                <h2 id="trust-title">Why families trust Boniface and Paulina Okafor Memorial Hospital</h2>
            </div>
            <ul class="public-trust-list reveal">
                @foreach (var point in trustPoints)
                {
                    <li>@point</li>
                }
            </ul>
        </div>
    </section>

    <section class="public-gateway-section public-gateway-section--sand" aria-labelledby="contact-title">
        <div class="public-wrap public-contact-grid">
            <div class="public-section-heading reveal">
                <p class="public-eyebrow">Visit or contact us</p>
                <h2 id="contact-title">Location and contact</h2>
                <p>Confirm current visiting details with the hospital team before travelling.</p>
            </div>
            <div class="public-contact-card reveal">
                <dl>
                    <div>
                        <dt>Hospital location</dt>
                        <dd>@(!string.IsNullOrWhiteSpace(hospitalAddress) ? hospitalAddress : "Please contact the hospital for current location details.")</dd>
                    </div>
                    <div>
                        <dt>Phone</dt>
                        <dd>@(!string.IsNullOrWhiteSpace(emergencyNumbers) ? emergencyNumbers : "Please use the contact page to reach the hospital team.")</dd>
                    </div>
                    <div>
                        <dt>Email</dt>
                        <dd>
                            @if (!string.IsNullOrWhiteSpace(hospitalEmail))
                            {
                                <a href="mailto:@hospitalEmail">@hospitalEmail</a>
                            }
                            else
                            {
                                <span>Please use the contact form for email enquiries.</span>
                            }
                        </dd>
                    </div>
                    <div>
                        <dt>Visiting hours</dt>
                        <dd>Please contact the hospital to confirm current visiting hours.</dd>
                    </div>
                </dl>
                <a asp-controller="Home" asp-action="Contact" class="public-button public-button--primary mt-6">Contact Us</a>
            </div>
            <div class="public-map-placeholder reveal">
                @if (!string.IsNullOrWhiteSpace(mapUrl))
                {
                    <iframe title="Map to Boniface and Paulina Okafor Memorial Hospital"
                            src="@mapUrl"
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"></iframe>
                }
                else
                {
                    <span>Please contact the hospital for directions.</span>
                }
            </div>
        </div>
    </section>
</div>
