@model Okafor_.NET.Models.ContactSubmission
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Contact Us";
    ViewData["PageTitle"] = "Contact a Hospital in Isuochi | Okafor Memorial Hospital";
    ViewData["MetaDescription"] = "Contact Boniface and Paulina Okafor Memorial Hospital at Ndibemaduka Compound, Umudim Ngodo Isuochi, Umunneochi L.G.A, Abia State, Nigeria for appointments, enquiries, and emergency guidance.";
    ViewData["CanonicalPath"] = "/contact";
    var success = TempData["ContactSuccess"] as bool? ?? false;
    var hospitalAddress = Configuration["Hospital:Address"] ?? "Ndibemaduka Compound, Umudim Ngodo Isuochi, Umunneochi L.G.A, Abia State, Nigeria";
    var hospitalEmail = Configuration["Hospital:Email"] ?? "info@okaformemorial.org";
    var emergencyNumbers = Configuration["Hospital:EmergencyNumbers"] ?? "112 / 199";
    var mapUrl = Configuration["Hospital:GoogleMapEmbedUrl"] ?? "https://www.google.com/maps?q=Ndibemaduka%20Compound%20Umudim%20Ngodo%20Isuochi%20Umunneochi%20Abia%20State%20Nigeria&output=embed";
}

<!-- Page header -->
<section class="site-page-header">
    <div class="site-page-header__inner">
        <p class="site-page-kicker">Contact Us</p>
        <h1 class="site-page-title mt-3">Get in touch with our hospital teams.</h1>
        <p class="site-page-lede mt-4 max-w-2xl">
            For appointment support, service inquiries, and general assistance, contact us through the channels below.
        </p>
    </div>
</section>

<section class="site-page-surface">
    <div class="mx-auto max-w-site px-6">

        <!-- Info cards -->
        <div class="mb-12 grid gap-5 md:grid-cols-3">
            <div class="site-card p-6">
                <h2 class="font-serif text-xl font-bold text-[#1c1c1c]">Main Reception</h2>
                <p class="mt-3 text-sm leading-6 text-[#4a4a4a]">@hospitalAddress</p>
                <p class="mt-1 text-sm text-[#4a4a4a]">Monday &ndash; Saturday: 8:00 AM &ndash; 6:00 PM</p>
            </div>
            <div class="site-card p-6">
                <h2 class="font-serif text-xl font-bold text-[#1c1c1c]">Emergency &amp; Email</h2>
                <p class="mt-3 text-sm text-[#4a4a4a]">
                    <a href="tel:112" class="font-semibold text-primary-700 hover:text-primary-900">Emergency: @emergencyNumbers</a>
                </p>
                <p class="mt-1 text-sm text-[#4a4a4a]">
                    <a href="mailto:@hospitalEmail" class="font-semibold text-primary-700 hover:text-primary-900">@hospitalEmail</a>
                </p>
            </div>
            <div class="site-card p-6">
                <h2 class="font-serif text-xl font-bold text-[#1c1c1c]">Appointment Desk</h2>
                <p class="mt-3 text-sm leading-6 text-[#4a4a4a]">Submit your request online and our team will coordinate availability.</p>
                <a asp-area="" asp-controller="AppointmentRequests" asp-action="Create"
                   class="site-button site-button--primary mt-4">
                    Book Appointment
                </a>
            </div>
        </div>

        <!-- Contact form -->
        <div class="grid gap-8 lg:grid-cols-12">
            <div class="site-card p-6 sm:p-8 lg:col-span-7">

                @if (success)
                {
                    <div class="mb-6 flex items-start gap-3 border border-teal-200 bg-primary-50 px-4 py-3">
                        <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <p class="text-sm text-primary-800">Your message has been received. A member of the hospital team will review it and reply using the email address provided.</p>
                    </div>
                }

                <h2 class="font-serif text-2xl font-bold text-[#1c1c1c]">Send Us a Message</h2>
                <p class="mt-1 text-sm text-[#5c5c5c]">Use this form for non-urgent questions. Hospital staff will reply using the email address you provide.</p>

                <div class="mt-4 border border-amber-300 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-900" role="note">
                    Do not use this form for urgent symptoms or emergencies. Call @emergencyNumbers or go directly to the nearest emergency department.
                </div>

                <form asp-area="" asp-controller="Home" asp-action="Contact" method="post" class="requires-network mt-6 space-y-5">

                    <div asp-validation-summary="ModelOnly"
                         class="border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

                    <div class="grid gap-5 md:grid-cols-2">
                        <div>
                            <label asp-for="Name" class="ok-form-label">Your Name</label>
                            <input asp-for="Name"
                                   class="ok-field"
                                   placeholder="Full name" />
                            <span asp-validation-for="Name" class="mt-1 block text-xs text-red-600"></span>
                        </div>
                        <div>
                            <label asp-for="Email" class="ok-form-label">Email Address</label>
                            <input asp-for="Email"
                                   class="ok-field"
                                   placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="mt-1 block text-xs text-red-600"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="Subject" class="ok-form-label">Subject</label>
                        <input asp-for="Subject"
                               class="ok-field"
                               placeholder="How can we help?" />
                        <span asp-validation-for="Subject" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Message" class="ok-form-label">Message</label>
                        <textarea asp-for="Message" rows="5"
                                  class="ok-field"
                                  placeholder="Your message&hellip;"></textarea>
                        <span asp-validation-for="Message" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <button type="submit" class="site-button site-button--primary">
                        Send Message
                    </button>

                </form>
            </div>

            <aside class="site-card p-6 lg:col-span-5">
                <h2 class="font-serif text-xl font-bold text-[#1c1c1c]">Emergency &amp; After-Hours</h2>
                <p class="mt-3 text-sm leading-6 text-[#4a4a4a]">
                    For medical emergencies in Nigeria, please call <strong>@emergencyNumbers</strong> or visit the nearest emergency department immediately.
                </p>
                <div class="mt-6 border-t border-secondary-300 pt-5">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-primary-800">Emergency Numbers</p>
                    <a href="tel:112" class="mt-1 block font-serif text-2xl font-bold text-[#1c1c1c] hover:text-primary-700">@emergencyNumbers</a>
                </div>
                <div class="mt-6 border-t border-secondary-300 pt-5">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-primary-800">Hospital Location</p>
                    <div class="mt-3 overflow-hidden border border-secondary-300 bg-white">
                        <iframe title="Map to Boniface and Paulina Okafor Memorial Hospital"
                                src="@mapUrl"
                                class="h-64 w-full border-0"
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                    <div class="mt-3 text-sm leading-6 text-[#5c5c5c]">
                        @hospitalAddress
                    </div>
                </div>
            </aside>
        </div>

    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
