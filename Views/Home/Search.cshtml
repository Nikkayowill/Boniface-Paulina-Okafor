@model Okafor_.NET.ViewModels.PublicSearchResultsViewModel

@{
    ViewData["Title"] = "Search";
    ViewData["MetaDescription"] = "Search doctors, clinical services, patient information, and hospital news from Boniface and Paulina Okafor Memorial Hospital.";

    string Excerpt(string? text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length > maxLength ? text[..maxLength] + "…" : text;
    }
}

<div class="public-search">
    <section class="public-search__hero" aria-labelledby="search-title">
        <div class="public-search__wrap">
            <p class="public-search__kicker">Hospital search</p>
            <h1 id="search-title">What can we help you find?</h1>
            <p>Search public hospital information. Do not enter private medical or payment information.</p>

            <form asp-area="" asp-controller="Home" asp-action="Search" method="get" class="public-search__form" role="search">
                <div class="public-search__field public-search__field--query">
                    <label for="hospital-search-query">Search term</label>
                    <input id="hospital-search-query"
                           name="query"
                           value="@Model.Query"
                           maxlength="100"
                           autocomplete="off"
                           placeholder="Doctor, service, or health topic" />
                </div>
                <div class="public-search__field">
                    <label for="hospital-search-scope">Search within</label>
                    <select id="hospital-search-scope" name="scope">
                        <option value="all" selected="@(Model.Scope == "all")">All information</option>
                        <option value="doctors" selected="@(Model.Scope == "doctors")">Doctors</option>
                        <option value="services" selected="@(Model.Scope == "services")">Services</option>
                        <option value="patient-info" selected="@(Model.Scope == "patient-info")">Patient information</option>
                        <option value="news" selected="@(Model.Scope == "news")">News</option>
                    </select>
                </div>
                <button type="submit" class="public-search__button glow-button">Search</button>
            </form>
        </div>
    </section>

    <section class="public-search__results" aria-live="polite">
        <div class="public-search__wrap">
            @if (string.IsNullOrWhiteSpace(Model.Query))
            {
                <div class="public-search__empty">
                    <h2>Start with a name or care need.</h2>
                    <p>Examples: maternity, malaria, laboratory, or a doctor's name.</p>
                </div>
            }
            else if (!Model.HasAnyResults)
            {
                <div class="public-search__empty">
                    <h2>No results for “@Model.Query”</h2>
                    <p>Check the spelling, choose “All information,” or contact the hospital for help.</p>
                    <a asp-controller="Home" asp-action="Contact">Contact the hospital</a>
                </div>
            }
            else
            {
                <div class="public-search__summary">
                    <p>Results for</p>
                    <h2>“@Model.Query”</h2>
                </div>

                @if (Model.Doctors.Any())
                {
                    <section class="public-search__group" aria-labelledby="doctor-results-title">
                        <h3 id="doctor-results-title">Doctors</h3>
                        <div class="public-search__list">
                            @foreach (var doctor in Model.Doctors)
                            {
                                <a asp-controller="Home" asp-action="DoctorProfile" asp-route-slug="@doctor.Slug" class="public-search__result">
                                    <span>
                                        <strong>@doctor.FullName</strong>
                                        <small>@doctor.Specialty · @(doctor.Department?.Name ?? "Department not listed")</small>
                                    </span>
                                    <span aria-hidden="true">→</span>
                                </a>
                            }
                        </div>
                    </section>
                }

                @if (Model.Services.Any())
                {
                    <section class="public-search__group" aria-labelledby="service-results-title">
                        <h3 id="service-results-title">Services</h3>
                        <div class="public-search__list">
                            @foreach (var service in Model.Services)
                            {
                                <a asp-controller="Home" asp-action="Services" asp-fragment="service-@service.Id" class="public-search__result">
                                    <span>
                                        <strong>@service.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(service.Description))
                                        {
                                            <small>@Excerpt(service.Description, 180)</small>
                                        }
                                    </span>
                                    <span aria-hidden="true">→</span>
                                </a>
                            }
                        </div>
                    </section>
                }

                @if (Model.PatientInformation.Any())
                {
                    <section class="public-search__group" aria-labelledby="patient-results-title">
                        <h3 id="patient-results-title">Patient information</h3>
                        <div class="public-search__list">
                            @foreach (var topic in Model.PatientInformation)
                            {
                                <a href="@topic.LinkUrl" class="public-search__result">
                                    <span>
                                        <strong>@topic.Title</strong>
                                        <small>@topic.Summary</small>
                                    </span>
                                    <span aria-hidden="true">→</span>
                                </a>
                            }
                        </div>
                    </section>
                }

                @if (Model.News.Any())
                {
                    <section class="public-search__group" aria-labelledby="news-results-title">
                        <h3 id="news-results-title">News and health updates</h3>
                        <div class="public-search__list">
                            @foreach (var post in Model.News)
                            {
                                <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@post.Slug" class="public-search__result">
                                    <span>
                                        <strong>@post.Title</strong>
                                        <small>@post.CreatedAt.ToString("MMMM d, yyyy") · @Excerpt(post.Content, 160)</small>
                                    </span>
                                    <span aria-hidden="true">→</span>
                                </a>
                            }
                        </div>
                    </section>
                }
            }
        </div>
    </section>
</div>
