@model Okafor_.NET.ViewModels.PublicSearchResultsViewModel

@{
    ViewData["Title"] = "Search";
}

<!-- Page header -->
<section class="border-b border-secondary-300 bg-secondary-100 py-14">
    <div class="mx-auto max-w-site px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Search</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-[#1c1c1c]">Find hospital information quickly.</h1>

        <form asp-area="" asp-controller="Home" asp-action="Search" method="get"
              class="mt-8 grid gap-3 md:grid-cols-[1fr_220px_120px]">
            <input name="query"
                   value="@Model.Query"
                   placeholder="Search doctors, services, news&hellip;"
                   class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] placeholder-[#aaa] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
            <select name="scope"
                    class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800">
                @foreach (var scope in new[] { "Entire Site", "Doctors", "Services", "News", "Patient Information" })
                {
                    <option value="@scope" selected="@(Model.Scope == scope ? "selected" : null)">@scope</option>
                }
            </select>
            <button type="submit"
                    class="bg-primary-800 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-colors hover:bg-primary-700">
                Search
            </button>
        </form>
    </div>
</section>

<!-- Results -->
<section class="bg-secondary-100 py-14">
    <div class="mx-auto max-w-site px-6">

        @if (string.IsNullOrWhiteSpace(Model.Query))
        {
            <p class="text-sm text-[#5c5c5c]">Enter a search term above to begin.</p>
        }
        else if (!Model.HasAnyResults)
        {
            <div class="border border-secondary-300 bg-secondary-100 px-6 py-10 text-center">
                <p class="font-serif text-xl text-[#1c1c1c]">No results found for &ldquo;@Model.Query&rdquo;</p>
                <p class="mt-2 text-sm text-[#5c5c5c]">Try a different keyword or broaden your search scope.</p>
            </div>
        }
        else
        {
            <p class="mb-8 text-sm text-[#5c5c5c]">Showing results for &ldquo;<strong>@Model.Query</strong>&rdquo;</p>

            @if (Model.Doctors.Any())
            {
                <div class="mb-10">
                    <h2 class="mb-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-primary-800">Doctors</h2>
                    <div class="divide-y divide-secondary-300 border border-secondary-300 bg-secondary-100">
                        @foreach (var doctor in Model.Doctors)
                        {
                            <div class="flex items-start gap-4 px-5 py-4">
                                <div>
                                    <p class="font-semibold text-[#1c1c1c]">@doctor.FullName</p>
                                    <p class="mt-0.5 text-sm text-[#5c5c5c]">@doctor.Specialty &middot; @(doctor.Department?.Name ?? "N/A")</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (Model.Services.Any())
            {
                <div class="mb-10">
                    <h2 class="mb-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-primary-800">Services</h2>
                    <div class="divide-y divide-secondary-300 border border-secondary-300 bg-secondary-100">
                        @foreach (var service in Model.Services)
                        {
                            <div class="px-5 py-4">
                                <p class="font-semibold text-[#1c1c1c]">@service.Name</p>
                                @if (!string.IsNullOrWhiteSpace(service.Description))
                                {
                                    <p class="mt-1 text-sm text-[#5c5c5c]">@(service.Description.Length > 200 ? service.Description[..200] + "\u2026" : service.Description)</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @if (Model.News.Any())
            {
                <div class="mb-10">
                    <h2 class="mb-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-primary-800">News &amp; Blog</h2>
                    <div class="divide-y divide-secondary-300 border border-secondary-300 bg-secondary-100">
                        @foreach (var post in Model.News)
                        {
                            <div class="px-5 py-4">
                                <p class="text-[10px] uppercase tracking-[0.12em] text-[#8c8c8c]">@post.CreatedAt.ToString("MMMM d, yyyy")</p>
                                <a asp-area="" asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@post.Slug"
                                   class="mt-1 block font-semibold text-[#1c1c1c] hover:text-primary-700">@post.Title</a>
                                <p class="mt-1 text-sm text-[#5c5c5c]">@(post.Content.Length > 200 ? post.Content[..200] + "\u2026" : post.Content)</p>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (Model.PatientInformation.Any())
            {
                <div class="mb-10">
                    <h2 class="mb-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-primary-800">Patient Information</h2>
                    <div class="divide-y divide-secondary-300 border border-secondary-300 bg-secondary-100">
                        @foreach (var topic in Model.PatientInformation)
                        {
                            <div class="px-5 py-4">
                                <p class="font-semibold text-[#1c1c1c]">@topic.Title</p>
                                <p class="mt-1 text-sm text-[#5c5c5c]">@topic.Summary</p>
                                <a href="@topic.LinkUrl" class="mt-2 inline-block text-xs font-medium text-primary-700 hover:text-primary-900">@topic.LinkText &rarr;</a>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</section>
