@model int
@{
    var isNotFound = Model == StatusCodes.Status404NotFound;
    var isForbidden = Model == StatusCodes.Status403Forbidden;
    ViewData["Title"] = isNotFound ? "Page not found" : isForbidden ? "Access unavailable" : "Request unavailable";
    ViewData["Robots"] = "noindex,nofollow";
}

<section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-24">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary-800">Status @Model</p>
        <h1 class="mt-3 text-3xl font-bold leading-tight text-slate-950 sm:text-5xl">
            @(isNotFound ? "We could not find that page." : isForbidden ? "That page is not available to you." : "That request is not available.")
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-base leading-7 text-slate-600">
            @(isNotFound
                ? "The link may be old or the address may be incomplete. You can search hospital information or return home."
                : "Return to the hospital home page or contact us if you believe you need access.")
        </p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
            <a asp-controller="Home" asp-action="Index" class="glow-button inline-flex min-h-12 items-center justify-center bg-primary-800 px-6 py-3 text-sm font-semibold text-white transition hover:bg-primary-700">
                Return home
            </a>
            @if (isNotFound)
            {
                <a asp-controller="Home" asp-action="Search" class="inline-flex min-h-12 items-center justify-center border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-primary-700 hover:text-primary-800">
                    Search the site
                </a>
            }
            else
            {
                <a asp-controller="Home" asp-action="Contact" class="inline-flex min-h-12 items-center justify-center border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-primary-700 hover:text-primary-800">
                    Contact the hospital
                </a>
            }
        </div>
    </div>
</section>
