@model IReadOnlyList<Okafor_.NET.Models.Post>
@using Okafor_.NET.Services

@{
    ViewData["Title"] = "Hospital Notes & Health Guides";
    ViewData["PageTitle"] = "Hospital Notes from Isuochi | Okafor Memorial Hospital";
    ViewData["MetaDescription"] = "Read short hospital updates, community outreach notes, patient notices, and practical health guidance from Okafor Memorial Hospital in Isuochi, Abia State.";
    ViewData["CanonicalPath"] = "/news";

    var leadPost = Model.FirstOrDefault(post => post.IsFeatured) ?? Model.FirstOrDefault();
    var remainingPosts = leadPost is null
        ? new List<Okafor_.NET.Models.Post>()
        : Model.Where(post => post.Id != leadPost.Id).ToList();
}

<main class="editorial-index">
    <header class="editorial-masthead">
        <div class="public-wrap editorial-masthead__inner">
            <div>
                <p class="hospital-kicker">From the hospital</p>
                <h1>Hospital notes from Isuochi.</h1>
                <p class="editorial-masthead__lede">
                    Useful updates do not need to be long. Find brief patient notices, stories from our community work,
                    and plain-language health guidance written for families in Isuochi and across Abia State.
                </p>
            </div>
            <a href="/feed.xml" class="editorial-feed-link" aria-label="Subscribe to Hospital Notes by RSS">
                Follow by RSS
                <span aria-hidden="true">↗</span>
            </a>
        </div>
    </header>

    <section class="public-wrap editorial-stream" aria-labelledby="latest-notes-title">
        @if (leadPost is not null)
        {
            var leadDescription = PostPresentation.Description(leadPost);
            <article class="editorial-lead @(!string.IsNullOrWhiteSpace(leadPost.ThumbnailImageUrl) ? string.Empty : "editorial-lead--text-only")">
                @if (!string.IsNullOrWhiteSpace(leadPost.ThumbnailImageUrl))
                {
                    <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@leadPost.Slug"
                       class="editorial-lead__image" tabindex="-1" aria-hidden="true">
                        <img src="@leadPost.ThumbnailImageUrl"
                             alt=""
                             width="1200"
                             height="675"
                             loading="eager"
                             decoding="async" />
                    </a>
                }
                <div class="editorial-lead__copy">
                    <div class="editorial-byline">
                        <span>@PostPresentation.FormatLabel(leadPost)</span>
                        <span aria-hidden="true">·</span>
                        <time datetime="@leadPost.CreatedAt.ToString("yyyy-MM-dd")">@leadPost.CreatedAt.ToString("d MMMM yyyy")</time>
                        <span aria-hidden="true">·</span>
                        <span>@PostPresentation.ReadingMinutes(leadPost) min read</span>
                    </div>
                    <h2>
                        <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@leadPost.Slug">@leadPost.Title</a>
                    </h2>
                    <p>@leadDescription</p>
                    <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@leadPost.Slug"
                       class="hospital-text-link">Read this note</a>
                </div>
            </article>

            @if (remainingPosts.Count > 0)
            {
                <div class="editorial-stream__heading">
                    <h2 id="latest-notes-title">Latest notes</h2>
                    <span>@remainingPosts.Count @(remainingPosts.Count == 1 ? "post" : "posts")</span>
                </div>

                <div class="editorial-list">
                    @foreach (var post in remainingPosts)
                    {
                        <article class="editorial-row">
                            <div class="editorial-row__meta">
                                <span>@PostPresentation.FormatLabel(post)</span>
                                <time datetime="@post.CreatedAt.ToString("yyyy-MM-dd")">@post.CreatedAt.ToString("d MMM yyyy")</time>
                            </div>
                            <div class="editorial-row__copy">
                                <h3>
                                    <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@post.Slug">@post.Title</a>
                                </h3>
                                <p>@PostPresentation.Description(post)</p>
                            </div>
                            <div class="editorial-row__read">
                                <span>@PostPresentation.ReadingMinutes(post) min</span>
                                <a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@post.Slug"
                                   aria-label="Read @post.Title">Read →</a>
                            </div>
                        </article>
                    }
                </div>
            }
        }
        else
        {
            <div class="editorial-empty">
                <p class="hospital-kicker">The first note is on its way</p>
                <h2>Clear, local health information will live here.</h2>
                <p>
                    We will publish hospital notices, outreach reports, and practical guidance after details have been
                    confirmed by the hospital team.
                </p>
                <a asp-controller="Home" asp-action="Contact" class="hospital-button hospital-button--primary">Contact the hospital</a>
            </div>
        }
    </section>
</main>
