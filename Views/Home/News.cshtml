@model IEnumerable<Okafor_.NET.Models.Post>

@{
    ViewData["Title"] = "News & Health Blog";
}

<!-- Page header -->
<section class="border-b border-secondary-300 bg-secondary-100 py-14">
    <div class="mx-auto max-w-site px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">News &amp; Health Blog</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-[#1c1c1c]">Hospital updates, clinical insights, and patient education.</h1>
        <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[#4a4a4a]">
            Stay informed with trusted updates from our clinical teams and hospital leadership.
        </p>
    </div>
</section>

<!-- Featured hospital images -->
<section class="bg-white py-12 border-b border-secondary-300">
    <div class="mx-auto max-w-site px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Our Hospital</p>
        <h3 class="mt-2 font-serif text-2xl text-slate-900">Dedicated to your care and recovery</h3>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
            @{
                var images = ViewBag.RandomImages as List<string>;
                if (images != null)
                {
                    int imageIndex = 0;
                    foreach (var image in images)
                    {
                        <div class="premium-card aspect-[4/3] overflow-hidden border border-secondary-300 bg-white">
                            <img src="@image" alt="Hospital care - image @(imageIndex + 1)" class="h-full w-full object-cover transition-transform duration-500 hover:scale-105">
                        </div>
                        imageIndex++;
                    }
                }
            }
        </div>
    </div>
</section>

<!-- Post list -->
<section class="bg-secondary-100 py-16">
    <div class="mx-auto max-w-site px-6">
        @if (Model.Any())
        {
            <div class="grid items-stretch gap-5 sm:grid-cols-2 lg:grid-cols-3">
                @foreach (var post in Model)
                {
                    var imageUrl = !string.IsNullOrWhiteSpace(post.ThumbnailImageUrl)
                        ? post.ThumbnailImageUrl
                        : "/images/placeholders/nigerian-hospital-care.webp";
                    var excerpt = !string.IsNullOrWhiteSpace(post.Summary)
                        ? post.Summary
                        : post.Content;

                    <article class="premium-card group relative min-h-[360px] overflow-hidden border border-secondary-300 bg-secondary-100">
                        <img src="@imageUrl" alt="@post.Title"
                             class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                             loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/50 to-black/20 transition-all duration-300 group-hover:from-black/90 group-hover:via-black/60"></div>

                        <div class="relative z-10 flex h-full flex-col justify-end p-6">
                            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-secondary-200">
                                @post.CreatedAt.ToString("MMMM d, yyyy")
                                @if (post.IsFeatured)
                                {
                                    <span>&nbsp;-&nbsp; Featured</span>
                                }
                            </p>
                            <h2 class="mt-2 font-serif text-[1.35rem] font-bold leading-snug text-white transition-colors duration-200 group-hover:text-secondary-100">@post.Title</h2>
                            <p class="mt-2 text-[13px] leading-6 text-secondary-200">
                                @(excerpt.Length > 170 ? excerpt[..170] + "..." : excerpt)
                            </p>
                            <a asp-area="" asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@post.Slug"
                               class="mt-4 inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-white transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-secondary-100">
                                Read More
                                <svg class="h-2.5 w-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="border border-secondary-300 bg-secondary-100 px-8 py-16 text-center">
                <p class="font-serif text-xl text-[#1c1c1c]">No published articles yet.</p>
                <p class="mt-2 text-sm text-[#5c5c5c]">Check back soon for hospital news and health education content.</p>
            </div>
        }
    </div>
</section>
