@model IEnumerable<Okafor_.NET.Models.Doctor>

@{
    ViewData["Title"] = "Doctors & Team";
    ViewData["PageTitle"] = "Doctors and Care Team in Isuochi | Okafor Memorial Hospital";
    ViewData["MetaDescription"] = "Meet the doctors, management leadership, and patient care staff serving Boniface and Paulina Okafor Memorial Hospital.";
    ViewData["CanonicalPath"] = "/doctors";
    var doctors = Model?.ToList() ?? new List<Okafor_.NET.Models.Doctor>();
    var fatherToochukwu = doctors.FirstOrDefault(doctor =>
        string.Equals(doctor.Slug, "rev-fr-dr-toochukwu-bartholomew-okafor", StringComparison.OrdinalIgnoreCase));
    var clinicalDoctors = doctors.Where(doctor => doctor != fatherToochukwu).ToList();
    var leadership = new[]
    {
        ("Management & Leadership", "Chief medical direction, administration, and governance for safe and accountable hospital operations."),
        ("Doctors & Specialists", "Clinical teams providing consultations, diagnosis, treatment planning, and continuity of care."),
        ("Nursing & Care Staff", "Ward care, patient comfort, family communication, and practical support throughout the patient journey.")
    };
}

<section class="site-page-header">
    <div class="site-page-header__inner">
        <p class="site-page-kicker">Doctors &amp; Team</p>
        <h1 class="site-page-title mt-3">Doctors, leadership, and care staff working together.</h1>
        <p class="site-page-lede mt-4 max-w-3xl">Meet the management, clinical, and care teams serving Boniface &amp; Paulina Okafor Memorial Hospital.</p>
    </div>
</section>

<section class="site-page-surface">
    <div class="mx-auto max-w-site px-6">
        @if (fatherToochukwu is not null)
        {
            <article class="site-card mb-12 grid overflow-hidden md:grid-cols-[minmax(220px,320px)_1fr]">
                <img src="@fatherToochukwu.ImageUrl"
                     alt="Portrait of @fatherToochukwu.FullName"
                     class="h-80 w-full object-cover object-top md:h-full"
                     width="768"
                     height="1024" />
                <div class="flex flex-col justify-center p-6 sm:p-8 lg:p-10">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-primary-800">Founder &amp; Spiritual Care Provider</p>
                    <h2 class="mt-3 text-2xl font-bold leading-tight text-slate-950 sm:text-3xl">@fatherToochukwu.FullName</h2>
                    <p class="mt-2 text-sm font-semibold text-secondary-950">@fatherToochukwu.Specialty</p>
                    <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">Fr. Toochukwu provides spiritual-emotional support and counselling for individuals, families, and couples through reviewed teleconsultation requests.</p>
                    <div class="site-action-row mt-6">
                        <a asp-controller="Home" asp-action="DoctorProfile" asp-route-slug="@fatherToochukwu.Slug" class="site-button site-button--primary">View full profile</a>
                        <a asp-controller="Teleconsultations" asp-action="Create" asp-route-departmentId="@fatherToochukwu.DepartmentId" asp-route-doctorId="@fatherToochukwu.Id" class="site-button site-button--secondary">Request teleconsultation</a>
                    </div>
                </div>
            </article>
        }

        <div class="grid items-stretch gap-5 md:grid-cols-3">
            @foreach (var item in leadership)
            {
                <article class="premium-card flex h-full flex-col border border-secondary-300 bg-white p-6">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-primary-800">@item.Item1</p>
                    <p class="mt-3 text-sm leading-6 text-[#4a4a4a]">@item.Item2</p>
                </article>
            }
        </div>

        <div class="mt-14" id="clinical-team">
            <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div>
                    <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Clinical Team</p>
                    <h2 class="mt-2 font-serif text-3xl font-bold text-[#1c1c1c]">Doctors</h2>
                </div>
                <a href="#clinical-team" class="text-[11px] font-semibold uppercase tracking-[0.14em] text-primary-700 hover:text-primary-900">Clinical profiles</a>
            </div>
            <div class="grid items-stretch gap-5 md:grid-cols-2 lg:grid-cols-3">
                @if (clinicalDoctors.Any())
                {
                    @foreach (var doctor in clinicalDoctors)
                    {
                        <article class="premium-card flex h-full flex-col border border-secondary-300 bg-white p-6">
                            <p class="text-[10px] uppercase tracking-[0.16em] text-primary-800">@(doctor.Department?.Name ?? "Medicine")</p>
                            <h3 class="mt-2 font-serif text-2xl font-bold text-[#1c1c1c]">@doctor.FullName</h3>
                            <p class="mt-1 text-sm font-semibold text-secondary-950">@doctor.Specialty</p>
                            @if (!string.IsNullOrWhiteSpace(doctor.Bio))
                            {
                                <p class="mt-3 flex-1 text-sm leading-6 text-[#5a5a5a]">@(doctor.Bio.Length > 130 ? doctor.Bio[..130] + "..." : doctor.Bio)</p>
                            }
                            <div class="card-action-row">
                                <a asp-controller="Home"
                                   asp-action="DoctorProfile"
                                   asp-route-slug="@doctor.Slug"
                                   class="inline-flex items-center text-[11px] font-semibold uppercase tracking-[0.12em] text-primary-700 hover:text-primary-900">
                                    View profile
                                </a>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="rounded-md border border-secondary-300 bg-white p-6 md:col-span-2 lg:col-span-3">
                        <p class="text-sm leading-6 text-slate-600">Doctor profiles are being updated. Please contact the hospital for current clinic availability.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
