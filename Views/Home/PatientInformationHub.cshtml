@{
    ViewData["Title"] = "Patient Information Hub";
    ViewData["PageTitle"] = "Patient Information | Okafor Memorial Hospital";
    ViewData["MetaDescription"] = "Prepare for care at Okafor Memorial Hospital with practical information about appointments, teleconsultations, hospital services, privacy, and contacting the team.";
    ViewData["CanonicalPath"] = "/patient-information";
}

@section Styles {
    <style>
        .hub-shell {
            min-height: 100vh;
        }

        .hub-sidebar {
            background-color: #132b20;
            color: #c0e3d6;
        }

        .hub-link {
            color: #c0e3d6;
            border-radius: 0.5rem;
            min-height: 44px;
            display: flex;
            align-items: center;
        }

        .hub-link:hover,
        .hub-link.is-active {
            background-color: #1b3d2d;
            color: #ffffff;
        }

        .hub-panel {
            border: 1px solid #d9f1f7;
            border-radius: 0.75rem;
            background: #ffffff;
            box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
        }

        .hub-drawer-backdrop {
            background: rgba(15, 23, 42, 0.42);
        }

        @@media (max-width: 1023.98px) {
            .hub-sidebar-drawer {
                width: min(88vw, 320px);
            }
        }
    </style>
}

<section class="site-page-header">
    <div class="site-page-header__inner">
        <div class="site-page-header__split">
            <div class="max-w-4xl">
                <p class="site-page-kicker">Patient Resources</p>
                <h1 class="site-page-title mt-3">Patient Information Hub</h1>
                <p class="site-page-lede mt-5 max-w-3xl">
                    Use this page to prepare for your visit, understand your rights, and know where to get help before you arrive.
                </p>
            </div>
            <button id="hub-sidebar-toggle" type="button"
                    class="site-button site-button--secondary mt-1 lg:hidden">
                Browse Sections
            </button>
        </div>
    </div>
</section>

<section class="section-shell py-10 md:py-12">
    <div class="hub-shell mx-auto grid max-w-site gap-8 px-6 lg:grid-cols-[260px,minmax(0,1fr)] lg:items-start">
        <div id="hub-sidebar-backdrop" class="hub-drawer-backdrop fixed inset-0 z-40 hidden lg:hidden"></div>

        <aside id="hub-sidebar"
               class="hub-sidebar hub-sidebar-drawer fixed inset-y-0 left-0 z-50 hidden overflow-y-auto px-4 py-5 shadow-2xl lg:static lg:z-auto lg:block lg:rounded-xl lg:px-3 lg:py-3 lg:shadow-none">
            <div class="flex items-start justify-between gap-3 border-b border-[#1b3d2d] px-3 pb-4 lg:pb-3">
                <div>
                    <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[#57a080]">Patient Guide</p>
                    <p class="mt-1 text-sm font-semibold text-white">Information Hub</p>
                </div>
                <button id="hub-sidebar-close" type="button"
                        class="inline-flex h-10 w-10 items-center justify-center rounded-md text-[#c0e3d6] transition-colors hover:bg-[#1b3d2d] hover:text-white lg:hidden"
                        aria-label="Close patient information navigation">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <nav class="mt-4 grid gap-1 text-[11px] font-semibold uppercase tracking-[0.12em]" aria-label="Patient information sections">
                <a href="#online-services" class="hub-link is-active px-3 py-3">Online Services</a>
                <a href="#before-your-visit" class="hub-link px-3 py-3">Before Your Visit</a>
                <a href="#during-your-visit" class="hub-link px-3 py-3">During Your Visit</a>
                <a href="#emergency" class="hub-link px-3 py-3 text-[#f8c9c9] hover:text-white">Emergency</a>
            </nav>

            <div class="mt-5 border-t border-[#1b3d2d] px-3 pt-5">
                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#57a080]">Need Help?</p>
                <p class="mt-3 text-sm leading-6 text-[#c0e3d6]">Our team is available Monday - Saturday, 8am - 6pm.</p>
                <div class="mt-4 space-y-2 text-sm">
                    <p><a href="tel:112" class="font-semibold text-white hover:underline">Emergency: 112 / 199</a></p>
                    <p><a href="mailto:info@okaformemorial.org" class="font-semibold text-white hover:underline">info@okaformemorial.org</a></p>
                </div>
                <div class="mt-5 flex flex-col gap-2">
                    <a asp-area="" asp-controller="Home" asp-action="Contact"
                       class="site-button site-button--light">
                        Contact Us
                    </a>
                    <a asp-area="" asp-controller="AppointmentRequests" asp-action="Create"
                       class="site-button site-button--secondary">
                        Book Appointment
                    </a>
                </div>
            </div>
        </aside>

        <div class="min-w-0 space-y-6">
            <section id="online-services" class="hub-panel scroll-mt-28 px-6 py-8 md:px-8 md:py-10">
                <div class="max-w-3xl">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Online Services</p>
                    <h2 class="mt-3 font-serif text-3xl font-bold leading-tight text-[#1c1c1c]">Access your patient account</h2>
                    <p class="mt-4 text-[14px] leading-7 text-[#4a4a4a]">
                        When you register for a patient account, our clinical team can release documents directly to you, such as
                        discharge letters, test result summaries, referral notes, and other records from your care.
                    </p>
                    <p class="mt-3 text-[14px] leading-7 text-[#4a4a4a]">
                        Your account is private, secure, and free to create. You only see what your care team has shared with you.
                    </p>
                </div>

                <div class="site-action-row mt-6">
                    @if (!Context.User.Identity?.IsAuthenticated ?? true)
                    {
                        <a asp-area="Identity" asp-page="/Account/Register"
                           class="site-button site-button--primary">
                            Create Free Account
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Login"
                           class="site-button site-button--secondary">
                            Sign In
                        </a>
                    }
                    else
                    {
                        <a asp-area="Patient" asp-controller="Dashboard" asp-action="Index"
                           class="site-button site-button--primary">
                            Go to My Portal
                        </a>
                    }
                </div>

                <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-5">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">Your Documents</h3>
                        <p class="mt-3 text-[13px] leading-6 text-[#6c6c6c]">Download discharge letters, referral notes, and results shared by your care team.</p>
                    </article>
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-5">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">Appointments</h3>
                        <p class="mt-3 text-[13px] leading-6 text-[#6c6c6c]">View your upcoming and past appointments in one place.</p>
                    </article>
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-5">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">Messages</h3>
                        <p class="mt-3 text-[13px] leading-6 text-[#6c6c6c]">Send and receive messages from the hospital team securely.</p>
                    </article>
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-5">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">Your Profile</h3>
                        <p class="mt-3 text-[13px] leading-6 text-[#6c6c6c]">Keep your contact and personal details up to date for accurate care.</p>
                    </article>
                </div>
            </section>

            <section id="before-your-visit" class="hub-panel scroll-mt-28 px-6 py-8 md:px-8 md:py-10">
                <div class="max-w-3xl">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Before Your Visit</p>
                    <h2 class="mt-3 font-serif text-3xl font-bold text-[#1c1c1c]">What to bring and how to prepare</h2>
                    <p class="mt-4 text-[14px] leading-7 text-[#4a4a4a]">
                        Bringing the right documents and preparing a little in advance helps registration run smoothly and gives our clinical team what they need from the start.
                    </p>
                </div>

                <div class="mt-8 grid gap-4 lg:grid-cols-2">
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-6">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.12em] text-[#1c1c1c]">What to Bring</h3>
                        <div class="mt-5 space-y-5 text-[13px] leading-6 text-[#4a4a4a]">
                            <div>
                                <p class="font-semibold text-[#1c1c1c]">Identification</p>
                                <ul class="mt-2 space-y-2">
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Government-issued photo ID (passport, national ID card, or driver's licence)</span></li>
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Your hospital patient number if you have been seen here before</span></li>
                                </ul>
                            </div>
                            <div>
                                <p class="font-semibold text-[#1c1c1c]">Medical Documents</p>
                                <ul class="mt-2 space-y-2">
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Any previous test results, scans, or discharge summaries</span></li>
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Referral letter from your GP or previous hospital if applicable</span></li>
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Vaccination records if relevant to your appointment</span></li>
                                </ul>
                            </div>
                            <div>
                                <p class="font-semibold text-[#1c1c1c]">Medications</p>
                                <ul class="mt-2 space-y-2">
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>A written or printed list of all current medications, including dosage</span></li>
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Bring the actual medication packaging where possible</span></li>
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Note any known drug allergies or reactions</span></li>
                                </ul>
                            </div>
                            <div>
                                <p class="font-semibold text-[#1c1c1c]">Payments &amp; Insurance</p>
                                <ul class="mt-2 space-y-2">
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Insurance card or membership number if your visit is covered</span></li>
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Payment method if self-paying</span></li>
                                    <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#8594;</span><span>Any pre-authorisation or referral codes required by your insurer</span></li>
                                </ul>
                            </div>
                        </div>
                    </article>

                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-6">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.12em] text-[#1c1c1c]">Appointment Checklist</h3>
                        <ol class="mt-5 space-y-4">
                            <li class="flex gap-4">
                                <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-md bg-primary-800 text-[12px] font-bold text-white">1</span>
                                <div>
                                    <p class="font-semibold text-[#1c1c1c]">Arrive at least 15 minutes early</p>
                                    <p class="mt-1 text-[13px] leading-6 text-[#6c6c6c]">Allow time for parking, registration, and finding the correct department.</p>
                                </div>
                            </li>
                            <li class="flex gap-4">
                                <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-md bg-primary-800 text-[12px] font-bold text-white">2</span>
                                <div>
                                    <p class="font-semibold text-[#1c1c1c]">Bring all required documents</p>
                                    <p class="mt-1 text-[13px] leading-6 text-[#6c6c6c]">Prepare everything the evening before your appointment.</p>
                                </div>
                            </li>
                            <li class="flex gap-4">
                                <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-md bg-primary-800 text-[12px] font-bold text-white">3</span>
                                <div>
                                    <p class="font-semibold text-[#1c1c1c]">Follow any pre-appointment instructions</p>
                                    <p class="mt-1 text-[13px] leading-6 text-[#6c6c6c]">If your appointment requires fasting, specific clothing, or avoiding certain medications, follow the instructions provided by our team.</p>
                                </div>
                            </li>
                            <li class="flex gap-4">
                                <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-md bg-primary-800 text-[12px] font-bold text-white">4</span>
                                <div>
                                    <p class="font-semibold text-[#1c1c1c]">Need to reschedule or cancel?</p>
                                    <p class="mt-1 text-[13px] leading-6 text-[#6c6c6c]">
                                        Please contact us as early as possible, ideally 24 hours before your appointment.
                                        <a asp-area="" asp-controller="Home" asp-action="Contact" class="ml-1 font-semibold text-primary-700 hover:underline">Contact the hospital &#8594;</a>
                                    </p>
                                </div>
                            </li>
                        </ol>
                    </article>
                </div>

                <div class="mt-6 rounded-lg border border-secondary-300 bg-secondary-50 px-6 py-5 text-[13px] leading-6 text-[#4a4a4a]">
                    <strong class="text-[#1c1c1c]">Questions about fees or coverage?</strong> Our billing team can help before your appointment.
                </div>

                <div class="site-action-row mt-6">
                    <a asp-area="" asp-controller="AppointmentRequests" asp-action="Create"
                       class="site-button site-button--primary">
                        Book an Appointment
                    </a>
                    <a asp-area="" asp-controller="Home" asp-action="Contact"
                       class="site-button site-button--secondary">
                        Contact Billing Team
                    </a>
                </div>
            </section>

            <section id="during-your-visit" class="hub-panel scroll-mt-28 px-6 py-8 md:px-8 md:py-10">
                <div class="max-w-3xl">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">During Your Visit</p>
                    <h2 class="mt-3 font-serif text-3xl font-bold text-[#1c1c1c]">Visiting hours, rights, and responsibilities</h2>
                    <p class="mt-4 text-[14px] leading-7 text-[#4a4a4a]">
                        Here is the practical information patients and families usually need once a visit is scheduled or underway.
                    </p>
                </div>

                <div class="mt-8 grid gap-4 xl:grid-cols-[1.1fr,0.9fr]">
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-6">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.12em] text-[#1c1c1c]">Visiting Hours</h3>
                        <div class="mt-5 grid gap-4 md:grid-cols-3">
                            <div class="rounded-lg border border-secondary-300 bg-white p-5">
                                <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-primary-700">General Wards</p>
                                <p class="mt-3 text-xl font-semibold text-[#1c1c1c]">9am - 6pm</p>
                                <p class="mt-2 text-[13px] text-[#6c6c6c]">Monday to Saturday</p>
                                <p class="mt-1 text-[13px] text-[#6c6c6c]">Sunday: 10am - 4pm</p>
                            </div>
                            <div class="rounded-lg border border-secondary-300 bg-white p-5">
                                <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-primary-700">Maternity Unit</p>
                                <p class="mt-3 text-xl font-semibold text-[#1c1c1c]">10am - 7pm</p>
                                <p class="mt-2 text-[13px] text-[#6c6c6c]">Daily - partners only outside these hours</p>
                                <p class="mt-1 text-[13px] text-[#6c6c6c]">Contact the ward for more detail.</p>
                            </div>
                            <div class="rounded-lg border border-red-200 bg-red-50 p-5">
                                <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-red-700">Emergency Care</p>
                                <p class="mt-3 text-xl font-semibold text-red-800">24 / 7</p>
                                <p class="mt-2 text-[13px] leading-6 text-red-700">Family members may wait in the designated waiting area at all times.</p>
                            </div>
                        </div>
                        <div class="mt-5 rounded-lg border border-secondary-300 bg-secondary-50 px-5 py-4 text-[13px] leading-6 text-[#4a4a4a]">
                            <strong class="text-[#1c1c1c]">Please note:</strong> Visiting hours may vary by department, time of year, or clinical circumstance.
                            If you are unsure, please call ahead to confirm. Children under 12 must be accompanied by an adult at all times.
                        </div>
                    </article>

                    <div class="grid gap-4">
                        <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-6">
                            <h3 class="border-l-2 border-primary-700 pl-3 text-[13px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">Your Rights as a Patient</h3>
                            <ul class="mt-5 space-y-3 text-[13px] leading-6 text-[#4a4a4a]">
                                <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#10003;</span><span>Receive respectful, dignified, and non-discriminatory care at all times</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#10003;</span><span>Be fully informed about your diagnosis, treatment options, and prognosis in plain language</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#10003;</span><span>Privacy and confidentiality of your personal and medical information</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#10003;</span><span>Consent to or decline any treatment or procedure after receiving full information</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#10003;</span><span>Access a second opinion or request a referral to another specialist</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-primary-800">&#10003;</span><span>Make a complaint without fear of it affecting the quality of your care</span></li>
                            </ul>
                        </article>

                        <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-6">
                            <h3 class="border-l-2 border-secondary-400 pl-3 text-[13px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">Your Responsibilities</h3>
                            <ul class="mt-5 space-y-3 text-[13px] leading-6 text-[#4a4a4a]">
                                <li class="flex gap-3"><span class="mt-0.5 text-[#888]">&#8594;</span><span>Provide complete and truthful information about your medical history, symptoms, and medications</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-[#888]">&#8594;</span><span>Follow the care plan and instructions agreed with your clinical team</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-[#888]">&#8594;</span><span>Treat all hospital staff, visitors, and other patients with courtesy and respect</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-[#888]">&#8594;</span><span>Notify us in advance if you cannot attend a scheduled appointment</span></li>
                                <li class="flex gap-3"><span class="mt-0.5 text-[#888]">&#8594;</span><span>Respect hospital policies, including no-smoking rules and visiting hour guidelines</span></li>
                            </ul>
                        </article>
                    </div>
                </div>
            </section>

            <section id="emergency" class="hub-panel scroll-mt-28 border-red-200 px-6 py-8 md:px-8 md:py-10">
                <div class="max-w-3xl">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-red-600">Urgent &amp; Emergency</p>
                    <h2 class="mt-3 font-serif text-3xl font-bold text-[#1c1c1c]">Emergency Information</h2>
                </div>

                <div class="mt-6 rounded-lg border border-red-300 bg-red-50 px-6 py-5">
                    <p class="text-[15px] font-semibold text-red-900">If this is a life-threatening emergency, do not wait.</p>
                    <p class="mt-2 text-[14px] leading-6 text-red-800">
                        Call emergency services immediately. In Nigeria, dial <strong>112</strong> (national emergency) or
                        <strong>199</strong> (ambulance), or proceed directly to our Emergency Department, which is open 24 hours.
                    </p>
                </div>

                <div class="mt-8 grid gap-4 md:grid-cols-2">
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-6">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">Emergency Department</h3>
                        <p class="mt-4 text-[13px] leading-6 text-[#4a4a4a]">
                            Our Emergency Care department is open <strong>24 hours a day, 7 days a week</strong>, including public holidays.
                        </p>
                        <p class="mt-4 text-[13px] text-[#4a4a4a]">Emergency numbers: <a href="tel:112" class="font-semibold text-primary-700 hover:underline">112 / 199</a></p>
                        <p class="mt-2 text-[13px] leading-6 text-[#4a4a4a]">Address: Ndibemaduka Compound, Umudim Ngodo Isuochi, Umunneochi L.G.A, Abia State, Nigeria</p>
                    </article>
                    <article class="rounded-lg border border-secondary-300 bg-secondary-100 p-6">
                        <h3 class="text-[12px] font-bold uppercase tracking-[0.1em] text-[#1c1c1c]">When to Use Emergency Care</h3>
                        <ul class="mt-4 space-y-3 text-[13px] leading-6 text-[#4a4a4a]">
                            <li class="flex gap-3"><span class="mt-0.5 text-red-600">&#8594;</span><span>Chest pain or difficulty breathing</span></li>
                            <li class="flex gap-3"><span class="mt-0.5 text-red-600">&#8594;</span><span>Loss of consciousness or suspected stroke</span></li>
                            <li class="flex gap-3"><span class="mt-0.5 text-red-600">&#8594;</span><span>Severe bleeding or trauma</span></li>
                            <li class="flex gap-3"><span class="mt-0.5 text-red-600">&#8594;</span><span>High fever in young children or infants</span></li>
                            <li class="flex gap-3"><span class="mt-0.5 text-red-600">&#8594;</span><span>Serious allergic reactions (anaphylaxis)</span></li>
                        </ul>
                    </article>
                </div>
            </section>
        </div>
    </div>
</section>

<button id="back-to-top" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })" aria-label="Back to top"
        class="fixed bottom-6 right-6 z-50 flex h-11 w-11 items-center justify-center rounded-full bg-primary-800 text-white shadow-lg transition-opacity duration-300 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2 opacity-0 pointer-events-none">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
    </svg>
</button>

@section Scripts {
    <script>
        (function () {
            var btn = document.getElementById('back-to-top');
            var sidebar = document.getElementById('hub-sidebar');
            var openButton = document.getElementById('hub-sidebar-toggle');
            var closeButton = document.getElementById('hub-sidebar-close');
            var backdrop = document.getElementById('hub-sidebar-backdrop');
            var links = sidebar ? sidebar.querySelectorAll('.hub-link') : [];
            var escapeHandler = null;

            function openSidebar() {
                if (!sidebar || !backdrop) {
                    return;
                }

                sidebar.classList.remove('hidden');
                backdrop.classList.remove('hidden');
                document.body.classList.add('overflow-hidden');
                
                // Set focus to close button and add Escape key listener
                if (closeButton) {
                    closeButton.focus();
                }
                
                escapeHandler = function (event) {
                    if (event.key === 'Escape') {
                        closeSidebar();
                    }
                };
                document.addEventListener('keydown', escapeHandler);
            }

            function closeSidebar() {
                if (!sidebar || !backdrop) {
                    return;
                }

                if (window.innerWidth >= 1024) {
                    return;
                }

                sidebar.classList.add('hidden');
                backdrop.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
                
                // Remove Escape listener and restore focus
                if (escapeHandler) {
                    document.removeEventListener('keydown', escapeHandler);
                    escapeHandler = null;
                }
                
                if (openButton) {
                    openButton.focus();
                }
            }

            function setActiveLink(target) {
                links.forEach(function (link) {
                    link.classList.toggle('is-active', link.getAttribute('href') === target);
                });
            }

            if (openButton) {
                openButton.addEventListener('click', openSidebar);
            }

            if (closeButton) {
                closeButton.addEventListener('click', closeSidebar);
            }

            if (backdrop) {
                backdrop.addEventListener('click', closeSidebar);
            }

            links.forEach(function (link) {
                link.addEventListener('click', function () {
                    setActiveLink(link.getAttribute('href'));
                    closeSidebar();
                });
            });

            window.addEventListener('resize', function () {
                if (window.innerWidth >= 1024) {
                    if (sidebar) {
                        sidebar.classList.remove('hidden');
                    }
                    if (backdrop) {
                        backdrop.classList.add('hidden');
                    }
                    document.body.classList.remove('overflow-hidden');
                }
            });

            if (btn) {
                window.addEventListener('scroll', function () {
                    if (window.scrollY > 300) {
                        btn.classList.remove('opacity-0', 'pointer-events-none');
                        btn.classList.add('opacity-100');
                    } else {
                        btn.classList.add('opacity-0', 'pointer-events-none');
                        btn.classList.remove('opacity-100');
                    }
                }, { passive: true });
            }
        })();
    </script>
}
