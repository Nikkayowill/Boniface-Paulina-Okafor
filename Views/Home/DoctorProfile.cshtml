@model Okafor_.NET.Models.Doctor

@{
    ViewData["Title"] = Model.FullName;
    var initials = string.Concat(
        Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                      .Take(2)
                      .Select(name => char.ToUpperInvariant(name[0])));
    var isFatherToochukwu = string.Equals(
        Model.Slug,
        "rev-fr-dr-toochukwu-bartholomew-okafor",
        StringComparison.OrdinalIgnoreCase);
}

<section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-12">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary-800">@(isFatherToochukwu ? "Founder & Care Provider" : "Doctor Profile")</p>
        <h1 class="mt-2 font-serif text-4xl text-slate-900">@Model.FullName</h1>
        <p class="mt-3 text-base text-slate-600">@Model.Specialty</p>
    </div>
</section>

<section class="bg-slate-50">
    <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:grid-cols-[300px,1fr]">
        <aside>
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl"
                     onerror="this.onerror=null;this.src='/images/placeholders/placeholder.svg'"
                     alt="Photo of @Model.FullName"
                     class="h-80 w-full rounded-md border border-slate-200 object-cover object-top" />
            }
            else
            {
                <div class="flex h-80 items-center justify-center rounded-md border border-slate-200 bg-primary-50" aria-hidden="true">
                    <span class="font-serif text-5xl font-bold text-primary-700">@initials</span>
                </div>
            }

            @if (isFatherToochukwu)
            {
                <a asp-controller="Teleconsultations"
                   asp-action="Create"
                   asp-route-departmentId="@Model.DepartmentId"
                   asp-route-doctorId="@Model.Id"
                   class="glow-button mt-4 inline-flex w-full items-center justify-center bg-primary-800 px-4 py-3 text-center text-sm font-semibold text-white transition-all duration-200 hover:bg-primary-700 hover:shadow-md">
                    Request Psychotherapy Teleconsultation
                </a>
                <p class="mt-3 text-xs leading-5 text-slate-500">Requests are reviewed before a private video session is confirmed. Staff will explain the session fee or any sponsored-care availability before confirmation. This service is not for emergencies.</p>
                <a asp-controller="Donation"
                   asp-action="Index"
                   asp-route-purpose="@Okafor_.NET.Models.DonationPurposeCodes.FatherToochukwuSpiritualCare"
                   class="mt-3 inline-flex w-full items-center justify-center border border-primary-300 px-4 py-3 text-center text-sm font-semibold text-primary-900 transition hover:border-primary-700 hover:bg-primary-50">
                    Support His Spiritual Care Program
                </a>
                <p class="mt-2 text-xs leading-5 text-slate-500">Donations are optional hospital program support. They are separate from session fees and do not affect booking priority.</p>
            }
            else
            {
                <a asp-controller="AppointmentRequests"
                   asp-action="Create"
                   asp-route-departmentId="@Model.DepartmentId"
                   asp-route-doctorId="@Model.Id"
                   class="glow-button mt-4 inline-flex w-full items-center justify-center bg-primary-800 px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:bg-primary-700 hover:shadow-md">
                    Book Appointment
                </a>
            }
        </aside>

        <article class="rounded-md border border-slate-200 bg-white p-6">
            <dl class="space-y-4 text-sm text-slate-700">
                <div>
                    <dt class="font-semibold text-slate-900">Specialty</dt>
                    <dd class="mt-1">@Model.Specialty</dd>
                </div>
                <div>
                    <dt class="font-semibold text-slate-900">Department</dt>
                    <dd class="mt-1">@(Model.Department?.Name ?? "N/A")</dd>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Qualifications) && !isFatherToochukwu)
                {
                    <div>
                        <dt class="font-semibold text-slate-900">Qualifications</dt>
                        <dd class="mt-1">@Model.Qualifications</dd>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ConsultationHours))
                {
                    <div>
                        <dt class="font-semibold text-slate-900">@(isFatherToochukwu ? "Teleconsultation Availability" : "Consultation Hours")</dt>
                        <dd class="mt-1">@Model.ConsultationHours</dd>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <div>
                        <dt class="font-semibold text-slate-900">Profile</dt>
                        <dd class="mt-1 leading-7">@Model.Bio</dd>
                    </div>
                }
                else
                {
                    <div>
                        <dt class="font-semibold text-slate-900">Profile</dt>
                        <dd class="mt-1 leading-7">Professional profile information will be updated soon.</dd>
                    </div>
                }
                @if (isFatherToochukwu)
                {
                    <div>
                        <dt class="font-semibold text-slate-900">Education and Training</dt>
                        <dd class="mt-2">
                            <ul class="list-disc space-y-2 pl-5 leading-6 marker:text-primary-700">
                                <li>Bachelor of Philosophy (B.Phil), Claretian Institute of Philosophy, Nekede, Owerri — affiliated with the Pontifical Urban University, Rome</li>
                                <li>Bachelor of Theology (B.Th), Bigard Memorial Seminary, Enugu — affiliated with the Pontifical Urban University, Rome</li>
                                <li>Diploma in Drug Dependency Counselling, St. Bonaventure University in association with Hogares Claret, Medellín, Colombia</li>
                                <li>Master of Arts in Counselling Psychology, Yorkville University, New Brunswick, Canada</li>
                                <li>Doctor of Philosophy in Clinical Psychology, Enugu State University of Science and Technology, Enugu, Nigeria</li>
                            </ul>
                        </dd>
                    </div>
                    <div>
                        <dt class="font-semibold text-slate-900">Languages</dt>
                        <dd class="mt-1">Igbo, English, Spanish, and basic French</dd>
                    </div>
                    <div>
                        <dt class="font-semibold text-slate-900">Leadership</dt>
                        <dd class="mt-1 leading-7">Founder of B&amp;P Memorial Hospital and B&amp;P Charity Foundation; Coordinator of Projects for the Nigeria Family Helper Program in Halifax, Canada.</dd>
                    </div>
                    <div>
                        <dt class="font-semibold text-slate-900">Contact</dt>
                        <dd class="mt-1"><a href="mailto:toochukwuokafor@yahoo.com" class="font-semibold text-primary-800 underline decoration-primary-300 underline-offset-4">toochukwuokafor@yahoo.com</a></dd>
                    </div>
                }
            </dl>
        </article>
    </div>
</section>
