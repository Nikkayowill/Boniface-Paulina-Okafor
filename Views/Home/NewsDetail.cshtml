@model Okafor_.NET.ViewModels.PublicPostDetailViewModel
@using System.Text.Json
@using Okafor_.NET.Services
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Okafor_.NET.Services.SeoUrlService SeoUrls

@{
    var post = Model.Post;
    var description = PostPresentation.Description(post);
    var canonicalPath = $"/news/{post.Slug}";
    var canonicalUrl = SeoUrls.Absolute(canonicalPath);
    var imageUrl = SeoUrls.Absolute(post.ThumbnailImageUrl ?? "/images/placeholders/Hospital/GOEH7326.webp");
    var publisherName = Configuration["Editorial:PublisherName"] ??
        "Boniface and Paulina Okafor Memorial Hospital";
    var byline = Configuration["Editorial:Byline"] ?? "Hospital communications team";
    var shareText = Uri.EscapeDataString($"{post.Title} — {canonicalUrl}");
    var blocks = PostPresentation.ContentBlocks(post.Content);

    ViewData["Title"] = post.Title;
    ViewData["PageTitle"] = $"{post.Title} | Okafor Memorial Hospital";
    ViewData["MetaDescription"] = description;
    ViewData["CanonicalPath"] = canonicalPath;
    ViewData["SocialImage"] = post.ThumbnailImageUrl;
    ViewData["OpenGraphType"] = "article";

    var articleSchema = JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "BlogPosting",
        ["headline"] = post.Title,
        ["description"] = description,
        ["image"] = new[] { imageUrl },
        ["datePublished"] = PostPresentation.AsUtc(post.CreatedAt).ToString("O"),
        ["dateModified"] = PostPresentation.AsUtc(post.UpdatedAt ?? post.CreatedAt).ToString("O"),
        ["mainEntityOfPage"] = canonicalUrl,
        ["inLanguage"] = "en-NG",
        ["author"] = new Dictionary<string, object?>
        {
            ["@type"] = "Organization",
            ["name"] = publisherName,
            ["url"] = $"{SeoUrls.BaseUrl}/"
        },
        ["publisher"] = new Dictionary<string, object?>
        {
            ["@type"] = "Organization",
            ["name"] = publisherName,
            ["logo"] = new Dictionary<string, string>
            {
                ["@type"] = "ImageObject",
                ["url"] = SeoUrls.Absolute("/images/icons/okafor-hospital-icon.svg")
            }
        }
    });
    var breadcrumbSchema = JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "BreadcrumbList",
        ["itemListElement"] = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@type"] = "ListItem",
                ["position"] = 1,
                ["name"] = "Hospital notes",
                ["item"] = SeoUrls.Absolute("/news")
            },
            new Dictionary<string, object?>
            {
                ["@type"] = "ListItem",
                ["position"] = 2,
                ["name"] = post.Title,
                ["item"] = canonicalUrl
            }
        }
    });
}

@section Head {
    <meta property="article:published_time" content="@PostPresentation.AsUtc(post.CreatedAt).ToString("O")" />
    <meta property="article:modified_time" content="@PostPresentation.AsUtc(post.UpdatedAt ?? post.CreatedAt).ToString("O")" />
    <meta property="article:author" content="@publisherName" />
    <script type="application/ld+json">@Html.Raw(articleSchema)</script>
    <script type="application/ld+json">@Html.Raw(breadcrumbSchema)</script>
}

<main class="editorial-article">
    <header class="editorial-article__header">
        <div class="editorial-reading-column">
            <a asp-controller="Home" asp-action="News" class="editorial-back-link">← Hospital notes</a>
            <div class="editorial-byline">
                <span>@PostPresentation.FormatLabel(post)</span>
                <span aria-hidden="true">·</span>
                <time datetime="@post.CreatedAt.ToString("yyyy-MM-dd")">@post.CreatedAt.ToString("d MMMM yyyy")</time>
                <span aria-hidden="true">·</span>
                <span>@PostPresentation.ReadingMinutes(post) min read</span>
            </div>
            <h1>@post.Title</h1>
            @if (!string.IsNullOrWhiteSpace(description))
            {
                <p class="editorial-article__dek">@description</p>
            }
            <div class="editorial-article__author">
                <span class="editorial-article__author-mark" aria-hidden="true">BP</span>
                <div>
                    <strong>@byline</strong>
                    <span>@publisherName</span>
                </div>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(post.ThumbnailImageUrl))
    {
        <figure class="editorial-article__hero">
            <img src="@post.ThumbnailImageUrl"
                 alt="@post.Title"
                 width="1400"
                 height="788"
                 loading="eager"
                 fetchpriority="high"
                 decoding="async" />
        </figure>
    }

    <div class="editorial-reading-column">
        <article class="editorial-prose">
            @foreach (var block in blocks)
            {
                switch (block.Type)
                {
                    case PostContentBlockType.Heading:
                        <h2>@block.Lines[0]</h2>
                        break;
                    case PostContentBlockType.UnorderedList:
                        <ul>
                            @foreach (var item in block.Lines)
                            {
                                <li>@item</li>
                            }
                        </ul>
                        break;
                    case PostContentBlockType.OrderedList:
                        <ol>
                            @foreach (var item in block.Lines)
                            {
                                <li>@item</li>
                            }
                        </ol>
                        break;
                    default:
                        <p>@block.Lines[0]</p>
                        break;
                }
            }
        </article>

        <aside class="editorial-health-note" aria-label="Health information notice">
            <strong>A note about health information</strong>
            <p>
                This article provides general education and does not replace an assessment by a qualified healthcare
                professional. Contact the hospital or seek urgent care when symptoms are severe or worsening.
            </p>
        </aside>

        <div class="editorial-share" aria-label="Share this post">
            <span>Share this note</span>
            <a href="https://wa.me/?text=@shareText" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            <a href="mailto:?subject=@Uri.EscapeDataString(post.Title)&body=@shareText">Email</a>
            <a href="@canonicalUrl">Open link</a>
        </div>

        <section class="editorial-care-cta" aria-labelledby="article-care-title">
            <p class="hospital-kicker">Need to speak with the hospital?</p>
            <h2 id="article-care-title">Turn information into a clear next step.</h2>
            <p>Request an appointment or contact the hospital team if you need guidance about available services.</p>
            <div>
                <a asp-controller="AppointmentRequests" asp-action="Create" class="hospital-button hospital-button--primary">Request appointment</a>
                <a asp-controller="Home" asp-action="Contact" class="hospital-button hospital-button--outline">Contact hospital</a>
            </div>
        </section>
    </div>

    @if (Model.MorePosts.Count > 0)
    {
        <section class="public-wrap editorial-more" aria-labelledby="more-notes-title">
            <div class="editorial-stream__heading">
                <h2 id="more-notes-title">Continue reading</h2>
                <a asp-controller="Home" asp-action="News">View every note →</a>
            </div>
            <div class="editorial-more__grid">
                @foreach (var item in Model.MorePosts)
                {
                    <article>
                        <span>@PostPresentation.FormatLabel(item)</span>
                        <h3><a asp-controller="Home" asp-action="NewsDetail" asp-route-slug="@item.Slug">@item.Title</a></h3>
                        <p>@PostPresentation.Description(item, 130)</p>
                    </article>
                }
            </div>
        </section>
    }
</main>
