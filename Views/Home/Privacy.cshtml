@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-14">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary-800">Privacy Policy</p>
        <h1 class="mt-2 font-serif text-4xl text-slate-900">Your privacy and confidentiality matter.</h1>
        <p class="mt-5 text-base leading-7 text-slate-600">
            Boniface and Paulina Okafor Memorial Hospital protects personal and medical information in accordance with applicable healthcare privacy standards.
        </p>
        <div class="mt-8 space-y-6 text-sm leading-7 text-slate-600">
            <p>We collect only information required for clinical care, appointment coordination, and hospital operations.</p>
            <p>Patient records are handled with strict access controls, audit procedures, and confidentiality obligations for all staff.</p>
            <p>For questions regarding privacy practices, contact our hospital administration office.</p>
        </div>
    </div>
</section>
