@model Okafor_.NET.ViewModels.TeleconsultationRequestViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Book a Teleconsultation";
}

<section class="ok-page-header">
    <div class="mx-auto max-w-site px-4 sm:px-6">
        <p class="ok-kicker">Virtual Care</p>
        <h1 class="ok-page-title mt-3">Book a Teleconsultation</h1>
        <p class="ok-copy mt-4 max-w-2xl">
            Request a video or follow-up consultation with our clinical team.
        </p>
    </div>
</section>

<section class="ok-page-band">
    <div class="mx-auto grid max-w-site gap-6 px-4 sm:px-6 lg:grid-cols-12 lg:gap-8">
        <aside class="ok-sidebar-panel lg:col-span-4">
            <h2 class="ok-section-title text-xl">Before You Begin</h2>
            <ul class="ok-list mt-4">
                <li class="ok-list-item"><span class="ok-list-dot" aria-hidden="true"></span>Use a quiet, private space with a stable internet connection.</li>
                <li class="ok-list-item"><span class="ok-list-dot" aria-hidden="true"></span>Keep your medication list and recent results nearby.</li>
                <li class="ok-list-item"><span class="ok-list-dot" aria-hidden="true"></span>Emergency symptoms should be handled by local emergency services immediately.</li>
            </ul>
            <div class="ok-divider">
                <p class="ok-kicker">New to virtual care?</p>
                <p class="ok-small-copy mt-2">
                    Choose video care for remote clinical review. For voice support, call the hospital main number directly.
                </p>
            </div>
        </aside>

        <div class="ok-panel lg:col-span-8">
            <form asp-action="Create" method="post" class="requires-network ok-widget-body space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="ok-alert"></div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="PatientName" class="ok-form-label">Full Name</label>
                        <input asp-for="PatientName" class="ok-field" />
                        <span asp-validation-for="PatientName" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="Email" class="ok-form-label">Email</label>
                        <input asp-for="Email" class="ok-field" />
                        <span asp-validation-for="Email" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="Phone" class="ok-form-label">Phone</label>
                        <div class="grid grid-cols-[7.5rem_1fr] gap-2">
                            <select asp-for="PhoneCountryCode" autocomplete="tel-country-code" class="ok-field">
                                <option value="+234">+234 NG</option>
                                <option value="+233">+233 GH</option>
                                <option value="+44">+44 UK</option>
                                <option value="+1">+1 US/CA</option>
                            </select>
                            <input asp-for="Phone" type="tel" inputmode="tel" autocomplete="tel-national" placeholder="08012345678 or 8012345678" class="ok-field" />
                        </div>
                        <span asp-validation-for="PhoneCountryCode" class="mt-1 block text-xs text-red-600"></span>
                        <span asp-validation-for="Phone" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="ConsultationType" class="ok-form-label">Consultation Type</label>
                        <select asp-for="ConsultationType" class="ok-field">
                            <option value="@((int)Okafor_.NET.Models.TeleconsultationType.Video)">Video consultation</option>
                            <option value="@((int)Okafor_.NET.Models.TeleconsultationType.FollowUp)">Follow-up consultation</option>
                        </select>
                        <span asp-validation-for="ConsultationType" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="DepartmentId" class="ok-form-label">Department / Specialty</label>
                        <select asp-for="DepartmentId" asp-items="ViewBag.DepartmentId" class="ok-field">
                            <option value="">Select a department</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="DoctorId" class="ok-form-label">Preferred Doctor</label>
                        <select asp-for="DoctorId" asp-items="ViewBag.DoctorId" class="ok-field">
                            <option value="">No preference</option>
                        </select>
                        <span asp-validation-for="DoctorId" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="PreferredDate" class="ok-form-label">Preferred Date</label>
                        <input asp-for="PreferredDate" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="ok-field" />
                        <span asp-validation-for="PreferredDate" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="PreferredTime" class="ok-form-label">Preferred Time</label>
                        <select asp-for="PreferredTime" class="ok-field">
                            <option value="">Select a time</option>
                            <option>08:00 AM</option>
                            <option>09:00 AM</option>
                            <option>10:00 AM</option>
                            <option>11:00 AM</option>
                            <option>01:00 PM</option>
                            <option>02:00 PM</option>
                            <option>03:00 PM</option>
                        </select>
                        <span asp-validation-for="PreferredTime" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Reason" class="ok-form-label">Reason for Consultation</label>
                    <textarea asp-for="Reason" rows="5" class="ok-field"></textarea>
                    <span asp-validation-for="Reason" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="flex items-start gap-3">
                    <input asp-for="ConsentAccepted" class="mt-1 h-4 w-4 accent-primary-800" />
                    <label asp-for="ConsentAccepted" class="ok-small-copy">I consent to virtual care communication and understand emergency care should not be delayed.</label>
                </div>
                <span asp-validation-for="ConsentAccepted" class="block text-xs text-red-600"></span>

                <div class="ok-note ok-note-accent">
                    <div class="flex items-start gap-3">
                        <input asp-for="WhatsAppOptIn" class="mt-1 h-4 w-4 accent-primary-800" />
                        <label asp-for="WhatsAppOptIn" class="text-sm leading-6">
                            Send updates to this phone number on WhatsApp.
                        </label>
                    </div>
                    <p class="mt-2 text-xs leading-5">
                        We will use WhatsApp for teleconsultation status updates, meeting links, and safer next steps when configured by the hospital.
                    </p>
                </div>

                <button type="submit" class="ok-btn ok-btn-primary w-full sm:w-auto">
                    Submit Teleconsultation Request
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        (function () {
            var departmentSelect = document.getElementById('DepartmentId');
            var doctorSelect = document.getElementById('DoctorId');
            if (!departmentSelect || !doctorSelect) return;

            var selectedDoctorId = '@(Model.DoctorId?.ToString() ?? string.Empty)';
            var doctorOptions = @Html.Raw(JsonSerializer.Serialize(ViewBag.DoctorOptions ?? new object[0]));

            function renderDoctors() {
                var deptId = departmentSelect.value;
                var doctors = doctorOptions.filter(function (doctor) {
                    return deptId && String(doctor.DepartmentId) === String(deptId);
                });

                doctorSelect.innerHTML = '';
                var defaultOption = document.createElement('option');
                defaultOption.value = '';
                defaultOption.textContent = 'No preference';
                doctorSelect.appendChild(defaultOption);

                doctors.forEach(function (doctor) {
                    var option = document.createElement('option');
                    option.value = doctor.Id;
                    option.textContent = doctor.Name;
                    if (String(doctor.Id) === selectedDoctorId) {
                        option.selected = true;
                    }
                    doctorSelect.appendChild(option);
                });
            }

            departmentSelect.addEventListener('change', function () {
                selectedDoctorId = '';
                renderDoctors();
            });

            renderDoctors();
        })();
    </script>
}
