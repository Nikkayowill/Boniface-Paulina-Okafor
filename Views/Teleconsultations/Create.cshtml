@model Okafor_.NET.ViewModels.TeleconsultationRequestViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Book a Teleconsultation";
}

<section class="border-b border-secondary-300 bg-secondary-100 py-10 md:py-14">
    <div class="mx-auto max-w-site px-4 sm:px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Virtual Care</p>
        <h1 class="mt-3 font-serif text-3xl font-bold text-[#1c1c1c] md:text-4xl">Book a Teleconsultation</h1>
        <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[#4a4a4a]">
            Request a phone, video, or follow-up consultation with our clinical team.
        </p>
    </div>
</section>

<section class="bg-secondary-100 py-10 md:py-16">
    <div class="mx-auto grid max-w-site gap-6 px-4 sm:px-6 lg:grid-cols-12 lg:gap-8">
        <aside class="premium-card border border-secondary-300 bg-white p-5 md:p-6 lg:col-span-4">
            <h2 class="font-serif text-xl font-bold text-[#1c1c1c]">Before You Begin</h2>
            <ul class="mt-4 space-y-3 text-sm leading-6 text-[#4a4a4a]">
                <li>Use a quiet, private space with a stable phone or internet connection.</li>
                <li>Keep your medication list and recent results nearby.</li>
                <li>Emergency symptoms should be handled by local emergency services immediately.</li>
            </ul>
            <div class="mt-6 border-t border-secondary-300 pt-5">
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-primary-800">New to virtual care?</p>
                <p class="mt-2 text-sm leading-6 text-[#4a4a4a]">
                    Choose video if you can use a stable internet connection. Choose phone if you prefer a direct call from the care team.
                </p>
            </div>
        </aside>

        <div class="premium-card border border-secondary-300 bg-white p-5 md:p-8 lg:col-span-8">
            <form asp-action="Create" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="PatientName" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Full Name</label>
                        <input asp-for="PatientName" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        <span asp-validation-for="PatientName" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="Email" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Email</label>
                        <input asp-for="Email" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        <span asp-validation-for="Email" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="Phone" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Phone</label>
                        <div class="grid grid-cols-[7.5rem_1fr] gap-2">
                            <select asp-for="PhoneCountryCode" autocomplete="tel-country-code" class="form-field w-full border border-secondary-300 bg-white px-3 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800">
                                <option value="+234">+234 NG</option>
                                <option value="+233">+233 GH</option>
                                <option value="+44">+44 UK</option>
                                <option value="+1">+1 US/CA</option>
                            </select>
                            <input asp-for="Phone" type="tel" inputmode="tel" autocomplete="tel-national" placeholder="08012345678 or 8012345678" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        </div>
                        <span asp-validation-for="PhoneCountryCode" class="mt-1 block text-xs text-red-600"></span>
                        <span asp-validation-for="Phone" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="ConsultationType" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Consultation Type</label>
                        <select asp-for="ConsultationType" asp-items="Html.GetEnumSelectList<Okafor_.NET.Models.TeleconsultationType>()" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800"></select>
                        <span asp-validation-for="ConsultationType" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="DepartmentId" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Department / Specialty</label>
                        <select asp-for="DepartmentId" asp-items="ViewBag.DepartmentId" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800">
                            <option value="">Select a department</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="DoctorId" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Preferred Doctor</label>
                        <select asp-for="DoctorId" asp-items="ViewBag.DoctorId" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800">
                            <option value="">No preference</option>
                        </select>
                        <span asp-validation-for="DoctorId" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="PreferredDate" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Preferred Date</label>
                        <input asp-for="PreferredDate" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        <span asp-validation-for="PreferredDate" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="PreferredTime" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Preferred Time</label>
                        <select asp-for="PreferredTime" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800">
                            <option value="">Select a time</option>
                            <option>08:00 AM</option>
                            <option>09:00 AM</option>
                            <option>10:00 AM</option>
                            <option>11:00 AM</option>
                            <option>01:00 PM</option>
                            <option>02:00 PM</option>
                            <option>03:00 PM</option>
                        </select>
                        <span asp-validation-for="PreferredTime" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Reason" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Reason for Consultation</label>
                    <textarea asp-for="Reason" rows="5" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800"></textarea>
                    <span asp-validation-for="Reason" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="flex items-start gap-3">
                    <input asp-for="ConsentAccepted" class="mt-1 h-4 w-4 accent-primary-800" />
                    <label asp-for="ConsentAccepted" class="text-sm leading-6 text-[#4a4a4a]">I consent to virtual care communication and understand emergency care should not be delayed.</label>
                </div>
                <span asp-validation-for="ConsentAccepted" class="block text-xs text-red-600"></span>

                <div class="border border-primary-200 bg-primary-50 p-4">
                    <div class="flex items-start gap-3">
                        <input asp-for="WhatsAppOptIn" class="mt-1 h-4 w-4 accent-primary-800" />
                        <label asp-for="WhatsAppOptIn" class="text-sm leading-6 text-[#3c3c3c]">
                            Send updates to this phone number on WhatsApp.
                        </label>
                    </div>
                    <p class="mt-2 text-xs leading-5 text-[#4a4a4a]">
                        We will use WhatsApp for teleconsultation status updates, meeting links, and safer next steps when configured by the hospital.
                    </p>
                </div>

                <button type="submit" class="glow-button w-full bg-primary-800 px-6 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-all hover:bg-primary-700 sm:w-auto">
                    Submit Teleconsultation Request
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
