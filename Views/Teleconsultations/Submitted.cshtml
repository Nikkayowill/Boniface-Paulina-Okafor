@model Okafor_.NET.Models.TeleconsultationRequest
@using Okafor_.NET.Services
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Teleconsultation Submitted";
    ViewData["Robots"] = "noindex,nofollow";
    var hospitalWhatsApp = NigerianPhoneNumber.NormalizeForWhatsApp(
        Configuration["Notifications:WhatsAppNumber"] ?? Configuration["Notifications:AdminPhone"] ?? string.Empty);
    var whatsAppText = Uri.EscapeDataString(
        $"Hello BP Okafor Memorial Hospital, I submitted teleconsultation request TC-{Model.Id:D6}. My name is {Model.PatientName}.");
    var isFatherToochukwu = string.Equals(Model.Doctor?.Slug, "rev-fr-dr-toochukwu-bartholomew-okafor", StringComparison.OrdinalIgnoreCase);
}

<section class="ok-page-band">
    <div class="mx-auto max-w-2xl px-6">
        <div class="ok-panel p-6 sm:p-10">
            <div class="ok-success-icon mb-6">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>

            <p class="ok-kicker">Request Received</p>
            <h1 class="ok-page-title mt-2">Your teleconsultation request has been submitted.</h1>
            <p class="ok-copy mt-3">Your request is pending clinical review. Our team will contact you with confirmation details, a meeting link, or a safer alternative if virtual care is not appropriate.</p>

            <div class="ok-summary-card mt-8 space-y-2 text-sm">
                <p><span class="text-slate-500">Reference:</span> <strong class="text-slate-950">TC-@Model.Id.ToString("D6")</strong></p>
                <p><span class="text-slate-500">Department:</span> <span class="text-slate-950">@(Model.Department?.Name ?? "N/A")</span></p>
                <p><span class="text-slate-500">Preferred time:</span> <span class="text-slate-950">@Model.PreferredDate.ToString("MMMM d, yyyy") at @Model.PreferredTime</span></p>
                <p><span class="text-slate-500">Status:</span> <span class="text-slate-950">@Model.Status</span></p>
            </div>

            <div class="ok-note ok-note-accent mt-6">
                <p class="ok-kicker mb-3">What Happens Next</p>
                <ol class="space-y-2 text-sm leading-6">
                    <li><strong>1.</strong> A staff member reviews the reason for consultation and requested time.</li>
                    <li><strong>2.</strong> If approved, your portal updates instantly and the meeting link appears after staff adds it.</li>
                    <li><strong>3.</strong> If symptoms need urgent care, please call <strong>112 / 199</strong> or visit emergency care immediately.</li>
                </ol>
            </div>

            @if (isFatherToochukwu)
            {
                <div class="ok-note mt-6">
                    <p class="font-semibold text-slate-950">Optional program support</p>
                    <p class="mt-1 text-sm leading-6">If you wish, you may support Father Toochukwu's Spiritual Care &amp; Psychotherapy Program through the hospital. A donation is separate from your session fee and will not affect review or booking priority.</p>
                    <a asp-controller="Donation" asp-action="Index" asp-route-purpose="@Okafor_.NET.Models.DonationPurposeCodes.FatherToochukwuSpiritualCare" class="mt-3 inline-flex font-semibold text-primary-800 underline decoration-primary-300 underline-offset-4">Support the program</a>
                </div>
            }

            <div class="mt-8 flex flex-wrap gap-3">
                <a asp-controller="Home" asp-action="Index" class="ok-btn ok-btn-primary">Back to Home</a>
                <a asp-controller="Teleconsultations" asp-action="Create" class="ok-btn ok-btn-secondary">Request Another</a>
                @if (!string.IsNullOrWhiteSpace(hospitalWhatsApp))
                {
                    <a href="https://wa.me/@hospitalWhatsApp?text=@whatsAppText" target="_blank" rel="noopener" class="ok-btn ok-whatsapp-btn">Message on WhatsApp</a>
                }
            </div>
        </div>
    </div>
</section>
