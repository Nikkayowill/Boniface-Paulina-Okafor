@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var today = DateTime.Today.ToString("yyyy-MM-dd");
    var maxDate = DateTime.Today.AddDays(60).ToString("yyyy-MM-dd");
    var doctorsJson = System.Text.Json.JsonSerializer.Serialize(
        ViewBag.BookingDoctors ?? Array.Empty<object>());
    var departmentOptions = ViewData["DepartmentId"] as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var doctorOptions = ViewData["DoctorId"] as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<script>
window.__bookingDoctors = @Html.Raw(doctorsJson);
</script>

<div class="mx-auto max-w-3xl"
     data-requires-network
     data-booking-widget>
    @Html.AntiForgeryToken()

    <div class="ok-widget-header">
        <p class="ok-kicker">Appointment Request</p>
        <h2 class="ok-section-title mt-2 sm:text-3xl">Find a Time That Works</h2>
    </div>

    <div class="ok-stepper" aria-label="Booking progress">
        @for (int i = 1; i <= 3; i++)
        {
            <div class="ok-step-item">
                <div class="ok-step-circle @(i == 1 ? "bg-primary-800 text-white" : "border border-slate-300 bg-white text-slate-400")"
                     data-step-circle="@i">
                    <span data-step-number="@i">@i</span>
                    <svg data-step-check="@i" hidden class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <span class="ok-step-label @(i == 1 ? "text-primary-800" : "text-slate-400")" data-step-label="@i">
                    @(i == 1 ? "Doctor" : i == 2 ? "Date & Time" : "Details")
                </span>
            </div>
            if (i < 3)
            {
                <div class="ok-step-line @(i < 1 ? "bg-primary-800" : "bg-slate-200")" data-step-line="@i"></div>
            }
        }
    </div>

    <div class="ok-widget-body">
        <div class="ok-alert" data-booking-error role="alert" aria-live="assertive" tabindex="-1" hidden></div>

        <section data-booking-step="1">
            <p class="ok-kicker">Step 1 of 3</p>
            <h3 class="ok-section-title mt-2">Choose a Department and Doctor</h3>
            <p class="ok-small-copy mt-2">Start with the type of care you need, then choose an available doctor.</p>

            <div class="mt-8 space-y-5">
                <div>
                    <label class="ok-form-label" for="bookingDepartment">Department</label>
                    <select id="bookingDepartment"
                            class="ok-field"
                            autocomplete="off"
                            asp-items="departmentOptions"
                            data-booking-department>
                        <option value="">Select a department...</option>
                    </select>
                </div>

                <div>
                    <label class="ok-form-label" for="bookingDoctor">Doctor</label>
                    <select id="bookingDoctor"
                            class="ok-field"
                            autocomplete="off"
                            asp-items="doctorOptions"
                            data-booking-doctor
                            disabled>
                        <option value="">Choose a department first...</option>
                    </select>
                    <div class="ok-doctor-summary" data-doctor-summary hidden>
                        <p class="text-sm font-semibold leading-5 text-slate-950" data-doctor-specialty></p>
                        <p class="mt-1 text-[13px] leading-5 text-slate-600" data-doctor-department></p>
                    </div>
                </div>

                <button type="button" class="ok-btn ok-btn-primary mt-6 w-full sm:w-auto" data-next-step disabled>
                    Next: Choose Time
                </button>
            </div>
        </section>

        <section data-booking-step="2" hidden>
            <p class="ok-kicker">Step 2 of 3</p>
            <h3 class="ok-section-title mt-2">Pick a Date & Time</h3>
            <p class="ok-small-copy mt-2">Choose a convenient date and time slot for your appointment.</p>

            <div class="mt-8 space-y-5">
                <div>
                    <label class="ok-form-label" for="bookingDate">Date</label>
                    <input id="bookingDate"
                           type="date"
                           min="@today"
                           max="@maxDate"
                           class="ok-field"
                           data-booking-date>
                </div>

                <div>
                    <label class="ok-form-label">Time Slot</label>
                    <p class="ok-note" data-slots-empty-date>
                        Select a date to view available times.
                    </p>
                    <div class="ok-note ok-note-accent flex items-center gap-2" data-slots-loading hidden aria-live="polite">
                        <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                        </svg>
                        Checking availability...
                    </div>
                    <div class="ok-slot-grid" data-slots-grid hidden></div>
                    <p class="ok-note" data-slots-none hidden>
                        No times are open for this date. Please choose another.
                    </p>
                </div>
            </div>

            <div class="mt-8 flex gap-3">
                <button type="button" class="ok-btn ok-btn-secondary flex-1" data-back-step="1">
                    Back
                </button>
            </div>
        </section>

        <section data-booking-step="3" hidden>
            <p class="ok-kicker">Step 3 of 3</p>
            <h3 class="ok-section-title mt-2">Confirm Your Details</h3>
            <p class="ok-small-copy mt-2">Enter your information so we can send you a confirmation.</p>

            <div class="mt-8 space-y-4">
                <div>
                    <label class="ok-form-label" for="bookingName">Full Name</label>
                    <input id="bookingName" type="text" maxlength="150" autocomplete="name" placeholder="Your full name" class="ok-field" data-form-name required>
                </div>
                <div>
                    <label class="ok-form-label" for="bookingPhone">Phone</label>
                    <input id="bookingPhone" type="tel" maxlength="30" inputmode="tel" autocomplete="tel" placeholder="Your phone number" class="ok-field" data-form-phone required>
                </div>
                <div>
                    <label class="ok-form-label" for="bookingEmail">Email</label>
                    <input id="bookingEmail" type="email" maxlength="150" inputmode="email" autocomplete="email" placeholder="your@email.com" class="ok-field" data-form-email required>
                </div>
                <div>
                    <label class="ok-form-label" for="bookingReason">Reason for Visit</label>
                    <textarea id="bookingReason" maxlength="250" autocomplete="off" placeholder="Brief description of your concern (optional)" class="ok-field resize-none" rows="3" data-form-reason></textarea>
                </div>
                <label class="flex items-start gap-2 pt-2">
                    <input type="checkbox" class="mt-1 h-4 w-4 accent-primary-800" data-form-confirmed>
                    <span class="text-[13px] leading-6 text-slate-600">I confirm my details are accurate and I understand I will receive appointment updates via email and WhatsApp.</span>
                </label>
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                <button type="button" class="ok-btn ok-btn-secondary flex-1" data-back-step="2">
                    Back
                </button>
                <button type="button" class="ok-btn ok-btn-primary flex-1" data-submit-booking disabled>
                    <span data-submit-label>Confirm Booking</span>
                    <svg data-submit-spinner hidden class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                    </svg>
                </button>
            </div>
        </section>

        <section data-booking-step="4" hidden>
            <div class="flex flex-col items-center py-4 text-center">
                <div class="ok-success-icon">
                    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <h2 class="ok-section-title mt-6">Booking Confirmed</h2>
                <p class="ok-small-copy mt-2">A confirmation email has been sent to <span class="font-semibold text-slate-950" data-result-email></span></p>

                <div class="ok-summary-card mt-6">
                    <p class="ok-kicker">Reference Number</p>
                    <p class="mt-1 break-all font-mono text-xl font-bold tracking-[0.16em] text-slate-950 sm:text-2xl sm:tracking-[0.2em]" data-result-reference></p>
                    <div class="mt-4 grid grid-cols-1 gap-3 text-[13px] sm:grid-cols-2">
                        <div><span class="text-slate-500">Doctor</span><br><span class="font-semibold text-slate-950" data-result-doctor></span></div>
                        <div><span class="text-slate-500">Department</span><br><span class="font-semibold text-slate-950" data-result-department></span></div>
                        <div><span class="text-slate-500">Date</span><br><span class="font-semibold text-slate-950" data-result-date></span></div>
                        <div><span class="text-slate-500">Time</span><br><span class="font-semibold text-slate-950" data-result-time></span></div>
                    </div>
                </div>

                <a href="#" target="_blank" rel="noopener noreferrer" class="ok-btn ok-whatsapp-btn mt-6" data-result-whatsapp>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
                    Tap to confirm via WhatsApp
                </a>

                <button type="button" class="mt-4 inline-flex min-h-10 items-center justify-center px-2 text-center text-[12px] font-semibold uppercase leading-none tracking-[0.1em] text-primary-700 transition-colors hover:text-primary-900" data-reset-booking>
                    Book Another Appointment
                </button>
            </div>
        </section>
    </div>
</div>
