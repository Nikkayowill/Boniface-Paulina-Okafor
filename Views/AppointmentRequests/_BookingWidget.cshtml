@using Okafor_.NET.Models
@model IEnumerable<Department>

@{
    var today = DateTime.Today.ToString("yyyy-MM-dd");
    var maxDate = DateTime.Today.AddDays(60).ToString("yyyy-MM-dd");
    var deptJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Select(d => new { id = d.Id, name = d.Name }));
}

<script>
window.__bookingDepartments = @Html.Raw(deptJson);
</script>

<div class="mx-auto max-w-2xl"
     x-data="bookingWidget()">
    @Html.AntiForgeryToken()

    @* ── Progress indicator ── *@
    <div class="mb-8 flex items-center">
        @for (int i = 1; i <= 3; i++)
        {
            <div class="flex items-center" :class="''" >
                <div class="flex h-8 w-8 items-center justify-center rounded-full text-[12px] font-bold transition-all duration-300"
                     :class="step > @i ? 'bg-primary-800 text-white' : step === @i ? 'bg-primary-800 text-white' : 'border-2 border-secondary-300 text-secondary-400'">
                    <template x-if="step > @i">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    </template>
                    <template x-if="step <= @i">
                        <span>@i</span>
                    </template>
                </div>
                <span class="ml-2 text-[11px] font-semibold uppercase tracking-[0.1em] hidden sm:inline"
                      :class="step >= @i ? 'text-primary-800' : 'text-secondary-400'">
                    @(i == 1 ? "Doctor" : i == 2 ? "Date & Time" : "Your Details")
                </span>
            </div>
            if (i < 3)
            {
                <div class="mx-3 h-px flex-1 transition-all duration-300"
                     :class="step > @i ? 'bg-primary-800' : 'bg-secondary-300'"></div>
            }
        }
    </div>

    <div class="border border-secondary-300 bg-white p-8">

        @* ── Error banner ── *@
        <div x-show="error" x-transition
             class="mb-6 border border-red-300 bg-red-50 px-4 py-3 text-[13px] text-red-800"
             x-text="error"></div>

        @* ══════════════════════════════════════════
           STEP 1 — Department & Doctor
        ══════════════════════════════════════════ *@
        <div x-show="step === 1" x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">

            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Step 1 of 3</p>
            <h2 class="mt-2 font-serif text-2xl font-bold text-[#1c1c1c]">Choose Department & Doctor</h2>
            <p class="mt-2 text-[13px] text-[#6a6a6a]">Select the clinical department and the doctor you'd like to see.</p>

            <div class="mt-8 space-y-5">
                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Department</label>
                    <select x-model="selectedDeptId" @@change="loadDoctors()"
                            class="w-full border border-secondary-300 bg-secondary-100 px-4 py-3 text-[14px] text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-700">
                        <option value="">Select a department…</option>
                        <template x-for="dept in departments" :key="dept.id">
                            <option :value="dept.id" x-text="dept.name"></option>
                        </template>
                    </select>
                </div>

                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Doctor</label>
                    <div x-show="doctorsLoading" class="flex items-center gap-2 py-3 text-[13px] text-secondary-400">
                        <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
                        Loading doctors…
                    </div>
                    <select x-show="!doctorsLoading" x-model="selectedDoctorId"
                            :disabled="!selectedDeptId"
                            class="w-full border border-secondary-300 bg-secondary-100 px-4 py-3 text-[14px] text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-700 disabled:opacity-50 disabled:cursor-not-allowed">
                        <option value="">Select a doctor…</option>
                        <template x-for="doctor in doctors" :key="doctor.id">
                            <option :value="doctor.id" x-text="doctor.fullName"></option>
                        </template>
                    </select>
                </div>

                <button @@click="step = 2" :disabled="!selectedDoctorId" class="mt-6 inline-flex min-w-[160px] items-center justify-center gap-2 bg-primary-800 px-6 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-colors hover:bg-primary-700 disabled:opacity-40 disabled:cursor-not-allowed">
                    Next: Choose Time
                </button>
            </div>
        </div>

        @* ══════════════════════════════════════════
           STEP 2 — Date & Time
        ══════════════════════════════════════════ *@
        <div x-show="step === 2" x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">

            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Step 2 of 3</p>
            <h2 class="mt-2 font-serif text-2xl font-bold text-[#1c1c1c]">Pick a Date & Time</h2>
            <p class="mt-2 text-[13px] text-[#6a6a6a]">Choose a convenient date and time slot for your appointment.</p>

            <div class="mt-8 space-y-5">
                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Date</label>
                    <input type="date" x-model="selectedDate" @@change="loadSlots()"
                           :min="@(DateTime.Today.ToString("yyyy-MM-dd"))"
                           :max="@(DateTime.Today.AddDays(60).ToString("yyyy-MM-dd"))"
                           class="w-full border border-secondary-300 bg-secondary-100 px-4 py-3 text-[14px] text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-700">
                </div>

                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Time Slot</label>
                    <div x-show="slotsLoading" class="flex items-center gap-2 py-3 text-[13px] text-secondary-400">
                        <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
                        Loading available times…
                    </div>
                    <div x-show="!slotsLoading && selectedDate" class="grid grid-cols-3 gap-2">
                        <template x-for="slot in slots" :key="slot">
                            <button @@click="selectedSlot = slot; step = 3"
                                    :class="selectedSlot === slot ? 'bg-primary-800 text-white' : 'bg-secondary-100 text-[#1c1c1c] hover:bg-secondary-200'"
                                    class="rounded border border-secondary-300 px-3 py-2 text-[13px] font-semibold transition-colors">
                                <span x-text="slot"></span>
                            </button>
                        </template>
                    </div>
                    <p x-show="!slotsLoading && selectedDate && slots.length === 0" class="mt-2 text-[13px] text-red-600">
                        No available times for this date. Please choose another.
                    </p>
                </div>
            </div>

            <div class="mt-8 flex gap-3">
                <button @@click="step = 1" class="flex-1 border border-secondary-300 bg-secondary-100 px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-[#1c1c1c] transition-colors hover:bg-secondary-200">
                    Back
                </button>
            </div>
        </div>

        @* ══════════════════════════════════════════
           STEP 3 — Your Details
        ══════════════════════════════════════════ *@
        <div x-show="step === 3" x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">

            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Step 3 of 3</p>
            <h2 class="mt-2 font-serif text-2xl font-bold text-[#1c1c1c]">Confirm Your Details</h2>
            <p class="mt-2 text-[13px] text-[#6a6a6a]">Enter your information so we can send you a confirmation.</p>

            <div class="mt-8 space-y-4">
                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Full Name</label>
                    <input type="text" x-model="form.name" placeholder="Your full name"
                           class="w-full border border-secondary-300 bg-secondary-100 px-4 py-3 text-[14px] text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-700">
                </div>
                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Phone</label>
                    <input type="tel" x-model="form.phone" placeholder="Your phone number"
                           class="w-full border border-secondary-300 bg-secondary-100 px-4 py-3 text-[14px] text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-700">
                </div>
                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Email</label>
                    <input type="email" x-model="form.email" placeholder="your@email.com"
                           class="w-full border border-secondary-300 bg-secondary-100 px-4 py-3 text-[14px] text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-700">
                </div>
                <div>
                    <label class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.1em] text-[#3c3c3c]">Reason for Visit</label>
                    <textarea x-model="form.reason" placeholder="Brief description of your concern"
                              class="w-full border border-secondary-300 bg-secondary-100 px-4 py-3 text-[14px] text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-700 resize-none" rows="3"></textarea>
                </div>
                <label class="flex items-start gap-2 pt-2">
                    <input type="checkbox" x-model="confirmed" class="mt-1 h-4 w-4 accent-primary-800">
                    <span class="text-[13px] text-[#4a4a4a]">I confirm my details are accurate and I understand I will receive appointment updates via email and WhatsApp.</span>
                </label>
            </div>

            <div class="mt-8 flex gap-3">
                <button @@click="step = 2" class="flex-1 border border-secondary-300 bg-secondary-100 px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-[#1c1c1c] transition-colors hover:bg-secondary-200">
                    Back
                </button>
                <button @@click="submitBooking()"
                        :disabled="submitting || !confirmed || !form.name || !form.phone || !form.email"
                        class="flex-1 inline-flex items-center justify-center gap-2 bg-primary-800 px-6 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-colors hover:bg-primary-700 disabled:opacity-40 disabled:cursor-not-allowed">
                    <template x-if="submitting">
                        <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
                    </template>
                    <template x-if="!submitting">
                        <span>Confirm Booking</span>
                    </template>
                </button>
            </div>
        </div>

        @* ══════════════════════════════════════════
           STEP 4 — Success
        ══════════════════════════════════════════ *@
        <div x-show="step === 4" x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100">

            <div class="flex flex-col items-center py-4 text-center">
                <div class="flex h-16 w-16 items-center justify-center bg-primary-800 text-white">
                    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h2 class="mt-6 font-serif text-2xl font-bold text-[#1c1c1c]">Booking Confirmed</h2>
                <p class="mt-2 text-[14px] text-[#6a6a6a]">A confirmation email has been sent to <span x-text="form.email" class="font-semibold text-[#1c1c1c]"></span></p>

                <div class="mt-6 w-full border border-secondary-300 bg-secondary-100 p-5 text-left">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-primary-800">Reference Number</p>
                    <p class="mt-1 font-mono text-2xl font-bold tracking-[0.2em] text-[#1c1c1c]" x-text="result?.confirmationRef"></p>
                    <div class="mt-4 grid grid-cols-2 gap-3 text-[13px]">
                        <div><span class="text-[#8a8a8a]">Doctor</span><br/><span class="font-semibold text-[#1c1c1c]" x-text="result?.doctorName"></span></div>
                        <div><span class="text-[#8a8a8a]">Department</span><br/><span class="font-semibold text-[#1c1c1c]" x-text="result?.department"></span></div>
                        <div><span class="text-[#8a8a8a]">Date</span><br/><span class="font-semibold text-[#1c1c1c]" x-text="result?.appointmentDate"></span></div>
                        <div><span class="text-[#8a8a8a]">Time</span><br/><span class="font-semibold text-[#1c1c1c]" x-text="result?.appointmentTime"></span></div>
                    </div>
                </div>

                <a :href="result?.whatsAppUrl" target="_blank" rel="noopener noreferrer"
                   class="mt-6 inline-flex w-full items-center justify-center gap-2.5 bg-[#25D366] px-6 py-3.5 text-[12px] font-semibold uppercase tracking-[0.12em] text-white transition-opacity hover:opacity-90">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Tap to confirm via WhatsApp
                </a>

                <button @@click="resetWidget()"
                        class="mt-4 text-[12px] font-semibold uppercase tracking-[0.1em] text-primary-700 hover:text-primary-900 transition-colors">
                    Book Another Appointment
                </button>
            </div>
        </div>

    </div>
</div>

<script>
function bookingWidget() {
    return {
        step: 1,
        departments: window.__bookingDepartments || [],
        doctors: [],
        doctorsLoading: false,
        selectedDeptId: '',
        selectedDoctorId: '',
        selectedDate: '',
        slots: [],
        slotsLoading: false,
        selectedSlot: null,
        form: { name: '', phone: '', email: '', reason: '' },
        confirmed: false,
        submitting: false,
        result: null,
        error: null,
        subscribedDoctorDay: null,

        async loadDoctors() {
            if (!this.selectedDeptId) { this.doctors = []; return; }
            this.doctorsLoading = true;
            this.selectedDoctorId = '';
            this.selectedDate = '';
            this.slots = [];
            this.selectedSlot = null;
            try {
                const res = await fetch(`/Doctors/GetByDepartment?deptId=${this.selectedDeptId}`);
                this.doctors = await res.json();
            } catch { this.doctors = []; }
            finally { this.doctorsLoading = false; }
        },

        async loadSlots() {
            if (!this.selectedDate || !this.selectedDoctorId) return;
            this.slotsLoading = true;
            this.selectedSlot = null;
            this.slots = [];
            try {
                const res = await fetch(`/AppointmentRequests/GetAvailableSlots?doctorId=${this.selectedDoctorId}&date=${this.selectedDate}`);
                const data = await res.json();
                this.slots = data.slots || [];
                await this.subscribeToSlotUpdates();
            } catch { this.slots = []; }
            finally { this.slotsLoading = false; }
        },

        async subscribeToSlotUpdates() {
            const connection = await window.okaforBookingRealtime?.start?.();
            if (!connection || !this.selectedDoctorId || !this.selectedDate) return;

            const nextKey = `${this.selectedDoctorId}:${this.selectedDate}`;
            if (this.subscribedDoctorDay === nextKey) return;

            if (this.subscribedDoctorDay) {
                const parts = this.subscribedDoctorDay.split(':');
                await connection.invoke('UnsubscribeDoctorDay', parseInt(parts[0]), parts[1]).catch(() => {});
            }

            this.subscribedDoctorDay = nextKey;
            await connection.invoke('SubscribeDoctorDay', parseInt(this.selectedDoctorId), this.selectedDate).catch(() => {});

            if (!connection._okaforSlotHandlerAttached) {
                connection.on('slotBooked', (payload) => {
                    if (!payload || String(payload.doctorId) !== String(this.selectedDoctorId) || payload.date !== this.selectedDate) return;
                    this.slots = this.slots.filter(slot => slot !== payload.slot);
                    if (this.selectedSlot === payload.slot) {
                        this.selectedSlot = null;
                        this.error = payload.message || 'That time was just booked. Please choose another available slot.';
                    }
                });
                connection._okaforSlotHandlerAttached = true;
            }
        },

        async submitBooking() {
            this.error = null;
            this.submitting = true;
            try {
                const res = await fetch('/AppointmentRequests/BookSlot', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({
                        doctorId: parseInt(this.selectedDoctorId),
                        slotDate: this.selectedDate,
                        slotTime: this.selectedSlot,
                        patientName: this.form.name,
                        patientPhone: this.form.phone,
                        patientEmail: this.form.email,
                        reasonForVisit: this.form.reason
                    })
                });
                const data = await res.json();
                if (data.success) {
                    // Unsubscribe from doctor+date group so we don't see the slot-booked broadcast
                    if (window.okaforBookingRealtime?.connection) {
                        await window.okaforBookingRealtime.connection.invoke('UnsubscribeDoctorDay', parseInt(this.selectedDoctorId), this.selectedDate).catch(() => {});
                    }
                    this.result = data;
                    this.step = 4;
                } else {
                    this.error = data.message || 'An error occurred. Please try again.';
                }
            } catch {
                this.error = 'Connection error. Please check your internet and try again.';
            } finally {
                this.submitting = false;
            }
        },

        resetWidget() {
            this.step = 1;
            this.selectedDeptId = '';
            this.selectedDoctorId = '';
            this.doctors = [];
            this.selectedDate = '';
            this.slots = [];
            this.selectedSlot = null;
            this.form = { name: '', phone: '', email: '', reason: '' };
            this.confirmed = false;
            this.result = null;
            this.error = null;
        }
    };
}
</script>
