@{
    ViewData["Title"] = "Request Submitted";

    var name     = TempData["Appt_Name"]     as string;
    var email    = TempData["Appt_Email"]    as string;
    var date     = TempData["Appt_Date"]     as string;
    var time     = TempData["Appt_Time"]     as string;
    var dept     = TempData["Appt_Dept"]     as string;
    var refNum   = TempData["Appt_Id"]       as string;
}

<section class="bg-secondary-100 py-20 min-h-[60vh] flex items-center">
    <div class="mx-auto w-full max-w-2xl px-6">
        <div class="premium-card reveal border border-secondary-300 bg-secondary-100 p-10">

            <!-- Icon -->
            <div class="mb-6 flex h-14 w-14 items-center justify-center bg-primary-100">
                <svg class="h-7 w-7 animate-scale-in text-primary-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>

            <p class="reveal text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Request Received</p>
            <h1 class="reveal mt-2 font-serif text-3xl font-bold text-[#1c1c1c]">Your appointment request has been received.</h1>
            <p class="reveal mt-3 text-[15px] leading-7 text-[#4a4a4a]">
                Your request is now pending staff review. The hospital team will contact you by phone or email to confirm the final appointment details.
            </p>

            @if (!string.IsNullOrWhiteSpace(name))
            {
                <div class="reveal mt-8 border border-secondary-300 bg-white p-5">
                    <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.18em] text-primary-800">Submission Summary</p>
                    <dl class="space-y-2 text-sm">
                        @if (!string.IsNullOrWhiteSpace(refNum))
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#8c8c8c]">Reference&nbsp;#</dt>
                                <dd class="font-semibold text-[#1c1c1c]">APT-@refNum</dd>
                            </div>
                        }
                        <div class="flex justify-between">
                            <dt class="text-[#8c8c8c]">Name</dt>
                            <dd class="text-[#1c1c1c]">@name</dd>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(email))
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#8c8c8c]">Email</dt>
                                <dd class="text-[#1c1c1c]">@email</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(dept))
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#8c8c8c]">Department</dt>
                                <dd class="text-[#1c1c1c]">@dept</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(date))
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#8c8c8c]">Preferred Date</dt>
                                <dd class="text-[#1c1c1c]">@date</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(time))
                        {
                            <div class="flex justify-between">
                                <dt class="text-[#8c8c8c]">Preferred Time</dt>
                                <dd class="text-[#1c1c1c]">@time</dd>
                            </div>
                        }
                    </dl>
                </div>
            }

            <div class="reveal mt-6 border border-primary-300 bg-primary-50 p-5">
                <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.18em] text-primary-800">What Happens Next</p>
                <ol class="space-y-2 text-sm leading-6 text-[#4a4a4a]">
                    <li><strong>1.</strong> Our staff checks doctor availability and any scheduling conflicts.</li>
                    <li><strong>2.</strong> You receive a call or email to confirm, reschedule, or clarify details.</li>
                    <li><strong>3.</strong> If you have a patient portal account, your status updates there as soon as staff action the request.</li>
                </ol>
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="glow-button bg-primary-800 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary-700">
                    Back to Home
                </a>
                <a asp-area="" asp-controller="Home" asp-action="Contact"
                   class="border border-secondary-400 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-[#3c3c3c] transition-all duration-300 hover:-translate-y-0.5 hover:border-primary-700 hover:text-primary-700 hover:shadow-sm">
                    Contact Support
                </a>
            </div>

        </div>
    </div>
</section>
