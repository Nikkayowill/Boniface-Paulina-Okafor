@{
    ViewData["Title"] = "Request Submitted";

    var name     = TempData["Appt_Name"]     as string;
    var email    = TempData["Appt_Email"]    as string;
    var date     = TempData["Appt_Date"]     as string;
    var time     = TempData["Appt_Time"]     as string;
    var dept     = TempData["Appt_Dept"]     as string;
    var refNum   = TempData["Appt_Id"]       as string;
}

<section class="ok-page-band flex min-h-[60vh] items-center">
    <div class="mx-auto w-full max-w-2xl px-6">
        <div class="ok-panel reveal p-6 sm:p-10">

            <div class="ok-success-icon mb-6">
                <svg class="h-7 w-7 animate-scale-in" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>

            <p class="ok-kicker reveal">Request Received</p>
            <h1 class="ok-page-title reveal mt-2">Your appointment request has been received.</h1>
            <p class="ok-copy reveal mt-3">
                Your request is now pending staff review. The hospital team will contact you by phone or email to confirm the final appointment details.
            </p>

            @if (!string.IsNullOrWhiteSpace(name))
            {
                <div class="ok-summary-card reveal mt-8">
                    <p class="ok-kicker mb-3">Submission Summary</p>
                    <dl class="space-y-2 text-sm">
                        @if (!string.IsNullOrWhiteSpace(refNum))
                        {
                            <div class="flex justify-between">
                                <dt class="text-slate-500">Reference&nbsp;#</dt>
                                <dd class="font-semibold text-slate-950">APT-@refNum</dd>
                            </div>
                        }
                        <div class="flex justify-between">
                            <dt class="text-slate-500">Name</dt>
                            <dd class="text-slate-950">@name</dd>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(email))
                        {
                            <div class="flex justify-between">
                                <dt class="text-slate-500">Email</dt>
                                <dd class="text-slate-950">@email</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(dept))
                        {
                            <div class="flex justify-between">
                                <dt class="text-slate-500">Department</dt>
                                <dd class="text-slate-950">@dept</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(date))
                        {
                            <div class="flex justify-between">
                                <dt class="text-slate-500">Preferred Date</dt>
                                <dd class="text-slate-950">@date</dd>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(time))
                        {
                            <div class="flex justify-between">
                                <dt class="text-slate-500">Preferred Time</dt>
                                <dd class="text-slate-950">@time</dd>
                            </div>
                        }
                    </dl>
                </div>
            }

            <div class="ok-note ok-note-accent reveal mt-6">
                <p class="ok-kicker mb-3">What Happens Next</p>
                <ol class="space-y-2 text-sm leading-6">
                    <li><strong>1.</strong> Our staff checks doctor availability and any scheduling conflicts.</li>
                    <li><strong>2.</strong> You receive a call or email to confirm, reschedule, or clarify details.</li>
                    <li><strong>3.</strong> If you have a patient portal account, your status updates there as soon as staff action the request.</li>
                </ol>
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="ok-btn ok-btn-primary">
                    Back to Home
                </a>
                <a asp-area="" asp-controller="Home" asp-action="Contact"
                   class="ok-btn ok-btn-secondary">
                    Contact Support
                </a>
            </div>

        </div>
    </div>
</section>
