@model Okafor_.NET.ViewModels.BillPaymentViewModel

@{
    ViewData["Title"] = "Pay a Bill";
    var paymentProvider = ViewData["PaymentProvider"] as string ?? "Mock";
    var isSandbox = ViewData["IsSandbox"] as bool? ?? true;
}

<section class="border-b border-secondary-300 bg-secondary-100 py-14">
    <div class="mx-auto max-w-site px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Billing</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-[#1c1c1c]">Pay a Hospital Bill</h1>
        <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[#4a4a4a]">
            Pay hospital invoices online through the hospital's configured payment provider.
        </p>
    </div>
</section>

<section class="bg-secondary-100 py-16">
    <div class="mx-auto max-w-3xl px-6">
        @if (isSandbox)
        {
            <div class="premium-card mb-6 border border-amber-200 bg-amber-50 px-5 py-4 text-sm leading-6 text-amber-800">
                Test mode is active through @paymentProvider. Approved transactions are test records only.
            </div>
        }

        <div class="premium-card border border-secondary-300 bg-white p-5 md:p-8">
            <form asp-action="Index" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

                <div>
                    <label asp-for="InvoiceNumber" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]"></label>
                    <input asp-for="InvoiceNumber" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                    <span asp-validation-for="InvoiceNumber" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="PatientName" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Patient Name</label>
                        <input asp-for="PatientName" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        <span asp-validation-for="PatientName" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="PatientPhone" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Phone</label>
                        <input asp-for="PatientPhone" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        <span asp-validation-for="PatientPhone" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="PatientEmail" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Email</label>
                    <input asp-for="PatientEmail" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                    <span asp-validation-for="PatientEmail" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="Amount" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Amount</label>
                        <input asp-for="Amount" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        <span asp-validation-for="Amount" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="Currency" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Currency</label>
                        <input asp-for="Currency" maxlength="3" class="form-field w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm uppercase focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                        <span asp-validation-for="Currency" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                @if (isSandbox)
                {
                    <div class="flex items-start gap-3">
                        <input asp-for="SandboxAcknowledged" class="mt-1 h-4 w-4 accent-primary-800" />
                        <label asp-for="SandboxAcknowledged" class="text-sm leading-6 text-[#4a4a4a]">I understand this is a test payment and no real money will be collected.</label>
                    </div>
                    <span asp-validation-for="SandboxAcknowledged" class="block text-xs text-red-600"></span>
                }

                <button type="submit" class="glow-button bg-primary-800 px-6 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-all hover:bg-primary-700">
                    @(isSandbox ? "Process Test Payment" : "Pay Now")
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
