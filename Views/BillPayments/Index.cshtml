@model Okafor_.NET.ViewModels.BillPaymentViewModel

@{
    ViewData["Title"] = "Pay a Bill";
    var paymentProvider = ViewData["PaymentProvider"] as string ?? "Mock";
    var isSandbox = ViewData["IsSandbox"] as bool? ?? true;
}

<section class="ok-page-header">
    <div class="mx-auto max-w-site px-4 sm:px-6">
        <p class="ok-kicker">Billing</p>
        <h1 class="ok-page-title mt-3">Pay a Hospital Bill</h1>
        <p class="ok-copy mt-4 max-w-2xl">
            Pay hospital invoices online through the hospital's configured payment provider.
        </p>
    </div>
</section>

<section class="ok-page-band">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
        @if (isSandbox)
        {
            <div class="mb-6 rounded-md border border-amber-200 bg-amber-50 px-5 py-4 text-sm leading-6 text-amber-800" role="status">
                Test mode is active through @paymentProvider. Approved transactions are test records only.
            </div>
        }

        <div class="ok-panel">
            <form asp-action="Index" method="post" class="requires-network ok-widget-body space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="ok-alert" role="alert"></div>

                <div>
                    <label asp-for="InvoiceNumber" class="ok-form-label"></label>
                    <input asp-for="InvoiceNumber" class="ok-field" autocomplete="off" autocapitalize="characters" />
                    <span asp-validation-for="InvoiceNumber" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="PatientName" class="ok-form-label">Patient Name</label>
                        <input asp-for="PatientName" class="ok-field" autocomplete="name" />
                        <span asp-validation-for="PatientName" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="PatientPhone" class="ok-form-label">Phone</label>
                        <input asp-for="PatientPhone" class="ok-field" type="tel" inputmode="tel" autocomplete="tel" />
                        <span asp-validation-for="PatientPhone" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="PatientEmail" class="ok-form-label">Email</label>
                    <input asp-for="PatientEmail" class="ok-field" type="email" inputmode="email" autocomplete="email" />
                    <span asp-validation-for="PatientEmail" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="Amount" class="ok-form-label">Amount</label>
                        <input asp-for="Amount" class="ok-field" inputmode="decimal" autocomplete="off" />
                        <span asp-validation-for="Amount" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                    <div>
                        <label asp-for="Currency" class="ok-form-label">Currency</label>
                        <input asp-for="Currency" maxlength="3" class="ok-field uppercase" autocomplete="off" autocapitalize="characters" />
                        <span asp-validation-for="Currency" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                @if (isSandbox)
                {
                    <div class="flex items-start gap-3">
                        <input asp-for="SandboxAcknowledged" class="mt-1 h-4 w-4 accent-primary-800" />
                        <label asp-for="SandboxAcknowledged" class="ok-small-copy">I understand this is a test payment and no real money will be collected.</label>
                    </div>
                    <span asp-validation-for="SandboxAcknowledged" class="block text-xs text-red-600"></span>
                }

                <button type="submit" class="ok-btn ok-btn-primary w-full sm:w-auto">
                    @(isSandbox ? "Process Test Payment" : "Pay Now")
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
