@model Okafor_.NET.Models.Donation

@{
    ViewData["Title"] = "Donation Interest Received";
}

<section class="border-b border-secondary-300 bg-secondary-100 py-14">
    <div class="mx-auto max-w-site px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Support the Hospital</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-[#1c1c1c]">Thank you. Your donation interest was received.</h1>
        <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[#4a4a4a]">
            No payment was taken. Hospital staff will use the contact information you provided to help you arrange the donation safely.
        </p>
    </div>
</section>

<section class="bg-secondary-100 py-16">
    <div class="mx-auto max-w-3xl px-6">
        <div class="border border-secondary-300 bg-white p-8 shadow-sm">
            <div class="border-b border-secondary-300 pb-6">
                <h2 class="font-serif text-2xl font-bold text-[#1c1c1c]">Donation interest summary</h2>
                <p class="mt-2 text-sm leading-6 text-[#5c5c5c]">Keep this private reference if you need to contact the hospital about your submission.</p>
            </div>

            <div class="grid gap-5 py-6 md:grid-cols-2">
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Intended amount</p>
                    <p class="mt-1 text-xl font-semibold text-[#1c1c1c]">@Model.Currency @Model.Amount.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Purpose</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Okafor_.NET.Models.DonationPurposeCodes.GetDisplayName(Model.PurposeCode)</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Preferred arrangement</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Okafor_.NET.Models.DonationMethodCodes.GetDisplayName(Model.PreferredMethod)</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Private reference</p>
                    <p class="mt-1 break-all text-base font-semibold text-primary-800">@Model.PaymentReference</p>
                </div>
            </div>

            <div class="border-t border-secondary-300 pt-6 text-sm leading-6 text-[#5c5c5c]">
                <p>This confirmation records your interest only. It is not a payment receipt and does not confirm that the hospital received funds.</p>
            </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
            <a asp-controller="Home" asp-action="Index" class="ok-btn ok-btn-primary w-full sm:w-auto">Return home</a>
            <a asp-controller="Home" asp-action="Contact" class="ok-btn ok-btn-secondary w-full sm:w-auto">Contact the hospital</a>
        </div>
    </div>
</section>
