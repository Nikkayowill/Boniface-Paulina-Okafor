@model Okafor_.NET.Models.Donation

@{
    ViewData["Title"] = "Donation Receipt";
}

<style>
    @@media print {
        .receipt-actions {
            display: none !important;
        }
    }
</style>

<section class="border-b border-secondary-300 bg-secondary-100 py-14">
    <div class="mx-auto max-w-site px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Donation Receipt</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-[#1c1c1c]">Thank you for your donation</h1>
        <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[#4a4a4a]">
            Your donation has been recorded. Please keep this receipt for your records.
        </p>
    </div>
</section>

<section class="bg-secondary-100 py-16">
    <div class="mx-auto max-w-3xl px-6">
        <div class="border border-secondary-300 bg-secondary-100 p-8 shadow-sm">
            <div class="border-b border-secondary-300 pb-6">
                <h2 class="font-serif text-2xl font-bold text-[#1c1c1c]">Boniface &amp; Paulina Okafor Memorial Hospital</h2>
                <p class="mt-2 text-sm text-[#5c5c5c]">Donation receipt confirmation</p>
            </div>

            <div class="grid gap-5 py-6 md:grid-cols-2">
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Donation Amount</p>
                    <p class="mt-1 text-xl font-semibold text-[#1c1c1c]">@Model.Currency @Model.Amount.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Date</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Receipt / Reference Number</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Model.PaymentReference</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Receipt ID</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Model.Id</p>
                </div>
            </div>

            <div class="border-t border-secondary-300 pt-6 text-sm text-[#5c5c5c]">
                <p>For official tax documentation, please contact the hospital directly.</p>
            </div>
        </div>

        <div class="receipt-actions mt-6 flex flex-wrap gap-3">
            <button type="button" onclick="window.print()" class="bg-primary-800 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-white transition-colors hover:bg-primary-700">
                Print Receipt
            </button>
            <a asp-controller="Donation" asp-action="Index" class="border border-secondary-400 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c] transition-colors hover:border-primary-700 hover:text-primary-700">
                Back to Donation
            </a>
        </div>
    </div>
</section>