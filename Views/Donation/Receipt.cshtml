@model Okafor_.NET.Models.Donation

@{
    ViewData["Title"] = "Donation Receipt";
    ViewData["Robots"] = "noindex,nofollow";
    var isSuccessful = Model.Status is Okafor_.NET.Models.DonationStatus.Paid or Okafor_.NET.Models.DonationStatus.SandboxApproved;
    var isPending = Model.Status == Okafor_.NET.Models.DonationStatus.Pending;
    var heading = isSuccessful
        ? "Thank you for your donation"
        : isPending
            ? "Donation awaiting confirmation"
            : "Donation not completed";
}

<style>
    @@media print {
        .receipt-actions {
            display: none !important;
        }
    }
</style>

<section class="site-page-header">
    <div class="site-page-header__inner">
        <p class="site-page-kicker">Donation Receipt</p>
        <h1 class="site-page-title mt-3">@heading</h1>
        <p class="site-page-lede mt-4 max-w-2xl">
            Your donation status is shown below. A receipt is valid only after the payment is confirmed.
        </p>
    </div>
</section>

<section class="site-page-surface">
    <div class="mx-auto max-w-3xl px-6">
        <div class="site-card p-6 sm:p-8">
            <div class="border-b border-secondary-300 pb-6">
                <h2 class="font-serif text-2xl font-bold text-[#1c1c1c]">Boniface &amp; Paulina Okafor Memorial Hospital</h2>
                <p class="mt-2 text-sm text-[#5c5c5c]">Donation receipt confirmation</p>
                @if (Model.IsSandbox)
                {
                    <div class="mt-4 border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                        Test transaction. No real money was collected.
                    </div>
                }
                @if (isPending)
                {
                    <div class="mt-4 border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-900" role="status">
                        The provider has not confirmed this donation. Do not submit it again if money was deducted.
                    </div>
                }
                else if (!isSuccessful)
                {
                    <div class="mt-4 border border-red-200 bg-red-50 px-4 py-3 text-sm leading-6 text-red-900" role="alert">
                        No successful donation was recorded for this attempt.
                    </div>
                }
            </div>

            <div class="grid gap-5 py-6 md:grid-cols-2">
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Status</p>
                    <p class="mt-1 text-xl font-semibold text-[#1c1c1c]">@Model.Status</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Donation Amount</p>
                    <p class="mt-1 text-xl font-semibold text-[#1c1c1c]">@Model.Currency @Model.Amount.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Donation Purpose</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Okafor_.NET.Models.DonationPurposeCodes.GetDisplayName(Model.PurposeCode)</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Date</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Receipt / Payment Reference</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Model.PaymentReference</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Receipt ID</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Model.Id</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Provider</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@Model.Provider</p>
                </div>
                <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#6a6a6a]">Channel</p>
                    <p class="mt-1 text-base text-[#1c1c1c]">@(Model.Channel ?? "-")</p>
                </div>
            </div>

            <div class="border-t border-secondary-300 pt-6 text-sm text-[#5c5c5c]">
                <p>Donations are separate from care fees and do not guarantee or prioritize an appointment. For official tax documentation, please contact the hospital directly.</p>
            </div>
        </div>

        <div class="receipt-actions mt-6 flex flex-wrap gap-3">
            @if (isSuccessful)
            {
                <button type="button" onclick="window.print()" class="ok-btn ok-btn-primary w-full sm:w-auto">Print Receipt</button>
            }
            <a asp-controller="Donation" asp-action="Index" class="ok-btn ok-btn-secondary w-full sm:w-auto">@(isSuccessful ? "Make another donation" : "Return to donation form")</a>
            <a asp-controller="Home" asp-action="Contact" class="ok-btn ok-btn-secondary w-full sm:w-auto">Contact support</a>
        </div>
    </div>
</section>
