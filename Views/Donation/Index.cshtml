@model Okafor_.NET.ViewModels.DonationCheckoutViewModel

@{
    ViewData["Title"] = "Make a Donation";
    var provider = ViewData["PaymentProvider"] as string ?? "Paystack";
    var isSandbox = ViewData["IsSandbox"] as bool? == true;
}

<section class="border-b border-secondary-300 bg-secondary-100 py-14">
    <div class="mx-auto max-w-site px-6">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-primary-800">Support the Hospital</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-[#1c1c1c]">Make a secure online donation</h1>
        <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[#4a4a4a]">
            Choose an amount and continue to @provider's secure hosted checkout. The hospital does not receive or store your card or bank credentials.
        </p>
    </div>
</section>

<section class="bg-secondary-100 py-16">
    <div class="mx-auto max-w-site px-6">
        <div class="grid gap-8 lg:grid-cols-12">
            <div class="border border-secondary-300 bg-white p-8 lg:col-span-7">
                <h2 class="font-serif text-2xl font-bold text-[#1c1c1c]">Donation details</h2>
                <p class="mt-1 text-sm text-[#5c5c5c]">Your email is required by the payment provider and is used for your donation receipt.</p>

                @if (isSandbox)
                {
                    <div class="mt-5 border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-900" role="status">
                        Demo mode is active. This checkout does not collect real money.
                    </div>
                }

                <form asp-controller="Donation" asp-action="Index" method="post" class="requires-network mt-6 space-y-5">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

                    <div class="grid gap-5 md:grid-cols-2">
                        <div>
                            <label asp-for="DonorName" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Donor name</label>
                            <input asp-for="DonorName" autocomplete="name" class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                            <span asp-validation-for="DonorName" class="mt-1 block text-xs text-red-600"></span>
                        </div>
                        <div>
                            <label asp-for="DonorEmail" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Email</label>
                            <input asp-for="DonorEmail" type="email" autocomplete="email" class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" placeholder="you@example.com" />
                            <span asp-validation-for="DonorEmail" class="mt-1 block text-xs text-red-600"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="DonorPhone" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Phone / WhatsApp <span class="font-normal text-[#888]">(optional)</span></label>
                        <input asp-for="DonorPhone" inputmode="tel" autocomplete="tel" class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" placeholder="+234..." />
                        <span asp-validation-for="DonorPhone" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <div class="grid gap-5 md:grid-cols-2">
                        <div>
                            <label asp-for="Amount" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Amount</label>
                            <input asp-for="Amount" type="number" min="0.01" step="0.01" inputmode="decimal" class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800" />
                            <span asp-validation-for="Amount" class="mt-1 block text-xs text-red-600"></span>
                        </div>
                        <div>
                            <label asp-for="Currency" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Currency</label>
                            <input asp-for="Currency" readonly aria-readonly="true" class="w-full border border-secondary-300 bg-secondary-100 px-3.5 py-2.5 text-sm uppercase text-[#1c1c1c]" />
                            <span asp-validation-for="Currency" class="mt-1 block text-xs text-red-600"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="PurposeCode" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Donation purpose</label>
                        <select asp-for="PurposeCode" asp-items="ViewBag.DonationPurposes" class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800"></select>
                        <span asp-validation-for="PurposeCode" class="mt-1 block text-xs text-red-600"></span>
                        <p class="mt-2 text-xs leading-5 text-[#5c5c5c]">Donations are optional, separate from care fees, and do not guarantee or prioritize an appointment.</p>
                    </div>

                    <div>
                        <label asp-for="DonorMessage" class="mb-1.5 block text-[11px] font-semibold uppercase tracking-[0.12em] text-[#3c3c3c]">Message <span class="font-normal text-[#888]">(optional)</span></label>
                        <textarea asp-for="DonorMessage" rows="3" class="w-full border border-secondary-300 bg-white px-3.5 py-2.5 text-sm text-[#1c1c1c] focus:border-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-800"></textarea>
                        <span asp-validation-for="DonorMessage" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <button type="submit" class="ok-btn ok-btn-primary w-full sm:w-auto">
                        Continue to secure checkout
                    </button>
                </form>
            </div>

            <aside class="border border-secondary-300 bg-secondary-100 p-6 lg:col-span-5">
                <h2 class="font-serif text-xl font-bold text-[#1c1c1c]">How payment works</h2>
                <ol class="mt-4 space-y-3 text-sm leading-6 text-[#4a4a4a]">
                    <li><strong>1.</strong> Enter your donation details here.</li>
                    <li><strong>2.</strong> Complete payment on @provider's encrypted checkout.</li>
                    <li><strong>3.</strong> Return automatically for server-verified confirmation and a receipt.</li>
                </ol>
                <p class="mt-5 border-t border-secondary-300 pt-4 text-sm leading-6 text-[#5c5c5c]">
                    If checkout fails before payment, no donation is recorded as paid. If your account is debited but confirmation is delayed, do not pay again; contact the hospital with your reference.
                </p>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
