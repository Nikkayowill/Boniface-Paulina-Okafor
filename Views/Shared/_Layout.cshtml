@using Microsoft.AspNetCore.Identity
@using Okafor_.NET.Models
@using System.Text.Json
@inject SignInManager<ApplicationUser> SignInManager
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@inject Okafor_.NET.Services.ILaunchFeatureAvailability LaunchFeatures
@inject Okafor_.NET.Services.SeoUrlService SeoUrls

@{
    var hospitalName = Configuration["Hospital:Name"] ?? "Boniface and Paulina Okafor Memorial Hospital";
    var hospitalAddress = Configuration["Hospital:Address"] ?? "Ndibemaduka Compound, Umudim Ngodo Isuochi, Umunneochi L.G.A, Abia State, Nigeria";
    var hospitalEmail = Configuration["Hospital:Email"] ?? "info@okaformemorial.org";
    var emergencyNumbers = Configuration["Hospital:EmergencyNumbers"] ?? "112 / 199";
    var hospitalWhatsApp = Okafor_.NET.Services.NigerianPhoneNumber.NormalizeForWhatsApp(
        Configuration["Notifications:WhatsAppNumber"] ?? Configuration["Notifications:AdminPhone"] ?? string.Empty);
    var whatsAppMessage = Uri.EscapeDataString(
        "Hello, I would like to book an appointment at Boniface & Paulina Okafor Memorial Hospital.\n\n" +
        "My name is:\n" +
        "Reason for visit:\n" +
        "Preferred day/time:");
    var metaDescription = ViewData["MetaDescription"] as string
        ?? "Boniface and Paulina Okafor Memorial Hospital in Umudim Ngodo Isuochi, Umunneochi L.G.A, Abia State, Nigeria, offering appointments, teleconsultations, departments, doctors, patient resources, and hospital services.";
    var robotsContent = ViewData["Robots"] as string ?? "index,follow";
    var titleText = ViewData["PageTitle"] as string ??
        (string.Equals(ViewData["Title"] as string, "Home", StringComparison.OrdinalIgnoreCase)
            ? hospitalName
            : $"{ViewData["Title"]} | {hospitalName}");
    var canonicalPath = ViewData["CanonicalPath"] as string ?? Context.Request.Path.Value ?? "/";
    var canonicalUrl = SeoUrls.Absolute(canonicalPath);
    var socialImage = SeoUrls.Absolute(
        ViewData["SocialImage"] as string ?? "/images/placeholders/Hospital/GOEH7326.webp");
    var openGraphType = ViewData["OpenGraphType"] as string ?? "website";
    var organizationSchema = JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@graph"] = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@type"] = "Hospital",
                ["@id"] = $"{SeoUrls.BaseUrl}/#hospital",
                ["name"] = hospitalName,
                ["url"] = $"{SeoUrls.BaseUrl}/",
                ["logo"] = SeoUrls.Absolute("/images/icons/okafor-hospital-icon.svg"),
                ["image"] = socialImage,
                ["address"] = new Dictionary<string, object?>
                {
                    ["@type"] = "PostalAddress",
                    ["streetAddress"] = "Ndibemaduka Compound, Umudim Ngodo Isuochi",
                    ["addressLocality"] = "Umunneochi",
                    ["addressRegion"] = "Abia State",
                    ["addressCountry"] = "NG"
                },
                ["email"] = hospitalEmail
            },
            new Dictionary<string, object?>
            {
                ["@type"] = "WebSite",
                ["@id"] = $"{SeoUrls.BaseUrl}/#website",
                ["url"] = $"{SeoUrls.BaseUrl}/",
                ["name"] = hospitalName,
                ["publisher"] = new Dictionary<string, string>
                {
                    ["@id"] = $"{SeoUrls.BaseUrl}/#hospital"
                },
                ["inLanguage"] = "en-NG"
            }
        }
    });
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@titleText</title>
    <meta name="description" content="@metaDescription" />
    <meta name="robots" content="@robotsContent" />
    <link rel="canonical" href="@canonicalUrl" />
    <link rel="alternate" type="application/rss+xml" title="Hospital Notes from Isuochi" href="@SeoUrls.Absolute("/feed.xml")" />
    <meta property="og:site_name" content="@hospitalName" />
    <meta property="og:locale" content="en_NG" />
    <meta property="og:type" content="@openGraphType" />
    <meta property="og:title" content="@titleText" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:image" content="@socialImage" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@titleText" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image" content="@socialImage" />
    <meta name="theme-color" content="#0a5f8f" />
    <link rel="manifest" href="@Url.Content("~/site.webmanifest")" />
    <link rel="icon" href="@Url.Content("~/images/icons/okafor-hospital-icon.svg")" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="@Url.Content("~/images/icons/apple-touch-icon.png")" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/public-site.css" asp-append-version="true" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script type="application/ld+json">@Html.Raw(organizationSchema)</script>
    @await RenderSectionAsync("Head", required: false)
</head>

<body class="bg-bone-50 text-slate-950">

    <!-- TOP UTILITY BAR -->
    <div class="top-utility-bar bg-primary-950">
        <div class="mx-auto flex max-w-site flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-6">
            <div class="top-utility-group flex flex-wrap items-center gap-x-6 gap-y-2 text-primary-100">
                <a href="tel:112" class="flex items-center gap-1.5 hover:text-white transition-colors duration-150">
                    <svg class="h-4 w-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
                    </svg>
                    Emergency: @emergencyNumbers
                </a>
                <a href="mailto:@hospitalEmail" class="hidden items-center gap-1.5 hover:text-white transition-colors duration-150 sm:flex">
                    <svg class="h-4 w-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                    </svg>
                    @hospitalEmail
                </a>
            </div>
            <div class="top-utility-group flex flex-wrap items-center gap-x-4 gap-y-2 text-primary-100">
                <a asp-area="" asp-controller="Donation" asp-action="Index" class="hover:text-white transition-colors duration-150">Donate</a>
                <span class="text-primary-700" aria-hidden="true">/</span>
                <a asp-area="" asp-controller="Home" asp-action="PatientInformationHub" class="hover:text-white transition-colors duration-150">Patient Info</a>
                <span class="text-primary-700" aria-hidden="true">/</span>
                <a asp-area="" asp-controller="Home" asp-action="Contact" class="hover:text-white transition-colors duration-150">Contact</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="text-primary-700" aria-hidden="true">/</span>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="hover:text-white transition-colors duration-150">Admin</a>
                        <span class="text-primary-700" aria-hidden="true">/</span>
                    }
                    <a asp-area="Patient" asp-controller="Dashboard" asp-action="Index" class="hover:text-white transition-colors duration-150">My Portal</a>
                    <span class="text-primary-700" aria-hidden="true">/</span>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" class="inline">
                        <button type="submit" class="hover:text-white transition-colors duration-150">Logout</button>
                    </form>
                }
                else
                {
                    <span class="text-primary-700" aria-hidden="true">/</span>
                    <a asp-area="Identity" asp-page="/Account/Login" class="hover:text-white transition-colors duration-150" data-offline-login-warning>Login</a>
                }
            </div>
        </div>
    </div>

    <!-- MAIN NAVIGATION -->
    <header class="site-header border-b border-gray-100 bg-white sticky top-0 z-50 transition-all duration-300"
            data-site-header>
        <div class="site-header__inner mx-auto flex max-w-site items-center justify-between gap-4 px-4 py-3 transition-all duration-300 sm:px-6 md:py-5">

            <!-- Logo -->
            <a asp-area="" asp-controller="Home" asp-action="Index" class="site-brand min-w-0 flex items-center gap-3 leading-none transition-transform duration-300 hover:scale-[1.01]">
                <img src="@Url.Content("~/images/icons/okafor-navbar-logo.svg")" alt="" class="site-brand__mark" width="48" height="48" />
                <span class="site-brand__text">
                    <span class="site-brand__eyebrow">Boniface &amp; Paulina Okafor</span>
                    <span class="site-brand__name">Memorial Hospital</span>
                </span>
            </a>

            <!-- Mobile toggle -->
            <button type="button"
                    id="mobile-menu-toggle"
                    class="mobile-menu-button flex items-center gap-2 border border-gray-200 px-4 py-2 font-semibold uppercase tracking-widest text-[#1c1c1c] transition-all duration-300 hover:-translate-y-0.5 hover:border-primary-800 hover:text-primary-800 hover:shadow-sm lg:hidden"
                    aria-controls="site-mobile-menu"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
                Menu
            </button>

            <!-- Desktop nav -->
            <nav class="desktop-nav hidden items-center gap-5 font-semibold uppercase tracking-[0.08em] text-[#3c3c3c] lg:flex" aria-label="Primary navigation">
                <a asp-area="" asp-controller="Home" asp-action="About"    class="nav-link hover:text-primary-700 transition-colors duration-150">About</a>
                <a asp-area="" asp-controller="Home" asp-action="Services" class="nav-link hover:text-primary-700 transition-colors duration-150">Services</a>
                <a asp-area="" asp-controller="Home" asp-action="Team"     class="nav-link hover:text-primary-700 transition-colors duration-150">Doctors &amp; Team</a>
                <a asp-area="" asp-controller="Home" asp-action="PatientInformationHub" class="nav-link hover:text-primary-700 transition-colors duration-150">Patient Info</a>
                <a asp-area="" asp-controller="Home" asp-action="Search"   class="nav-link nav-link--search hover:text-primary-700 transition-colors duration-150">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m21 21-4.35-4.35m1.35-5.4A6.75 6.75 0 1 1 4.5 11.25a6.75 6.75 0 0 1 13.5 0Z" />
                    </svg>
                    Search
                </a>
            </nav>

            <!-- Book Appointment CTA -->
            <a asp-area="" asp-controller="AppointmentRequests" asp-action="Create"
               data-live-feature="appointment"
               class="glow-button hidden items-center gap-2 bg-primary-800 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary-700 lg:inline-flex">
                Request Appointment
                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
            </a>
        </div>

        <!-- Mobile menu -->
        <div id="site-mobile-menu"
             class="site-mobile-menu border-t border-gray-100 bg-white/95 backdrop-blur-md lg:hidden">
            <nav class="mobile-nav mx-auto flex max-w-site flex-col gap-1 px-4 py-4 sm:px-6" aria-label="Mobile navigation">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="mobile-nav-link">Home</a>
                <a asp-area="" asp-controller="Home" asp-action="About" class="mobile-nav-link">About</a>
                <a asp-area="" asp-controller="Home" asp-action="Services" class="mobile-nav-link">Services</a>
                <a asp-area="" asp-controller="Home" asp-action="Team" class="mobile-nav-link">Doctors &amp; Team</a>
                <a asp-area="" asp-controller="Home" asp-action="PatientInformationHub" class="mobile-nav-link">Patient Info</a>
                <a asp-area="" asp-controller="Home" asp-action="News" class="mobile-nav-link">News</a>
                <a asp-area="" asp-controller="Home" asp-action="Search" class="mobile-nav-link">Search hospital information</a>
                <a asp-area="" asp-controller="Home" asp-action="Contact" class="mobile-nav-link">Contact</a>
                <a asp-area="" asp-controller="Donation" asp-action="Index" class="mobile-nav-link mobile-nav-link--donate">Donate</a>
                <div class="border-t border-gray-100 pt-4">
                    <a asp-area="" asp-controller="AppointmentRequests" asp-action="Create"
                       data-live-feature="appointment"
                       class="mobile-nav-cta bg-primary-800 text-white hover:bg-primary-700">
                        Request Appointment
                    </a>
                    <a asp-area="" asp-controller="Teleconsultations" asp-action="Create"
                       data-live-feature="teleconsultation"
                       class="mobile-nav-cta mt-3 border border-primary-200 text-primary-950 hover:border-primary-700 hover:text-primary-700">
                        Ask About Teleconsultation
                    </a>
                </div>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-primary-950 text-primary-100">
        <div class="mx-auto max-w-site px-6 pt-16 pb-10">
            <div class="grid gap-14 lg:grid-cols-12">

                <!-- Brand -->
                <div class="lg:col-span-5">
                    <p class="text-[9px] font-semibold uppercase tracking-[0.22em] text-primary-400">Boniface &amp; Paulina Okafor</p>
                    <h2 class="mt-1.5 text-[28px] font-bold leading-tight text-white">Memorial Hospital</h2>
                    <p class="mt-5 max-w-sm text-[13px] leading-7 text-primary-200">
                        Rooted in memory, service, and community care, we support patients and families with thoughtful treatment, clear guidance, and a steady commitment to dignity.
                    </p>
                    <div class="mt-8">
                        <a asp-controller="Donation" asp-action="Index"
                           class="glow-button inline-flex items-center gap-2 bg-primary-800 px-5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.14em] text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary-700">
                            Donate
                            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Nav columns -->
                <div class="lg:col-span-7 grid grid-cols-2 gap-10 md:grid-cols-3">
                    <div>
                        <h3 class="text-[9px] font-semibold uppercase tracking-[0.2em] text-primary-500">Hospital</h3>
                        <ul class="mt-4 space-y-3 text-[13px] text-primary-200">
                            <li><a asp-area="" asp-controller="Home" asp-action="About"    class="hover:text-white transition-colors">About Us</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="Services" class="hover:text-white transition-colors">Services</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="Team"     class="hover:text-white transition-colors">Doctors &amp; Team</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="News"     class="hover:text-white transition-colors">News &amp; Health Blog</a></li>
                            <li><a href="https://www.nigeriafamilyhelperprogram.org/boniface-and-paulina-okafor-hospital" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Nigeria Family Helper Program</a></li>
                        </ul>
                    </div>
                    <div>
                        <h3 class="text-[9px] font-semibold uppercase tracking-[0.2em] text-primary-500">Patients</h3>
                        <ul class="mt-4 space-y-3 text-[13px] text-primary-200">
                            <li><a asp-area="" asp-controller="AppointmentRequests" asp-action="Create" class="hover:text-white transition-colors" data-live-feature="appointment">Book Appointment</a></li>
                            <li><a asp-area="" asp-controller="Teleconsultations" asp-action="Create" class="hover:text-white transition-colors" data-live-feature="teleconsultation">Book Teleconsultation</a></li>
                            @if (LaunchFeatures.IsEnabled(Okafor_.NET.Services.LaunchFeature.BillPayments))
                            {
                                <li><a asp-area="" asp-controller="BillPayments" asp-action="Index" class="hover:text-white transition-colors" data-live-feature="billing">Pay a Bill</a></li>
                            }
                            <li><a asp-area="" asp-controller="Donation" asp-action="Index" class="hover:text-white transition-colors">Donate</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="PatientInformationHub" class="hover:text-white transition-colors">Patient Information Hub</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="Contact"               class="hover:text-white transition-colors">Contact Us</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="Privacy"               class="hover:text-white transition-colors">Privacy Policy</a></li>
                        </ul>
                    </div>
                    <div>
                        <h3 class="text-[9px] font-semibold uppercase tracking-[0.2em] text-primary-500">Contact</h3>
                        <ul class="mt-4 space-y-3 text-[13px] text-primary-200">
                            <li class="leading-6">@hospitalAddress</li>
                            <li><a href="tel:112" class="hover:text-white transition-colors">Emergency: @emergencyNumbers</a></li>
                            <li><a href="mailto:@hospitalEmail" class="hover:text-white transition-colors">@hospitalEmail</a></li>
                            <li class="text-primary-400">Mon - Sat &nbsp;8am - 6pm</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Bottom bar -->
            <div class="mt-14 flex flex-col gap-2 border-t border-primary-900 pt-6 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-[11px] text-primary-400">&copy; 2026 Boniface and Paulina Okafor Memorial Hospital. All rights reserved.</p>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-[11px] text-primary-400 transition-colors hover:text-primary-100">Privacy Policy</a>
            </div>
        </div>
    </footer>

    @if (!string.IsNullOrWhiteSpace(hospitalWhatsApp))
    {
        @* Manual WhatsApp click-to-chat link only; this is not WhatsApp Business API integration. *@
        <a class="whatsapp-float"
           href="https://wa.me/@hospitalWhatsApp?text=@whatsAppMessage"
           target="_blank"
           rel="noopener"
           aria-label="Contact us on WhatsApp to book an appointment">
            <span class="whatsapp-float__icon" aria-hidden="true">
                <svg viewBox="0 0 32 32" focusable="false">
                    <path fill="currentColor" d="M16.04 3.2c-7.04 0-12.76 5.66-12.76 12.62 0 2.23.6 4.41 1.73 6.32L3.2 28.8l6.86-1.77a12.9 12.9 0 0 0 5.98 1.5c7.04 0 12.76-5.66 12.76-12.62S23.08 3.2 16.04 3.2Zm0 23.18c-1.9 0-3.77-.5-5.4-1.44l-.39-.23-4.07 1.05 1.09-3.9-.26-.4a10.3 10.3 0 0 1-1.58-5.64c0-5.77 4.76-10.46 10.61-10.46s10.61 4.69 10.61 10.46-4.76 10.56-10.61 10.56Zm5.82-7.83c-.32-.16-1.9-.93-2.19-1.04-.3-.11-.51-.16-.73.16-.21.31-.84 1.04-1.03 1.25-.19.21-.38.24-.7.08-.32-.16-1.35-.49-2.58-1.57-.95-.84-1.6-1.88-1.79-2.2-.19-.31-.02-.48.14-.64.15-.15.32-.38.49-.57.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.73-1.74-1-2.38-.26-.62-.53-.54-.73-.55h-.62c-.21 0-.56.08-.86.4-.3.31-1.13 1.09-1.13 2.66s1.16 3.09 1.32 3.3c.16.21 2.28 3.44 5.52 4.82.77.33 1.37.53 1.84.68.77.24 1.47.21 2.03.13.62-.09 1.9-.77 2.17-1.52.27-.75.27-1.39.19-1.52-.08-.13-.29-.21-.61-.37Z" />
                </svg>
            </span>
            <span class="whatsapp-float__text">Contact Us</span>
        </a>
    }

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/js/navigation.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/offline-state.js" asp-append-version="true"></script>
    <script src="~/js/encrypted-offline-store.js" asp-append-version="true"></script>
    @if (HostEnvironment.IsDevelopment() || HostEnvironment.IsEnvironment("E2E"))
    {
        <script src="~/js/pwa-development-reset.js" asp-append-version="true"></script>
    }
    else
    {
        <script src="~/js/pwa-register.js" asp-append-version="true"></script>
    }
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/booking-realtime.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
