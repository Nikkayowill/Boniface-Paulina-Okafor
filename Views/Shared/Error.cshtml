@model ErrorViewModel
@{
    ViewData["Title"] = "We could not complete that request";
    ViewData["Robots"] = "noindex,nofollow";
}

<section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-24">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary-800">Temporary problem</p>
        <h1 class="mt-3 text-3xl font-bold leading-tight text-slate-950 sm:text-5xl">We could not complete that request.</h1>
        <p class="mx-auto mt-5 max-w-xl text-base leading-7 text-slate-600">
            Your request was not completed. Please try again, return to the home page, or contact the hospital if you still need help.
        </p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
            <a asp-controller="Home" asp-action="Index" class="glow-button inline-flex min-h-12 items-center justify-center bg-primary-800 px-6 py-3 text-sm font-semibold text-white transition hover:bg-primary-700">
                Return home
            </a>
            <a asp-controller="Home" asp-action="Contact" class="inline-flex min-h-12 items-center justify-center border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-primary-700 hover:text-primary-800">
                Contact the hospital
            </a>
        </div>
        @if (Model.ShowRequestId)
        {
            <p class="mt-8 text-xs text-slate-500">
                Support reference: <code class="break-all rounded bg-slate-100 px-2 py-1 text-slate-700">@Model.RequestId</code>
            </p>
        }
    </div>
</section>
