#!/usr/bin/env sh

current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ "$current_branch" = "main" ] || [ "$current_branch" = "master" ]; then
  echo "Direct pushes from '$current_branch' are blocked."
  echo "Create a feature branch and open a pull request instead."
  exit 1
fi

while read local_ref local_sha remote_ref remote_sha
do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      echo "Direct pushes to '$remote_ref' are blocked."
      echo "Push your feature branch and open a pull request instead."
      exit 1
      ;;
  esac
done

exit 0
