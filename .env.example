# Copy to .env and set a strong SA_PASSWORD before running docker compose
SA_PASSWORD=Your_password123
# ACCEPT_EULA is required by the SQL Server container
ACCEPT_EULA=Y

# Brevo SMTP email. Keep real values in your local .env or deployment secrets.
Email__SmtpHost=smtp-relay.brevo.com
Email__Port=587
Email__EnableSsl=true
Email__FromAddress=info@okaformemorial.org
Email__Username=REPLACE_WITH_BREVO_SMTP_LOGIN
Email__Password=REPLACE_WITH_BREVO_SMTP_KEY

# Optional Sentry error tracking. Leave blank to keep Sentry disabled locally.
SENTRY_DSN=
