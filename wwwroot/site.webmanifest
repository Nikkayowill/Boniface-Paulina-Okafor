{
  "name": "Boniface and Paulina Okafor Memorial Hospital",
  "short_name": "Okafor Hospital",
  "description": "Patient resources, appointments, departments, doctors, and hospital information for Okafor Memorial Hospital.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#0a5f8f",
  "orientation": "portrait-primary",
  "categories": ["health", "medical", "lifestyle"],
  "icons": [
